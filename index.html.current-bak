 <!-- 链上信号：聪明钱 / KOL / 巨鲸 -->
<style>
.sm-panel{background:linear-gradient(135deg,rgba(124,58,237,.08) 0%,rgba(255,255,255,.03) 100%);border:1px solid rgba(124,58,237,.2);border-radius:18px;overflow:hidden;position:relative;}
.sm-panel::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,rgba(124,58,237,.6),transparent);}
.sm-panel.green{background:linear-gradient(135deg,rgba(52,211,153,.07) 0%,rgba(255,255,255,.02) 100%);border-color:rgba(52,211,153,.2);}
.sm-panel.green::before{background:linear-gradient(90deg,transparent,rgba(52,211,153,.5),transparent);}
.sm-panel.amber{background:linear-gradient(135deg,rgba(251,191,36,.07) 0%,rgba(255,255,255,.02) 100%);border-color:rgba(251,191,36,.2);}
.sm-panel.amber::before{background:linear-gradient(90deg,transparent,rgba(251,191,36,.5),transparent);}
.sm-head{padding:14px 18px;border-bottom:1px solid rgba(255,255,255,.06);display:flex;align-items:center;justify-content:space-between;}
.sm-icon{width:32px;height:32px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:16px;background:rgba(124,58,237,.15);margin-right:10px;}
.sm-panel.green .sm-icon{background:rgba(52,211,153,.12);}
.sm-panel.amber .sm-icon{background:rgba(251,191,36,.12);}
.sm-title{font-size:12px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--tx2);}
.sm-sub{font-size:10px;color:var(--tx3);margin-top:1px;}
.sm-badge{font-size:9px;padding:2px 7px;border-radius:8px;font-weight:700;letter-spacing:.5px;}
.sm-row{display:flex;align-items:center;justify-content:space-between;padding:11px 18px;border-bottom:1px solid rgba(255,255,255,.04);transition:background .15s;cursor:pointer;}
.sm-row:hover{background:rgba(255,255,255,.04);}
.sm-row:last-child{border-bottom:none;}
.sm-sym{font-size:14px;font-weight:800;color:var(--tx);}
.sm-meta{font-size:10px;color:var(--tx3);margin-top:2px;}
