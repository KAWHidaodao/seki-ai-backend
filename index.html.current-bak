              <div style="color:#a78bfa">fundJob(uint256 jobId)</div>
              <div style="color:#a78bfa">cancelJob(uint256 jobId)</div>
              <div style="color:#a78bfa">claimRefund(uint256 jobId)</div>
            </div>
