</div>


<div id="page-my" class="pw" style="display:none">
<div style="max-width:700px;margin:0 auto;padding:80px 20px 60px">

<!-- 页面标题 -->
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:32px">
  <h2 style="font-size:24px;font-weight:900;margin:0">我的</h2>
  <button onclick="refundJob()" class="btns" style="font-size:12px;background:rgba(248,113,113,.1);border-color:rgba(248,113,113,.3);color:#f87171">Job 退款</button>
</div>

<!-- 钱包信息 -->
<div id="my-wallet-info" style="display:none;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.09);border-radius:16px;padding:20px;margin-bottom:20px">
  <div style="font-size:11px;color:var(--tx3);margin-bottom:4px">已连接钱包</div>
  <div id="my-addr" style="font-family:monospace;font-size:13px;color:var(--tx)"></div>
  <div style="display:flex;gap:12px;margin-top:12px;flex-wrap:wrap">
    <div><div style="font-size:11px;color:var(--tx3)">BNB 余额</div><div id="my-bnb" style="font-size:16px;font-weight:700">—</div></div>
    <div><div style="font-size:11px;color:var(--tx3)">活跃委托</div><div id="my-jobs" style="font-size:16px;font-weight:700">—</div></div>
  </div>
</div>
<div id="my-no-wallet" style="text-align:center;padding:40px;color:var(--tx3)">请先连接钱包</div>

<!-- Personal Agent 区块 -->
<style>
.pa-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.09);border-radius:16px;padding:20px;margin-bottom:16px;}
.pa-label{font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--tx3);margin-bottom:8px;}
.pa-row{display:flex;align-items:center;gap:10px;margin-bottom:8px;}
.pa-inp{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:8px;padding:8px 12px;color:var(--tx);font-size:13px;font-family:var(--font);width:100%;box-sizing:border-box;}
.pa-check{width:16px;height:16px;accent-color:var(--p);cursor:pointer;}
.pa-tog{position:relative;width:40px;height:22px;cursor:pointer;}
.pa-tog input{opacity:0;width:0;height:0;}
.pa-tog-slider{position:absolute;inset:0;background:rgba(255,255,255,.12);border-radius:11px;transition:.3s;}
.pa-tog-slider:before{content:'';position:absolute;width:16px;height:16px;left:3px;top:3px;background:#fff;border-radius:50%;transition:.3s;}
.pa-tog input:checked+.pa-tog-slider{background:var(--p);}
.pa-tog input:checked+.pa-tog-slider:before{transform:translateX(18px);}
.pa-btn{padding:8px 16px;border-radius:8px;border:1px solid var(--p);background:rgba(124,58,237,.12);color:var(--p);font-size:12px;font-weight:700;cursor:pointer;transition:all .2s;}
.pa-btn:hover{background:rgba(124,58,237,.25);}
.pa-btn-sm{padding:5px 10px;font-size:11px;}
.pa-status{font-size:12px;padding:6px 12px;border-radius:6px;background:rgba(255,255,255,.04);color:var(--tx3);display:inline-block;}
.pa-hist-item{padding:10px 18px;border-bottom:1px solid rgba(255,255,255,.06);font-size:12px;}
.pa-hist-item:last-child{border-bottom:none;}
</style>

<div class="pa-card">
  <div class="label" style="margin-bottom:16px">🤖 Personal Agent</div>

  <!-- 钱包管理 -->
  <div class="pa-label">代理钱包</div>
  <div id="pa-wallet-locked" style="display:block">
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <button class="pa-btn" onclick="paCreate()">创建新钱包</button>
      <button class="pa-btn" onclick="paImport()">导入私钥</button>
      <button class="pa-btn" onclick="paUnlock()">解锁</button>
    </div>
  </div>
  <div id="pa-wallet-unlocked" style="display:none">
    <div style="font-family:monospace;font-size:12px;color:var(--tx2);margin-bottom:8px" id="pa-addr">—</div>
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:8px">
      <span style="font-size:13px;font-weight:700" id="pa-bal">— BNB</span>
      <button class="pa-btn pa-btn-sm" onclick="paRefBal()">刷新</button>
      <button class="pa-btn pa-btn-sm" onclick="paExport()">导出</button>
      <button class="pa-btn pa-btn-sm" style="color:#f87171;border-color:rgba(248,113,113,.3)" onclick="paLock()">锁定</button>
    </div>
  </div>

  <!-- 执行策略 -->
  <div class="pa-label" style="margin-top:16px">执行策略</div>
  <div class="pa-row">
    <label class="pa-tog"><input type="checkbox" id="pa-auto" onchange="paOnTog()"><span class="pa-tog-slider"></span></label>
    <span style="font-size:13px;color:var(--tx2)">自动执行</span>
  </div>
  <div style="margin-bottom:10px">
    <div style="font-size:11px;color:var(--tx3);margin-bottom:6px">任务类型</div>
    <div style="display:flex;gap:12px">
      <label style="display:flex;align-items:center;gap:5px;font-size:12px;cursor:pointer"><input type="checkbox" class="pa-check" id="pa-t0" checked> 持仓</label>
      <label style="display:flex;align-items:center;gap:5px;font-size:12px;cursor:pointer"><input type="checkbox" class="pa-check" id="pa-t1" checked> 交互</label>
      <label style="display:flex;align-items:center;gap:5px;font-size:12px;cursor:pointer"><input type="checkbox" class="pa-check" id="pa-t2" checked> 早鸟</label>
    </div>
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px">
    <div>
      <div style="font-size:11px;color:var(--tx3);margin-bottom:4px">最低奖励 (BNB)</div>
      <input type="number" class="pa-inp" id="pa-minr" placeholder="0.001" step="0.001" min="0">
    </div>
    <div>
      <div style="font-size:11px;color:var(--tx3);margin-bottom:4px">每日上限</div>
      <input type="number" class="pa-inp" id="pa-maxd" placeholder="10" min="1" max="100">
    </div>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap">
    <button class="pa-btn" onclick="paSave()">保存策略</button>
    <button class="pa-btn" id="pa-start-btn" onclick="paStart()" style="background:rgba(52,211,153,.1);border-color:rgba(52,211,153,.3);color:#34d399">启动执行器</button>
    <button class="pa-btn" id="pa-stop-btn" onclick="paStop()" style="display:none;background:rgba(248,113,113,.1);border-color:rgba(248,113,113,.3);color:#f87171">停止</button>
  </div>
  <div id="pa-smsg" style="display:none;margin-top:8px;font-size:12px;color:var(--gr);padding:6px 10px;background:rgba(52,211,153,.08);border-radius:6px"></div>
</div>

<!-- AI 策略解析 -->
<div class="pa-card">
  <div class="label" style="margin-bottom:12px">✨ AI 帮我配置策略</div>
  <div style="font-size:12px;color:var(--tx3);margin-bottom:10px">用自然语言描述你的策略，AI 自动解析并填入表单</div>
  <textarea id="pa-ai-inp" class="pa-inp" rows="3" placeholder="例：自动完成早鸟任务，奖励至少0.005BNB，每天最多5个" style="resize:vertical;height:70px;margin-bottom:8px"></textarea>
  <div style="display:flex;gap:8px;align-items:center">
    <button class="pa-btn" id="pa-ai-btn" onclick="paAiParse()">解析</button>
    <span id="pa-ai-loading" style="display:none;font-size:12px;color:var(--tx3)">解析中...</span>
  </div>
  <div id="pa-ai-result" style="display:none;margin-top:12px;background:rgba(167,139,250,.06);border:1px solid rgba(167,139,250,.2);border-radius:10px;padding:12px">
    <div id="pa-ai-text" style="font-size:12px;color:var(--tx2);margin-bottom:10px"></div>
    <button class="pa-btn" onclick="paApplyAi()" style="background:rgba(52,211,153,.1);border-color:rgba(52,211,153,.3);color:#34d399">应用此策略</button>
  </div>
</div>

<!-- 链上任务监控 -->
<div class="pa-card">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
    <div class="label" style="margin:0">链上任务</div>
    <button class="pa-btn pa-btn-sm" onclick="paLoadTasks()">刷新</button>
  </div>
  <div id="pa-tasks" style="font-size:12px;color:var(--tx3)">点击刷新加载任务...</div>
</div>

<!-- 执行记录 -->
<div class="pa-card">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
    <div class="label" style="margin:0">执行记录</div>
    <button class="pa-btn pa-btn-sm" onclick="paClearH()" style="color:#f87171;border-color:rgba(248,113,113,.3)">清除</button>
  </div>
  <div id="pa-hist" style="max-height:200px;overflow-y:auto">
    <div style="font-size:12px;color:var(--tx3);text-align:center;padding:20px">暂无记录</div>
  </div>
</div>

<!-- 我的任务 / 委托 -->
<div class="ms">
  <div class="mst on" onclick="myTab('my0',this)">参与中 / 已领取</div>
  <div class="mst" onclick="myTab('my1',this)">我发布的任务</div>
  <div class="tg" id="my0"><div class="empty">连接钱包后查看
    <div id="my-claimed-list"></div>
  </div></div>
  <div class="tg" id="my1" style="display:none"><div class="empty">暂无发布记录</div></div>
</div>

</div>
</div>

<div id="page-logic" class="pw">
 <div style="max-width:900px;margin:0 auto;padding:48px 28px 100px">
 <div style="text-align:center;margin-bottom:56px">
 <div style="display:inline-block;background:linear-gradient(135deg,rgba(124,58,237,.15),rgba(59,130,246,.1));border:1px solid rgba(124,58,237,.25);border-radius:40px;padding:8px 20px;font-size:11px;font-weight:700;letter-spacing:3px;color:var(--p);margin-bottom:20px">ERC-8183 · AI AGENT PROTOCOL</div>
 <h1 style="font-size:36px;font-weight:900;line-height:1.2;margin-bottom:16px">Seki Agent<br><span style="background:linear-gradient(135deg,#7c3aed,#3b82f6);-webkit-background-clip:text;-webkit-text-fill-color:transparent">决策逻辑全解</span></h1>
 <p style="font-size:15px;color:var(--tx2);max-width:560px;margin:0 auto;line-height:1.8">不是黑盒，不是人工操盘。每一个任务的发布，都有公开可查的链上数据和市场信号作为依据。</p>
 </div>
 <div style="margin-bottom:48px">
 <div style="font-size:10px;font-weight:700;letter-spacing:4px;color:var(--tx3);text-transform:uppercase;margin-bottom:20px">CORE LOOP · 核心循环</div>
 <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px">
 <div style="background:rgba(124,58,237,.08);border:1px solid rgba(124,58,237,.25);border-radius:20px;padding:24px;text-align:center">
 <div style="font-size:36px;margin-bottom:12px"></div>
 <div style="font-size:16px;font-weight:900;color:var(--p);margin-bottom:8px">OBSERVE</div>
 <div style="font-size:12px;font-weight:700;color:var(--tx2);margin-bottom:12px">感知</div>
 <div style="font-size:11px;color:var(--tx2);line-height:1.8;text-align:left">· 链上价格/流动性<br>· 任务完成率<br>· taxPool 余额<br>· 资金费率<br>· 买卖盘深度比<br>· 鲸鱼大单追踪<br>· DexScreener 量</div>
 </div>
 <div style="background:rgba(59,130,246,.08);border:1px solid rgba(59,130,246,.25);border-radius:20px;padding:24px;text-align:center">
 <div style="font-size:36px;margin-bottom:12px"></div>
 <div style="font-size:16px;font-weight:900;color:#3b82f6;margin-bottom:8px">THINK</div>
 <div style="font-size:12px;font-weight:700;color:var(--tx2);margin-bottom:12px">决策</div>
 <div style="font-size:11px;color:var(--tx2);line-height:1.8;text-align:left">· 人格自动选择<br>&nbsp;&nbsp;猎手/军师/传令官<br>· 所有信号输入 LLM<br>· 输出任务类型<br>· 计算奖励金额<br>· 决定窗口期(分钟)<br>· 设定持仓门槛</div>
 </div>
 <div style="background:rgba(52,211,153,.06);border:1px solid rgba(52,211,153,.2);border-radius:20px;padding:24px;text-align:center">
 <div style="font-size:36px;margin-bottom:12px">·</div>
 <div style="font-size:16px;font-weight:900;color:#34d399;margin-bottom:8px">ACT</div>
 <div style="font-size:12px;font-weight:700;color:var(--tx2);margin-bottom:12px">执行</div>
 <div style="font-size:11px;color:var(--tx2);line-height:1.8;text-align:left">· 从 taxPool 扣款<br>· 调用合约发任务<br>· 写链上交易记录<br>· 更新 Agent 日志<br>· 每3分钟一次<br>· 失败自动退款</div>
 </div>
 </div>
 <div style="text-align:center;margin-top:12px;font-size:12px;color:var(--tx3)">每 3 分钟自动循环，永不停止</div>
 </div>
 <div style="margin-bottom:48px">
 <div style="font-size:10px;font-weight:700;letter-spacing:4px;color:var(--tx3);text-transform:uppercase;margin-bottom:20px">DATA SOURCES · 信号来源</div>
 <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
 <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:20px">
 <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px"><div style="width:36px;height:36px;border-radius:10px;background:rgba(124,58,237,.15);display:flex;align-items:center;justify-content:center;font-size:18px"></div><div><div style="font-size:13px;font-weight:800">BSC 链上数据</div><div style="font-size:10px;color:var(--tx3)">PancakeSwap AMM · BSCScan</div></div></div>
 <div style="font-size:12px;color:var(--tx2);line-height:2">代币实时价格（BNB计价）<br>流动性池深度<br>任务完成率 &amp; 领取记录<br>taxPool 合约余额<br>job 链上状态同步</div>
 </div>
 <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:20px">
 <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px"><div style="width:36px;height:36px;border-radius:10px;background:rgba(59,130,246,.15);display:flex;align-items:center;justify-content:center;font-size:18px"></div><div><div style="font-size:13px;font-weight:800">市场信号</div><div style="font-size:10px;color:var(--tx3)">链上数据</div></div></div>
 <div style="font-size:12px;color:var(--tx2);line-height:2">BNB 价格 &amp; 24h涨跌幅<br>BNB-USDT-SWAP 资金费率<br>买卖盘深度比（多空力量）<br>鲸鱼大单（3m内 &gt;50 BNB）<br>资金费率历史趋势（3期）</div>
 </div>
 <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:20px">
 <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px"><div style="width:36px;height:36px;border-radius:10px;background:rgba(245,158,11,.15);display:flex;align-items:center;justify-content:center;font-size:18px"></div><div><div style="font-size:13px;font-weight:800">DexScreener 热度</div><div style="font-size:10px;color:var(--tx3)">实时 DEX 成交量</div></div></div>
 <div style="font-size:12px;color:var(--tx2);line-height:2">1h / 6h / 24h 成交量<br>1h 价格涨跌幅<br>10分钟内3x突增检测<br>成交量萎缩告警<br>热度趋势判断</div>
 </div>
 <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:20px">
 <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px"><div style="width:36px;height:36px;border-radius:10px;background:rgba(52,211,153,.15);display:flex;align-items:center;justify-content:center;font-size:18px"></div><div><div style="font-size:13px;font-weight:800">LLM 推理引擎</div><div style="font-size:10px;color:var(--tx3)">GPT-5.4 · 私有部署</div></div></div>
 <div style="font-size:12px;color:var(--tx2);line-height:2">接收所有链上+市场信号<br>结合当前人格角色推理<br>输出结构化 JSON 决策<br>任务类型/奖励/窗口期<br>带中文文案生成</div>
 </div>
 </div>
 </div>
 <div style="margin-bottom:48px">
 <div style="font-size:10px;font-weight:700;letter-spacing:4px;color:var(--tx3);text-transform:uppercase;margin-bottom:20px">TRIGGER RULES · 自动触发规则（优先于 LLM）</div>
 <div style="display:flex;flex-direction:column;gap:10px">
 <div style="display:flex;align-items:center;gap:14px;background:rgba(239,68,68,.06);border:1px solid rgba(239,68,68,.2);border-radius:14px;padding:16px"><div style="font-size:24px;width:40px;text-align:center;flex-shrink:0"></div><div style="flex:1"><div style="font-size:13px;font-weight:800;margin-bottom:4px">热度峰值 <span style="font-size:10px;color:var(--tx3)">优先级 #1</span></div><div style="font-size:11px;color:var(--tx2)">10分钟内1h成交量暴涨3倍 → 立即强制发布 <strong style="color:#ef4444">5分钟早鸟任务</strong>，窗口极短，先到先得</div></div><div style="font-size:10px;font-weight:700;color:#ef4444;flex-shrink:0">强制覆盖</div></div>
 <div style="display:flex;align-items:center;gap:14px;background:rgba(248,113,113,.05);border:1px solid rgba(248,113,113,.15);border-radius:14px;padding:16px"><div style="font-size:24px;width:40px;text-align:center;flex-shrink:0"></div><div style="flex:1"><div style="font-size:13px;font-weight:800;margin-bottom:4px">抄底触发 <span style="font-size:10px;color:var(--tx3)">优先级 #2</span></div><div style="font-size:11px;color:var(--tx2)">代币1h跌幅超过15% → 发布 <strong style="color:#f87171">买入任务（2倍奖励）</strong>，激励用户逢低买入</div></div><div style="font-size:10px;font-weight:700;color:#f87171;flex-shrink:0">2x 奖励</div></div>
 <div style="display:flex;align-items:center;gap:14px;background:rgba(239,68,68,.05);border:1px solid rgba(239,68,68,.15);border-radius:14px;padding:16px"><div style="font-size:24px;width:40px;text-align:center;flex-shrink:0"></div><div style="flex:1"><div style="font-size:13px;font-weight:800;margin-bottom:4px">BNB 恐慌防护 <span style="font-size:10px;color:var(--tx3)">优先级 #3</span></div><div style="font-size:11px;color:var(--tx2)">BNB 24h跌幅超过8% → 大盘恐慌，发 <strong style="color:#ef4444">高奖励（3倍）买入任务</strong>，奖励覆盖用户部分损失</div></div><div style="font-size:10px;font-weight:700;color:#ef4444;flex-shrink:0">3x 奖励</div></div>
 <div style="display:flex;align-items:center;gap:14px;background:rgba(52,211,153,.05);border:1px solid rgba(52,211,153,.15);border-radius:14px;padding:16px"><div style="font-size:24px;width:40px;text-align:center;flex-shrink:0"></div><div style="flex:1"><div style="font-size:13px;font-weight:800;margin-bottom:4px">BNB 上涨联动 <span style="font-size:10px;color:var(--tx3)">优先级 #4</span></div><div style="font-size:11px;color:var(--tx2)">BNB 24h涨幅超过5%且无活跃任务 → 发 <strong style="color:#34d399">10分钟持仓任务</strong>，锁住跟涨筹码</div></div><div style="font-size:10px;font-weight:700;color:#34d399;flex-shrink:0">锁筹码</div></div>
 <div style="display:flex;align-items:center;gap:14px;background:rgba(59,130,246,.05);border:1px solid rgba(59,130,246,.15);border-radius:14px;padding:16px"><div style="font-size:24px;width:40px;text-align:center;flex-shrink:0"></div><div style="flex:1"><div style="font-size:13px;font-weight:800;margin-bottom:4px">成交量冲量 <span style="font-size:10px;color:var(--tx3)">优先级 #5</span></div><div style="font-size:11px;color:var(--tx2)">1h成交量低于6h均值50%且无活跃任务 → 发 <strong style="color:#3b82f6">买入任务</strong>，恢复活跃度和热度排名</div></div><div style="font-size:10px;font-weight:700;color:#3b82f6;flex-shrink:0">拉热度</div></div>
 <div style="display:flex;align-items:center;gap:14px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:14px;padding:16px"><div style="font-size:24px;width:40px;text-align:center;flex-shrink:0"></div><div style="flex:1"><div style="font-size:13px;font-weight:800;margin-bottom:4px">LLM 自由决策 <span style="font-size:10px;color:var(--tx3)">兜底</span></div><div style="font-size:11px;color:var(--tx2)">以上规则均不触发时，所有信号交给大语言模型推理，输出最适合当前行情的任务类型和奖励</div></div><div style="font-size:10px;font-weight:700;color:var(--tx3);flex-shrink:0">AI 自主</div></div>
 </div>
 </div>
 <div style="margin-bottom:48px">
 <div style="font-size:10px;font-weight:700;letter-spacing:4px;color:var(--tx3);text-transform:uppercase;margin-bottom:20px">PERSONA · 人格系统（每30分钟自动切换）</div>
 <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px">
 <div style="background:rgba(239,68,68,.06);border:1px solid rgba(239,68,68,.2);border-radius:16px;padding:20px;text-align:center"><div style="font-size:32px;margin-bottom:10px">●</div><div style="font-size:14px;font-weight:900;margin-bottom:6px">猎手</div><div style="font-size:11px;color:var(--tx2);line-height:1.8">BNB 急跌 / 完成率&lt;20%<br>风格：短平快，高频小额<br>制造紧迫感和 FOMO</div></div>
 <div style="background:rgba(245,158,11,.06);border:1px solid rgba(245,158,11,.2);border-radius:16px;padding:20px;text-align:center"><div style="font-size:32px;margin-bottom:10px">●</div><div style="font-size:14px;font-weight:900;margin-bottom:6px">军师</div><div style="font-size:11px;color:var(--tx2);line-height:1.8">完成率&gt;70%<br>风格：低频大额，精准时机<br>冷静稳定，优化资金效率</div></div>
 <div style="background:rgba(52,211,153,.06);border:1px solid rgba(52,211,153,.2);border-radius:16px;padding:20px;text-align:center"><div style="font-size:32px;margin-bottom:10px">●</div><div style="font-size:14px;font-weight:900;margin-bottom:6px">传令官</div><div style="font-size:11px;color:var(--tx2);line-height:1.8">BNB 大涨 / 热度高峰<br>风格：造势狂欢，趁热打铁<br>最大化曝光和参与人数</div></div>
 </div>
 </div>
 <div style="margin-bottom:48px">
 <div style="font-size:10px;font-weight:700;letter-spacing:4px;color:var(--tx3);text-transform:uppercase;margin-bottom:20px">FUND SAFETY · 资金安全</div>
 <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:24px">
 <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:16px">
 <div><div style="font-size:13px;font-weight:800;color:#34d399;margin-bottom:10px">Agent 能做</div><div style="font-size:12px;color:var(--tx2);line-height:2">从 taxPool 发布任务<br>调用合约白名单函数<br>支付交易 Gas 费用<br>自动退款过期任务</div></div>
 <div><div style="font-size:13px;font-weight:800;color:#f87171;margin-bottom:10px">Agent 不能做</div><div style="font-size:12px;color:var(--tx2);line-height:2">提取 taxPool 资金<br>修改合约规则<br>用自己的钱发任务<br>绕过合约直接转账</div></div>
 </div>
 <div style="padding:12px 16px;background:rgba(52,211,153,.06);border-radius:10px;font-size:12px;color:var(--tx2);line-height:1.8">taxPool 锁在 AgentRegistry 合约，任何人（包括 Agent）无法直接提取。奖励只能通过合约函数定向发放给任务完成者，全程链上可查。</div>
 </div>
 </div>
 <div style="margin-bottom:20px">
 <div style="font-size:10px;font-weight:700;letter-spacing:4px;color:var(--tx3);text-transform:uppercase;margin-bottom:20px">LIVE · 当前市场情绪</div>
 <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:24px">
 <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:8px"><div style="font-size:14px;font-weight:800">BNB 恐惧贪婪指数</div><div id="logic-sentiment-badge" style="font-size:12px;font-weight:700;padding:4px 14px;border-radius:20px;background:rgba(124,58,237,.15);color:var(--p)">加载中...</div></div>
 <div style="margin-bottom:16px">
 <div style="display:flex;justify-content:space-between;font-size:10px;color:var(--tx3);margin-bottom:6px"><span>极度恐慌 0</span><span>50 中性</span><span>100 极度贪婪</span></div>
 <div style="height:10px;background:linear-gradient(to right,#ef4444,#f59e0b,#34d399);border-radius:5px;position:relative"><div id="logic-sentiment-cursor" style="position:absolute;top:-5px;width:20px;height:20px;background:#fff;border-radius:50%;transform:translateX(-50%);left:50%;box-shadow:0 2px 8px rgba(0,0,0,.5);transition:left .8s ease"></div></div>
 <div style="text-align:center;margin-top:12px;font-size:40px;font-weight:900" id="logic-sentiment-score">--</div>
 </div>
 <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:14px">
 <div style="background:rgba(255,255,255,.04);border-radius:10px;padding:10px;text-align:center"><div style="font-size:10px;color:var(--tx3);margin-bottom:4px">BNB 24h</div><div style="font-size:14px;font-weight:800" id="logic-bnb">--</div></div>
 <div style="background:rgba(255,255,255,.04);border-radius:10px;padding:10px;text-align:center"><div style="font-size:10px;color:var(--tx3);margin-bottom:4px">资金费率</div><div style="font-size:14px;font-weight:800" id="logic-fr">--</div></div>
 <div style="background:rgba(255,255,255,.04);border-radius:10px;padding:10px;text-align:center"><div style="font-size:10px;color:var(--tx3);margin-bottom:4px">盘口比</div><div style="font-size:14px;font-weight:800" id="logic-ob">--</div></div>
 <div style="background:rgba(255,255,255,.04);border-radius:10px;padding:10px;text-align:center"><div style="font-size:10px;color:var(--tx3);margin-bottom:4px">鲸鱼(3m)</div><div style="font-size:14px;font-weight:800" id="logic-whale">--</div></div>
 </div>
 <div id="logic-reasoning" style="background:rgba(13,13,26,.8);border-radius:10px;padding:14px;font-size:12px;color:var(--tx2);line-height:1.8"><span style="color:var(--tx3)">获取中...</span></div>
 or:var(--p)">加载中...</div>
 </div>
 <!-- 情绪分仪表 -->
 <div style="display:flex;align-items:center;gap:16px;margin-bottom:16px;flex-wrap:wrap">
 <div style="flex:1;min-width:180px">
 <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--tx3);margin-bottom:6px">
 <span>极度恐慌</span><span>中性</span><span>极度贪婪</span>
 </div>
 <div style="height:8px;background:linear-gradient(to right,#ef4444,#f59e0b,#34d399);border-radius:4px;position:relative">
 <div id="sentiment-cursor" style="position:absolute;top:-4px;width:16px;height:16px;background:#fff;border-radius:50%;transform:translateX(-50%);left:50%;box-shadow:0 2px 8px rgba(0,0,0,.4);transition:left .5s ease"></div>
 </div>
 <div style="text-align:center;margin-top:8px;font-size:28px;font-weight:900" id="sentiment-score">—</div>
