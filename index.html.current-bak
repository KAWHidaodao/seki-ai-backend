&nbsp;&nbsp;<span style="color:#f59e0b">"taskTypes"</span>: [<span style="color:#34d399">0</span>, <span style="color:#34d399">1</span>, <span style="color:#34d399">2</span>],&nbsp;<span style="color:var(--tx3)">// 0=持仓 1=交互 2=流动性</span><br>
&nbsp;&nbsp;<span style="color:#f59e0b">"minReward"</span>: <span style="color:#34d399">"0.005"</span>,&nbsp;<span style="color:var(--tx3)">// BNB 最低奖励门槛</span><br>
&nbsp;&nbsp;<span style="color:#f59e0b">"maxPerDay"</span>: <span style="color:#a78bfa">10</span>,<br>
&nbsp;&nbsp;<span style="color:#f59e0b">"tokenWhitelist"</span>: []<br>
}
      </div>
      <div style="font-size:11px;color:var(--tx3);line-height:1.7">⚠️ 安全说明：私钥由用户密码 XOR 加密后存 localStorage，服务器端不存储任何钱包数据。建议仅存入用于执行任务的最低限度 BNB。</div>
