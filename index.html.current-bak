<!-- AI 发任务流程 -->
<div style="max-width:700px;margin:40px auto 0;padding:0 20px">
  <div class="label" style="margin-bottom:20px">◆ &nbsp;AI 智能发任务</div>

  <!-- Step 1: 输入表单 -->
  <div id="ai-step1">
    <div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.09);border-radius:20px;padding:28px;margin-bottom:16px">
      <div style="margin-bottom:16px">
        <label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:6px">你想要什么效果？</label>
        <textarea id="p-intent" class="fi" rows="3" placeholder="例：让更多人持有我的代币超过10分钟，每人奖励0.002 BNB" style="width:100%;resize:vertical;height:80px;box-sizing:border-box"></textarea>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px">
        <div>
          <label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:6px">代币合约地址 *</label>
          <input id="p-token" class="fi" placeholder="0x..." style="font-family:monospace;font-size:12px">
        </div>
        <div>
          <label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:6px">代币符号</label>
          <input id="p-symbol" class="fi" placeholder="SEKI">
        </div>
      </div>
      <div style="margin-bottom:20px">
        <label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:6px">总预算 BNB *</label>
        <input id="p-budget" class="fi" type="number" placeholder="0.1" step="0.01" min="0.01">
      </div>
      <button class="btnp" onclick="generateTask()" style="width:100%;padding:14px">✨ AI 生成任务方案</button>
    </div>
  </div>

  <!-- Step 2: AI 生成结果 -->
  <div id="ai-step2" style="display:none">
    <div id="ai-loading" style="display:flex;align-items:center;justify-content:center;gap:12px;padding:40px;background:rgba(255,255,255,.04);border-radius:20px;margin-bottom:16px">
      <div style="width:20px;height:20px;border:2px solid var(--p);border-top-color:transparent;border-radius:50%;animation:spin .8s linear infinite"></div>
      <span style="color:var(--tx2)">AI 分析中...</span>
    </div>
    <div id="ai-result" style="display:none;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.09);border-radius:20px;padding:28px;margin-bottom:16px">
      <div style="font-size:13px;font-weight:700;color:var(--tx);margin-bottom:16px">📋 AI 生成方案</div>
      <div id="ai-result-content" style="font-size:13px;color:var(--tx2);line-height:1.8;margin-bottom:20px"></div>
      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <button class="btnp" onclick="confirmPublish()" style="flex:1;padding:12px">确认发布</button>
        <button class="btns" onclick="backToStep1()" style="padding:12px 20px">重新生成</button>
      </div>
    </div>
  </div>

  <!-- Step 3: 发布中 -->
  <div id="ai-step3" style="display:none">
    <div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.09);border-radius:20px;padding:40px;text-align:center;margin-bottom:16px">
      <div id="publish-status" style="font-size:14px;color:var(--tx2);margin-bottom:16px">等待钱包确认...</div>
      <div id="publish-tx" style="font-size:12px;font-family:monospace;color:var(--p)"></div>
    </div>
  </div>
</div>
</div>
</div>
</div>
</div>

<div id="page-delegate" class="pw" style="display:none">

<!-- 顶部 Hero -->
<div style="position:relative;overflow:hidden;padding:80px 24px 60px;text-align:center">
 <div style="position:absolute;top:-60px;left:50%;transform:translateX(-50%);width:600px;height:400px;background:radial-gradient(ellipse,rgba(124,58,237,.18) 0%,transparent 70%);pointer-events:none"></div>
 <div class="label" style="margin-bottom:14px;justify-content:center">◆ DELEGATE TO AGENT</div>
 <h2 class="headline" style="font-size:clamp(32px,5vw,52px);margin-bottom:16px;line-height:1.1">Delegate to <span class="accent">Agent</span></h2>
 <p style="font-size:14px;color:var(--tx2);max-width:480px;margin:0 auto;line-height:1.9">充值预算，Agent 自主运营。链上透明，资金托管合约，随时可退款。</p>
</div>

<!-- Agent 能力展示 -->
<div style="max-width:1100px;margin:0 auto;padding:0 24px 60px">

 <!-- 4大能力横幅 -->
 <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:60px">
 <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:20px 16px;text-align:center">
 <div style="font-size:28px;margin-bottom:10px"></div>
 <div style="font-size:13px;font-weight:800;color:var(--tx);margin-bottom:6px">实时观察</div>
 <div style="font-size:11px;color:var(--tx3);line-height:1.6">每3分钟扫描链上数据、持币人数、价格波动</div>
 </div>
 <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:20px 16px;text-align:center">
 <div style="font-size:28px;margin-bottom:10px"></div>
 <div style="font-size:13px;font-weight:800;color:var(--tx);margin-bottom:6px">AI 决策</div>
 <div style="font-size:11px;color:var(--tx3);line-height:1.6">LLM 分析生态，自主决定发什么任务、给多少奖励</div>
 </div>
 <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:20px 16px;text-align:center">
 <div style="font-size:28px;margin-bottom:10px"></div>
 <div style="font-size:13px;font-weight:800;color:var(--tx);margin-bottom:6px">自动执行</div>
 <div style="font-size:11px;color:var(--tx3);line-height:1.6">直接调合约发任务、核查完成、链上打款，零人工</div>
 </div>
 <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:20px 16px;text-align:center">
 <div style="font-size:28px;margin-bottom:10px"></div>
 <div style="font-size:13px;font-weight:800;color:var(--tx);margin-bottom:6px">资金安全</div>
 <div style="font-size:11px;color:var(--tx3);line-height:1.6">预算锁在 ERC-8183 合约，Agent 私钥只能出 Gas</div>
 </div>
 </div>

 <!-- Agent 卡片 + 表单 两栏 -->
 <div style="display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:start">

 <!-- 左栏：4个 Agent 详细介绍 -->
 <div>
 <div style="font-size:11px;font-weight:700;letter-spacing:2px;color:var(--tx3);text-transform:uppercase;margin-bottom:20px">选择你的 Agent</div>

 <div style="display:flex;flex-direction:column;gap:12px">

 <div class="dg-agent-card" id="dga-hunter" onclick="dgSelectAgent('hunter')" style="padding:20px;background:rgba(255,255,255,.03);border:1.5px solid rgba(255,255,255,.08);border-radius:16px;cursor:pointer;transition:all .2s">
 <div style="display:flex;align-items:center;gap:14px;margin-bottom:12px">
 <div style="width:40px;height:40px;background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.25);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
   <div style="width:14px;height:14px;background:#ef4444;border-radius:3px"></div>
 </div>
 <div style="flex:1">
   <div style="font-size:14px;font-weight:800;color:var(--tx);letter-spacing:.3px">猎手 <span style="font-size:11px;font-weight:500;color:var(--tx3)">Hunter</span></div>
   <div style="font-size:9px;color:#f87171;font-weight:700;letter-spacing:2px;margin-top:2px">AGGRESSIVE · 拉新优先</div>
 </div>
 </div>
 <div style="font-size:12px;color:var(--tx2);line-height:1.8;margin-bottom:14px">激进策略，高频小额任务，快速积累持币人数和买入量。适合新盘冷启动。</div>
 <div style="border-top:1px solid rgba(255,255,255,.05);padding-top:12px">
   <div style="font-size:9px;font-weight:700;letter-spacing:2px;color:var(--tx3);margin-bottom:8px">可发布任务</div>
   <div style="display:flex;flex-direction:column;gap:5px">
     <div style="display:flex;justify-content:space-between;font-size:11px"><span style="color:var(--tx2)">持仓任务</span><span style="color:#f87171;font-size:10px">持有 ≥5min → 领奖励</span></div>
     <div style="display:flex;justify-content:space-between;font-size:11px"><span style="color:var(--tx2)">买入任务</span><span style="color:#f87171;font-size:10px">买入验证 → 即时结算</span></div>
     <div style="display:flex;justify-content:space-between;font-size:11px"><span style="color:var(--tx2)">早鸟任务</span><span style="color:#f87171;font-size:10px">前 N 名完成 → 瓜分奖池</span></div>
   </div>
 </div>
 </div>

 <div class="dg-agent-card" id="dga-strategist" onclick="dgSelectAgent('strategist')" style="padding:20px;background:rgba(255,255,255,.03);border:1.5px solid rgba(255,255,255,.08);border-radius:16px;cursor:pointer;transition:all .2s">
 <div style="display:flex;align-items:center;gap:14px;margin-bottom:12px">
 <div style="width:40px;height:40px;background:rgba(234,179,8,.1);border:1px solid rgba(234,179,8,.25);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
   <div style="width:14px;height:14px;background:#d97706;border-radius:3px"></div>
 </div>
 <div style="flex:1">
   <div style="font-size:14px;font-weight:800;color:var(--tx);letter-spacing:.3px">军师 <span style="font-size:11px;font-weight:500;color:var(--tx3)">Strategist</span></div>
   <div style="font-size:9px;color:#fbbf24;font-weight:700;letter-spacing:2px;margin-top:2px">ADAPTIVE · 数据驱动</div>
 </div>
 </div>
 <div style="font-size:12px;color:var(--tx2);line-height:1.8;margin-bottom:14px">实时分析链上数据，行情好加码，行情差保守。奖励随市场情绪自动调整。</div>
 <div style="border-top:1px solid rgba(255,255,255,.05);padding-top:12px">
   <div style="font-size:9px;font-weight:700;letter-spacing:2px;color:var(--tx3);margin-bottom:8px">可发布任务</div>
   <div style="display:flex;flex-direction:column;gap:5px">
     <div style="display:flex;justify-content:space-between;font-size:11px"><span style="color:var(--tx2)">持仓任务</span><span style="color:#fbbf24;font-size:10px">BNB上涨时 → 锁筹码</span></div>
     <div style="display:flex;justify-content:space-between;font-size:11px"><span style="color:var(--tx2)">买入任务</span><span style="color:#fbbf24;font-size:10px">急跌时 → 2x 抄底奖励</span></div>
     <div style="display:flex;justify-content:space-between;font-size:11px"><span style="color:var(--tx2)">锦标赛</span><span style="color:#fbbf24;font-size:10px">横盘时 → 拉长持仓周期</span></div>
   </div>
 </div>
 </div>

 <div class="dg-agent-card" id="dga-herald" onclick="dgSelectAgent('herald')" style="padding:20px;background:rgba(255,255,255,.03);border:1.5px solid rgba(255,255,255,.08);border-radius:16px;cursor:pointer;transition:all .2s">
 <div style="display:flex;align-items:center;gap:14px;margin-bottom:12px">
 <div style="width:40px;height:40px;background:rgba(52,211,153,.1);border:1px solid rgba(52,211,153,.25);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
   <div style="width:14px;height:14px;background:#059669;border-radius:3px"></div>
 </div>
 <div style="flex:1">
   <div style="font-size:14px;font-weight:800;color:var(--tx);letter-spacing:.3px">传令官 <span style="font-size:11px;font-weight:500;color:var(--tx3)">Herald</span></div>
   <div style="font-size:9px;color:#34d399;font-weight:700;letter-spacing:2px;margin-top:2px">NARRATIVE · 故事叙事</div>
 </div>
 </div>
 <div style="font-size:12px;color:var(--tx2);line-height:1.8;margin-bottom:14px">构建连续故事线，每个任务有章节剧情，提升社区归属感。适合做长期品牌的项目。</div>
 <div style="border-top:1px solid rgba(255,255,255,.05);padding-top:12px">
   <div style="font-size:9px;font-weight:700;letter-spacing:2px;color:var(--tx3);margin-bottom:8px">可发布任务</div>
   <div style="display:flex;flex-direction:column;gap:5px">
     <div style="display:flex;justify-content:space-between;font-size:11px"><span style="color:var(--tx2)">早鸟任务</span><span style="color:#34d399;font-size:10px">热度高峰 → 5min 窗口</span></div>
     <div style="display:flex;justify-content:space-between;font-size:11px"><span style="color:var(--tx2)">持仓任务</span><span style="color:#34d399;font-size:10px">章节解锁 → 故事线推进</span></div>
     <div style="display:flex;justify-content:space-between;font-size:11px"><span style="color:var(--tx2)">锦标赛</span><span style="color:#34d399;font-size:10px">Boss 战 → 持仓最久者胜</span></div>
   </div>
 </div>
 </div>

 <div class="dg-agent-card" id="dga-custom" onclick="dgSelectAgent('custom')" style="padding:20px;background:rgba(255,255,255,.03);border:1.5px solid rgba(255,255,255,.08);border-radius:16px;cursor:pointer;transition:all .2s">
 <div style="display:flex;align-items:center;gap:14px;margin-bottom:12px">
 <div style="width:40px;height:40px;background:rgba(124,58,237,.1);border:1px solid rgba(124,58,237,.25);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
   <div style="width:14px;height:14px;background:var(--p);border-radius:3px"></div>
 </div>
 <div style="flex:1">
   <div style="font-size:14px;font-weight:800;color:var(--tx);letter-spacing:.3px">自定义 <span style="font-size:11px;font-weight:500;color:var(--tx3)">Custom</span></div>
   <div style="font-size:9px;color:var(--p);font-weight:700;letter-spacing:2px;margin-top:2px">CUSTOM · 完全掌控</div>
 </div>
 </div>
 <div style="font-size:12px;color:var(--tx2);line-height:1.8;margin-bottom:14px">手动设置全部参数，Agent 严格按你的策略执行。适合有明确运营方案的进阶用户。</div>
 <div style="border-top:1px solid rgba(255,255,255,.05);padding-top:12px">
   <div style="font-size:9px;font-weight:700;letter-spacing:2px;color:var(--tx3);margin-bottom:8px">可发布任务</div>
   <div style="display:flex;flex-direction:column;gap:5px">
     <div style="display:flex;justify-content:space-between;font-size:11px"><span style="color:var(--tx2)">全部类型</span><span style="color:var(--p);font-size:10px">持仓 / 买入 / 早鸟 / 锦标赛</span></div>
     <div style="display:flex;justify-content:space-between;font-size:11px"><span style="color:var(--tx2)">自定义门槛</span><span style="color:var(--p);font-size:10px">持仓量 / 买入量 / 持有时长</span></div>
     <div style="display:flex;justify-content:space-between;font-size:11px"><span style="color:var(--tx2)">奖励范围</span><span style="color:var(--p);font-size:10px">min ~ max BNB 自由设定</span></div>
   </div>
 </div>
 </div>

 </div>
 </div><!-- /左栏 -->

 <!-- 右栏：委托表单 -->
 <div style="position:sticky;top:90px">

 <!-- 步骤指示器 -->
 <div style="display:flex;gap:0;margin-bottom:24px">
 <div id="dgs-1" style="flex:1;padding:12px 14px;background:rgba(124,58,237,.12);border:1px solid rgba(124,58,237,.35);border-right:none;border-radius:10px 0 0 10px">
 <div style="font-size:10px;font-weight:700;color:var(--p);letter-spacing:1px">STEP 1</div>
 <div style="font-size:12px;font-weight:700;color:var(--tx);margin-top:2px">配置参数</div>
 </div>
 <div id="dgs-2" style="flex:1;padding:12px 14px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:0 10px 10px 0;opacity:.5">
 <div style="font-size:10px;font-weight:700;color:var(--tx3);letter-spacing:1px">STEP 2</div>
 <div style="font-size:12px;font-weight:700;color:var(--tx3);margin-top:2px">签名（共2次）</div>
 </div>
 </div>

 <div id="delegate-form" style="display:none">
 <div id="dg-form">
 <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:16px;padding:20px;margin-bottom:16px">
 <div style="font-size:10px;font-weight:700;letter-spacing:1.5px;color:var(--tx3);text-transform:uppercase;margin-bottom:14px">基础配置</div>
 <div style="display:flex;flex-direction:column;gap:12px">
 <div>
 <label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:5px">目标代币地址 *</label>
 <input class="fi" id="d0" placeholder="0x..." style="width:100%;font-family:monospace;font-size:12px">
 </div>
 <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
 <div>
 <label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:5px">预算 BNB *</label>
 <input class="fi" id="d1" type="number" placeholder="0.05" min="0.01" step="0.01" oninput="dgCalc()">
 <div style="font-size:10px;color:var(--su);margin-top:3px">建议 ≥ 0.05 BNB</div>
 </div>
 <div>
 <label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:5px">运营时长（分钟）</label>
 <input class="fi" id="d2" type="number" placeholder="120" min="10" step="10" value="120">
 </div>
 </div>
 <div>
 <label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:5px">Telegram 通知（选填）</label>
 <input class="fi" id="d4" placeholder="@your_channel">
 </div>
 </div>
 </div>

 <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:16px;padding:20px;margin-bottom:16px">
 <div style="font-size:10px;font-weight:700;letter-spacing:1.5px;color:var(--tx3);text-transform:uppercase;margin-bottom:14px">任务门槛（选填）</div>
 <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
 <div><label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:5px">最低持币量</label><input class="fi" id="th-amount" type="number" placeholder="0"></div>
 <div><label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:5px">最低买入 BNB</label><input class="fi" id="th-buy" type="number" placeholder="0" step="0.001"></div>
 <div><label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:5px">最短持仓（秒）</label><input class="fi" id="th-hold" type="number" placeholder="300" min="120" max="3600"></div>
 <div><label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:5px">最低推荐数</label><input class="fi" id="th-ref" type="number" placeholder="0"></div>
 </div>
 </div>

 <!-- 自定义策略（仅 custom 模式显示）-->
 <div id="dg-custom-block" style="display:none;background:rgba(255,255,255,.03);border:1px solid rgba(124,58,237,.2);border-radius:16px;padding:20px;margin-bottom:16px">
 <div style="font-size:10px;font-weight:700;letter-spacing:1.5px;color:var(--p);text-transform:uppercase;margin-bottom:14px">自定义策略</div>
 <div style="display:flex;flex-direction:column;gap:12px">
   <div>
     <label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:8px">任务类型（可多选）</label>
     <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
       <label style="display:flex;align-items:center;gap:8px;padding:9px 12px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.1);border-radius:10px;cursor:pointer;font-size:12px"><input type="checkbox" id="ct-hold" value="0" style="accent-color:var(--p)"> 持仓任务</label>
       <label style="display:flex;align-items:center;gap:8px;padding:9px 12px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.1);border-radius:10px;cursor:pointer;font-size:12px"><input type="checkbox" id="ct-buy" value="1" style="accent-color:var(--p)"> 买入任务</label>
       <label style="display:flex;align-items:center;gap:8px;padding:9px 12px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.1);border-radius:10px;cursor:pointer;font-size:12px"><input type="checkbox" id="ct-early" value="2" style="accent-color:var(--p)"> 早鸟任务</label>
       <label style="display:flex;align-items:center;gap:8px;padding:9px 12px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.1);border-radius:10px;cursor:pointer;font-size:12px"><input type="checkbox" id="ct-tour" value="4" style="accent-color:var(--p)"> 锦标赛</label>
     </div>
   </div>
   <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
     <div><label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:5px">奖励下限 BNB</label><input class="fi" id="ct-min-reward" type="number" placeholder="0.001" min="0.001" step="0.001" oninput="dgCalc()"></div>
     <div><label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:5px">奖励上限 BNB</label><input class="fi" id="ct-max-reward" type="number" placeholder="0.01" min="0.001" step="0.001" oninput="dgCalc()"></div>
   </div>
   <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
     <div><label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:5px">每次奖励人数</label><input class="fi" id="ct-winners" type="number" placeholder="5" min="1" max="50" value="5"></div>
     <div><label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:5px">任务窗口期（分钟）</label><input class="fi" id="ct-deadline" type="number" placeholder="20" min="10" max="45" value="20"></div>
   </div>
   <div>
     <label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:8px">触发模式</label>
     <div style="display:flex;gap:8px">
       <label style="display:flex;align-items:center;gap:7px;padding:9px 12px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.1);border-radius:10px;cursor:pointer;font-size:12px;flex:1"><input type="radio" name="ct-mode" id="ct-mode-auto" value="auto" checked style="accent-color:var(--p)"> 自动循环<span style="font-size:10px;color:var(--tx3)">Agent 决定</span></label>
       <label style="display:flex;align-items:center;gap:7px;padding:9px 12px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.1);border-radius:10px;cursor:pointer;font-size:12px;flex:1"><input type="radio" name="ct-mode" id="ct-mode-manual" value="manual" style="accent-color:var(--p)"> 信号触发<span style="font-size:10px;color:var(--tx3)">有信号才发</span></label>
     </div>
   </div>
 </div>
 </div>

 <!-- 预算预览 -->
 <div style="background:rgba(124,58,237,.07);border:1px solid rgba(124,58,237,.18);border-radius:16px;padding:16px;margin-bottom:16px">
 <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:8px"><span style="color:var(--tx3)">预计可发任务</span><span style="font-weight:700;color:var(--tx)" id="dg-est-tasks">—</span></div>
 <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:8px"><span style="color:var(--tx3)">每任务均奖励</span><span style="color:var(--p)" id="dg-est-reward">—</span></div>
 <div style="display:flex;justify-content:space-between;font-size:12px"><span style="color:var(--tx3)">平台手续费 5%</span><span style="color:var(--tx3)" id="dg-est-fee">—</span></div>
 </div>

 <button class="btnp" style="width:100%;padding:14px;font-size:14px;font-weight:800" id="dg-submit-btn" onclick="submitDelegate()">
 开始委托 → <span id="df-btn-name">请先选择 Agent</span>
 </button>
 <div style="font-size:11px;color:var(--tx3);text-align:center;margin-top:10px;line-height:1.7">需签名 2 次 · 资金托管合约 · 到期随时退款</div>
 </div><!-- /dg-form -->

 <!-- 进度 -->
 <div id="dg-progress" style="display:none">
 <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:20px;padding:28px;text-align:center">
 <div style="font-size:32px;margin-bottom:12px" id="dg-prog-icon">⏳</div>
 <div style="font-size:16px;font-weight:800;color:var(--tx);margin-bottom:6px" id="dg-prog-title">处理中</div>
 <div style="font-size:13px;color:var(--tx2)" id="dg-prog-desc">请在 MetaMask 确认</div>
 <div style="display:flex;flex-direction:column;gap:8px;margin-top:20px;text-align:left">
 <div id="dgps-1" style="display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:10px;background:rgba(255,255,255,.04)"><span id="dgps-1-ico">⏳</span><span style="font-size:12px;color:var(--tx2)">① 创建并锁定资金（签名一次）</span></div>
 <div id="dgps-2" style="display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:10px;background:rgba(255,255,255,.04);opacity:.4"><span id="dgps-2-ico">⏳</span><span style="font-size:12px;color:var(--tx2)">② Agent 激活</span></div>
 </div>
 </div>
 </div>

 <!-- 成功 -->
 <div id="dg-success" style="display:none">
 <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:20px;padding:32px;text-align:center">
 <div style="font-size:48px;margin-bottom:12px"></div>
 <div style="font-size:20px;font-weight:900;margin-bottom:6px">委托成功！</div>
 <div style="font-size:13px;color:var(--tx2);margin-bottom:20px" id="dg-success-desc"></div>
 <div style="background:rgba(124,58,237,.08);border:1px solid rgba(124,58,237,.2);border-radius:12px;padding:14px;margin-bottom:20px;text-align:left" id="dg-success-info"></div>
 <div style="display:flex;gap:10px">
 <button class="btns" style="flex:1;padding:11px" onclick="G('my',document.querySelectorAll('.nl')[4])"> 查看状态</button>
 <button class="btnp" style="flex:1;padding:11px" onclick="dgReset()">再委托</button>
 </div>
 </div>
 </div>
 </div><!-- /delegate-form -->

 </div><!-- /右栏 -->
 </div><!-- /两栏 -->
</div><!-- /max-width -->
</div>


<div class="pw" id="page-hall" style="display:none">
<style>
@keyframes hallPulse{0%,100%{opacity:.6}50%{opacity:1}}
@keyframes hallFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
@keyframes hallGlow{0%{box-shadow:0 0 20px rgba(124,58,237,.1)}50%{box-shadow:0 0 40px rgba(124,58,237,.2)}100%{box-shadow:0 0 20px rgba(124,58,237,.1)}}
.hall-wrap{position:relative;z-index:1;max-width:1100px;margin:0 auto;padding:0 24px 100px}
.hall-hero{text-align:center;padding:70px 0 40px}
.hall-hero h1{font-size:42px;font-weight:900;line-height:1.1;margin:0 0 14px;background:linear-gradient(135deg,#fff 20%,#c4b5fd 50%,#7c3aed 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.hall-hero p{font-size:14px;color:var(--tx3);line-height:1.7;max-width:480px;margin:0 auto}
.hall-stats{display:flex;justify-content:center;gap:40px;margin:30px 0 0}
.hall-stat-num{font-size:26px;font-weight:900;color:#fff}
.hall-stat-lbl{font-size:11px;color:var(--tx3);margin-top:4px;letter-spacing:1px}
.hall-toolbar{display:flex;align-items:center;gap:10px;margin:32px 0 20px;flex-wrap:wrap}
.hall-chip{font-size:11px;font-weight:700;padding:6px 16px;border-radius:20px;border:1px solid rgba(255,255,255,.08);background:rgba(255,255,255,.03);color:var(--tx3);cursor:pointer;transition:all .2s;font-family:inherit}
.hall-chip:hover{border-color:rgba(124,58,237,.3);color:var(--tx2)}
.hall-chip.on{background:rgba(124,58,237,.15);border-color:rgba(124,58,237,.4);color:#c4b5fd}
.hall-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:18px}
.hall-card{background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.06);border-radius:20px;overflow:hidden;transition:all .3s;animation:hallGlow 4s ease-in-out infinite}
.hall-card:hover{border-color:rgba(124,58,237,.35);transform:translateY(-3px)}
.hall-card-top{padding:20px 20px 14px;border-bottom:1px solid rgba(255,255,255,.04)}
.hall-card-body{padding:14px 20px 18px}
.hall-badge{display:inline-flex;align-items:center;gap:4px;font-size:10px;font-weight:800;letter-spacing:1px;padding:3px 10px;border-radius:10px}
.hall-badge-hunter{background:rgba(239,68,68,.12);color:#f87171}
.hall-badge-strategist{background:rgba(59,130,246,.12);color:#60a5fa}
.hall-badge-herald{background:rgba(52,211,153,.1);color:#34d399}
.hall-badge-custom{background:rgba(255,255,255,.05);color:var(--tx2)}
.hall-meta{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-top:12px}
.hall-meta-item{text-align:center;padding:8px 0;background:rgba(255,255,255,.02);border-radius:10px}
.hall-meta-val{font-size:15px;font-weight:800;color:#fff}
.hall-meta-lbl{font-size:10px;color:var(--tx3);margin-top:2px}
.hall-status{display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:700;padding:3px 10px;border-radius:8px}
.hall-status-active{background:rgba(74,222,128,.1);color:#4ade80}
.hall-status-active::before{content:'';width:5px;height:5px;border-radius:50%;background:#4ade80;animation:hallPulse 1.5s infinite}
.hall-empty-state{text-align:center;padding:80px 20px}
.hall-empty-icon{font-size:48px;margin-bottom:16px;opacity:.3}
.hall-empty-title{font-size:18px;font-weight:800;color:var(--tx2);margin-bottom:8px}
.hall-empty-desc{font-size:13px;color:var(--tx3)}
</style>
<div class="hall-wrap">
  <div class="hall-hero">
    <h1>任务大厅</h1>
    <p>所有 AI Agent 委托任务实时展示<br>链上资金托管 · 透明可验证 · 自动执行</p>
    <div class="hall-stats">
      <div><div class="hall-stat-num" id="hall-stat-total">—</div><div class="hall-stat-lbl">总任务</div></div>
      <div><div class="hall-stat-num" id="hall-stat-active">—</div><div class="hall-stat-lbl">运行中</div></div>
      <div><div class="hall-stat-num" id="hall-stat-budget">—</div><div class="hall-stat-lbl">锁定 BNB</div></div>
    </div>
  </div>
  <div class="hall-toolbar">
    <button class="hall-chip on" onclick="_hallFilter='all';document.querySelectorAll('.hall-chip').forEach(c=>c.classList.remove('on'));this.classList.add('on');renderHallGrid()">全部</button>
    <button class="hall-chip" onclick="_hallFilter='hunter';document.querySelectorAll('.hall-chip').forEach(c=>c.classList.remove('on'));this.classList.add('on');renderHallGrid()">🎯 猎手</button>
    <button class="hall-chip" onclick="_hallFilter='strategist';document.querySelectorAll('.hall-chip').forEach(c=>c.classList.remove('on'));this.classList.add('on');renderHallGrid()">📊 军师</button>
    <button class="hall-chip" onclick="_hallFilter='herald';document.querySelectorAll('.hall-chip').forEach(c=>c.classList.remove('on'));this.classList.add('on');renderHallGrid()">📣 传令官</button>
    <button class="hall-chip" style="margin-left:auto" onclick="loadHallPage()">↻ 刷新</button>
  </div>
  <div id="hall-grid" class="hall-grid"></div>
</div>
</div>

<div
id="page-docs" class="pw" style="display:none">
  <div style="max-width:900px;margin:0 auto;padding:40px 28px 100px">
    <div style="display:flex;gap:8px;margin-bottom:40px;flex-wrap:wrap">
      <button id="dtag-logic" onclick="docTab('logic',this)" style="padding:8px 20px;border-radius:20px;border:1px solid var(--p);background:rgba(124,58,237,.15);color:var(--p);font-size:13px;font-weight:700;cursor:pointer"> AI 逻辑</button>
      <button id="dtag-dev" onclick="docTab('dev',this)" style="padding:8px 20px;border-radius:20px;border:1px solid rgba(255,255,255,.15);background:transparent;color:var(--tx2);font-size:13px;font-weight:700;cursor:pointer"> 开发者</button>
    </div>
    <div id="docs-logic">
  <div style="text-align:center;margin-bottom:56px">
    <div style="font-size:9px;font-weight:700;letter-spacing:4px;color:var(--p);text-transform:uppercase;margin-bottom:14px">ERC-8183 · AI AGENT PROTOCOL</div>
    <h1 style="font-size:clamp(32px,5vw,52px);font-weight:900;line-height:1.1;letter-spacing:-1.5px;margin-bottom:16px">Seki <span style="background:linear-gradient(135deg,#a78bfa,#60a5fa);-webkit-background-clip:text;-webkit-text-fill-color:transparent">Agent</span><br>决策逻辑全解</h1>
    <p style="font-size:14px;color:var(--tx2);max-width:500px;margin:0 auto;line-height:2">不是黑盒，不是人工操盘。<br>每一个任务的发布，都有公开可查的链上数据和市场信号作为依据。<br><span style="font-size:12px;color:var(--p);font-weight:700;letter-spacing:1px">全球首个 ERC-8183 兼容 · AI Agent 双链 Meme 激励平台</span></p>
  </div>

  
<!-- ONCHAIN DECISIONS -->
<div style="margin-bottom:64px">
  <div class="label" style="margin-bottom:16px">◆ &nbsp;DECISIONS ON-CHAIN</div>
  <h3 style="font-size:clamp(18px,2.5vw,28px);font-weight:900;letter-spacing:-1px;margin-bottom:8px">每一个决策，都在链上</h3>
  <p style="font-size:13px;color:var(--tx2);line-height:1.9;margin-bottom:28px">Agent 的每次 ACT（发任务）都写入链上合约事件，可在区块浏览器永久查证。任何人都能验证 Agent 的行为没有人为干预。</p>
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:28px">
    <div style="padding:20px;background:rgba(52,211,153,.06);border:1px solid rgba(52,211,153,.2);border-radius:16px">
      <div style="font-size:11px;font-weight:700;letter-spacing:1px;color:#34d399;margin-bottom:10px">BSC</div>
      <div style="font-size:22px;font-weight:900;margin-bottom:4px" id="od-bsc-tasks">—</div>
      <div style="font-size:11px;color:var(--tx3)">链上任务总数</div>
    </div>
    <div style="padding:20px;background:rgba(167,139,250,.06);border:1px solid rgba(167,139,250,.2);border-radius:16px">
      
      <div style="font-size:22px;font-weight:900;margin-bottom:4px" id="od-xl-tasks">—</div>
      <div style="font-size:11px;color:var(--tx3)">链上任务总数</div>
    </div>
    <div style="padding:20px;background:rgba(245,158,11,.06);border:1px solid rgba(245,158,11,.2);border-radius:16px">
      <div style="font-size:11px;font-weight:700;letter-spacing:1px;color:#f59e0b;margin-bottom:10px">AGENT</div>
      <div style="font-size:22px;font-weight:900;margin-bottom:4px" id="od-agent-tasks">—</div>
      <div style="font-size:11px;color:var(--tx3)">Agent 自主发布</div>
    </div>
  </div>
  <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:16px;padding:20px">
    <div style="font-size:11px;font-weight:700;color:var(--tx3);letter-spacing:1px;margin-bottom:14px">最近链上决策</div>
    <div id="od-log-list" style="font-size:12px;color:var(--tx2);line-height:2">加载中...</div>
    <div style="margin-top:14px;display:flex;gap:10px">
      <a href="https://bscscan.com/address/0xea43a24a1baefb89494126c12fe8921b5b8e3d8d#events" target="_blank" style="font-size:11px;color:#f59e0b;text-decoration:none;font-weight:700">BSCScan Events ↗</a>
      
    </div>
  </div>
</div>
<!-- CORE LOOP -->
  <div style="margin-bottom:56px">
    <div style="font-size:9px;font-weight:700;letter-spacing:4px;color:var(--tx3);text-transform:uppercase;margin-bottom:24px">CORE LOOP &nbsp;·&nbsp; 核心循环</div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(255,255,255,.06);border-radius:20px;overflow:hidden">
      <div style="background:var(--bg2);padding:28px 24px">
        <div style="font-size:9px;font-weight:700;letter-spacing:2px;color:rgba(167,139,250,.5);margin-bottom:8px">01</div>
        <div style="font-size:16px;font-weight:900;color:var(--p);letter-spacing:1px;margin-bottom:4px">OBSERVE</div>
        <div style="font-size:10px;color:var(--tx3);letter-spacing:1px;margin-bottom:20px">观察</div>
        <div style="display:flex;flex-direction:column;gap:10px">
          <div style="font-size:12px;color:var(--tx2);line-height:1.7;padding-left:10px;border-left:2px solid rgba(167,139,250,.3)">链上价格 · 流动性深度<br>任务完成率 · taxPool 余额</div>
          <div style="font-size:12px;color:var(--tx2);line-height:1.7;padding-left:10px;border-left:2px solid rgba(167,139,250,.3)">资金费率 · 买卖盘深度<br>鲸鱼大单 · BNB 涨跌幅</div>
          <div style="font-size:12px;color:var(--tx2);line-height:1.7;padding-left:10px;border-left:2px solid rgba(167,139,250,.3)">DexScreener 成交量<br>持续热度追踪</div>
        </div>
        <div style="margin-top:18px;font-size:10px;color:var(--tx3);background:rgba(255,255,255,.03);border-radius:8px;padding:8px 10px;line-height:1.7">每 <strong style="color:var(--tx)">3 分钟</strong>采集一次全量信号，写入状态快照</div>
      </div>
      <div style="background:var(--bg2);padding:28px 24px;border-left:1px solid rgba(255,255,255,.06);border-right:1px solid rgba(255,255,255,.06)">
        <div style="font-size:9px;font-weight:700;letter-spacing:2px;color:rgba(59,130,246,.5);margin-bottom:8px">02</div>
        <div style="font-size:16px;font-weight:900;color:#3b82f6;letter-spacing:1px;margin-bottom:4px">THINK</div>
        <div style="font-size:10px;color:var(--tx3);letter-spacing:1px;margin-bottom:20px">推理</div>
        <div style="display:flex;flex-direction:column;gap:10px">
          <div style="font-size:12px;color:var(--tx2);line-height:1.7;padding-left:10px;border-left:2px solid rgba(59,130,246,.3)">匹配 <strong style="color:var(--tx)">5 条优先规则</strong><br>命中即跳过 LLM 直接执行</div>
          <div style="font-size:12px;color:var(--tx2);line-height:1.7;padding-left:10px;border-left:2px solid rgba(59,130,246,.3)">规则未命中 → 全量信号输入<br><strong style="color:var(--tx)">GPT-5.4</strong> 综合推理</div>
          <div style="font-size:12px;color:var(--tx2);line-height:1.7;padding-left:10px;border-left:2px solid rgba(59,130,246,.3)">自动切换人格<br>猎手 / 军师 / 传令官</div>
        </div>
        <div style="margin-top:18px;font-size:10px;color:var(--tx3);background:rgba(255,255,255,.03);border-radius:8px;padding:8px 10px;line-height:1.7">输出：任务类型 · 奖励金额 · 窗口期 · 持仓门槛</div>
      </div>
      <div style="background:var(--bg2);padding:28px 24px">
        <div style="font-size:9px;font-weight:700;letter-spacing:2px;color:rgba(52,211,153,.5);margin-bottom:8px">03</div>
        <div style="font-size:16px;font-weight:900;color:#34d399;letter-spacing:1px;margin-bottom:4px">ACT</div>
        <div style="font-size:10px;color:var(--tx3);letter-spacing:1px;margin-bottom:20px">执行</div>
        <div style="display:flex;flex-direction:column;gap:10px">
          <div style="font-size:12px;color:var(--tx2);line-height:1.7;padding-left:10px;border-left:2px solid rgba(52,211,153,.3)">从 <strong style="color:var(--tx)">taxPool</strong> 扣款<br>调用合约发布任务</div>
          <div style="font-size:12px;color:var(--tx2);line-height:1.7;padding-left:10px;border-left:2px solid rgba(52,211,153,.3)">写链上记录 · 更新日志<br>等待用户完成领取</div>
          <div style="font-size:12px;color:var(--tx2);line-height:1.7;padding-left:10px;border-left:2px solid rgba(52,211,153,.3)">超时未领 → <strong style="color:var(--tx)">自动退款</strong><br>资金原路返回 taxPool</div>
        </div>
        <div style="margin-top:18px;font-size:10px;color:var(--tx3);background:rgba(255,255,255,.03);border-radius:8px;padding:8px 10px;line-height:1.7">全程链上可查，无人工介入</div>
      </div>
    </div>
  </div>

  <!-- TRIGGER RULES -->
  <div style="margin-bottom:56px">
    <div style="font-size:9px;font-weight:700;letter-spacing:4px;color:var(--tx3);text-transform:uppercase;margin-bottom:8px">TRIGGER RULES &nbsp;·&nbsp; 触发规则</div>
    <div style="font-size:12px;color:var(--tx3);margin-bottom:24px;line-height:1.8">规则按优先级排序。命中高优先级规则时，直接执行，跳过 LLM 推理，响应延迟 &lt;1s。</div>
    <div style="display:flex;flex-direction:column;gap:10px">
      <div style="background:rgba(255,255,255,.03);border:1px solid rgba(239,68,68,.2);border-radius:16px;padding:20px 24px;display:flex;gap:20px;align-items:flex-start">
        <div style="flex-shrink:0;width:36px;padding-top:2px;text-align:center">
          <div style="font-size:11px;font-weight:900;color:#ef4444;letter-spacing:1px">01</div>
          <div style="font-size:9px;color:var(--tx3);margin-top:3px">最高</div>
        </div>
        <div style="flex:1">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;flex-wrap:wrap">
            <span style="font-size:13px;font-weight:800;color:var(--tx)">热度峰值</span>
            <span style="font-size:9px;padding:2px 8px;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.2);border-radius:20px;color:#f87171;letter-spacing:1px">SPIKE DETECTED</span>
          </div>
          <div style="font-size:12px;color:var(--tx2);line-height:1.8;margin-bottom:10px">10 分钟内成交量达平均值 <strong style="color:var(--tx)">3 倍以上</strong>，判定为热度峰值。强制插入一个 <strong style="color:#f87171">5 分钟早鸟任务</strong>，极短窗口制造 FOMO 效应。</div>
          <div style="font-size:11px;color:var(--tx3);background:rgba(255,255,255,.02);border-radius:8px;padding:8px 12px;border-left:2px solid rgba(239,68,68,.3)">设计原因：热度是最稀缺的资源，出现时必须立刻利用，不能等 LLM 慢慢想。</div>
        </div>
      </div>
      <div style="background:rgba(255,255,255,.03);border:1px solid rgba(248,113,113,.15);border-radius:16px;padding:20px 24px;display:flex;gap:20px;align-items:flex-start">
        <div style="flex-shrink:0;width:36px;padding-top:2px;text-align:center">
          <div style="font-size:11px;font-weight:900;color:#f87171;letter-spacing:1px">02</div>
        </div>
        <div style="flex:1">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;flex-wrap:wrap">
            <span style="font-size:13px;font-weight:800;color:var(--tx)">抄底触发</span>
            <span style="font-size:9px;padding:2px 8px;background:rgba(248,113,113,.1);border:1px solid rgba(248,113,113,.2);border-radius:20px;color:#f87171;letter-spacing:1px">DIP DETECTED</span>
          </div>
          <div style="font-size:12px;color:var(--tx2);line-height:1.8;margin-bottom:10px">1 小时内跌幅超过 <strong style="color:var(--tx)">15%</strong>，发布买入任务，奖励倍率 <strong style="color:#f87171">2×</strong>，持仓门槛降至默认值一半，降低抄底门槛。</div>
          <div style="font-size:11px;color:var(--tx3);background:rgba(255,255,255,.02);border-radius:8px;padding:8px 12px;border-left:2px solid rgba(248,113,113,.3)">设计原因：跌幅大时散户最容易割肉，高奖励买入任务能拦截抛压，给钻石手奖励。</div>
        </div>
      </div>
      <div style="background:rgba(255,255,255,.03);border:1px solid rgba(239,68,68,.12);border-radius:16px;padding:20px 24px;display:flex;gap:20px;align-items:flex-start">
        <div style="flex-shrink:0;width:36px;padding-top:2px;text-align:center">
          <div style="font-size:11px;font-weight:900;color:#ef4444;letter-spacing:1px">03</div>
        </div>
        <div style="flex:1">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;flex-wrap:wrap">
            <span style="font-size:13px;font-weight:800;color:var(--tx)">BNB 恐慌防护</span>
            <span style="font-size:9px;padding:2px 8px;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.2);border-radius:20px;color:#f87171;letter-spacing:1px">MARKET PANIC</span>
          </div>
          <div style="font-size:12px;color:var(--tx2);line-height:1.8;margin-bottom:10px">BNB 24h 跌幅超过 <strong style="color:var(--tx)">8%</strong>，整个 BSC 生态进入恐慌。发布高奖励买入任务，倍率 <strong style="color:#f87171">3×</strong>，主动对冲用户浮亏情绪。</div>
          <div style="font-size:11px;color:var(--tx3);background:rgba(255,255,255,.02);border-radius:8px;padding:8px 12px;border-left:2px solid rgba(239,68,68,.3)">设计原因：BNB 跌等于当前链所有 meme 都跌，此时最需要外部激励维持持仓信心。</div>
        </div>
      </div>
      <div style="background:rgba(255,255,255,.03);border:1px solid rgba(52,211,153,.12);border-radius:16px;padding:20px 24px;display:flex;gap:20px;align-items:flex-start">
        <div style="flex-shrink:0;width:36px;padding-top:2px;text-align:center">
          <div style="font-size:11px;font-weight:900;color:#34d399;letter-spacing:1px">04</div>
        </div>
        <div style="flex:1">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;flex-wrap:wrap">
            <span style="font-size:13px;font-weight:800;color:var(--tx)">BNB 上涨联动</span>
            <span style="font-size:9px;padding:2px 8px;background:rgba(52,211,153,.1);border:1px solid rgba(52,211,153,.2);border-radius:20px;color:#34d399;letter-spacing:1px">BULL SIGNAL</span>
          </div>
          <div style="font-size:12px;color:var(--tx2);line-height:1.8;margin-bottom:10px">BNB 24h 涨幅超过 <strong style="color:var(--tx)">5%</strong>，市场情绪偏多。发布持仓任务，要求持有至少 <strong style="color:#34d399">10 分钟</strong>，锁筹码防止高位砸盘。</div>
          <div style="font-size:11px;color:var(--tx3);background:rgba(255,255,255,.02);border-radius:8px;padding:8px 12px;border-left:2px solid rgba(52,211,153,.3)">设计原因：涨势中最大的风险是短期获利了结，持仓任务能让筹码稳定在强手里。</div>
        </div>
      </div>
      <div style="background:rgba(255,255,255,.03);border:1px solid rgba(59,130,246,.12);border-radius:16px;padding:20px 24px;display:flex;gap:20px;align-items:flex-start">
        <div style="flex-shrink:0;width:36px;padding-top:2px;text-align:center">
          <div style="font-size:11px;font-weight:900;color:#3b82f6;letter-spacing:1px">05</div>
        </div>
        <div style="flex:1">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;flex-wrap:wrap">
            <span style="font-size:13px;font-weight:800;color:var(--tx)">成交量萎缩</span>
            <span style="font-size:9px;padding:2px 8px;background:rgba(59,130,246,.1);border:1px solid rgba(59,130,246,.2);border-radius:20px;color:#60a5fa;letter-spacing:1px">VOLUME DRY</span>
          </div>
          <div style="font-size:12px;color:var(--tx2);line-height:1.8;margin-bottom:10px">连续 <strong style="color:var(--tx)">2 个周期</strong>无活跃任务且成交量低于均值 <strong style="color:var(--tx)">30%</strong>，判定为流动性枯竭。发布小额买入任务，重新引入交易热度。</div>
          <div style="font-size:11px;color:var(--tx3);background:rgba(255,255,255,.02);border-radius:8px;padding:8px 12px;border-left:2px solid rgba(59,130,246,.3)">设计原因：死盘的特征就是没人交易，小额任务是激活流动性成本最低的手段。</div>
        </div>
      </div>
      <div style="background:rgba(124,58,237,.05);border:1px solid rgba(124,58,237,.2);border-radius:16px;padding:20px 24px;display:flex;gap:20px;align-items:flex-start">
        <div style="flex-shrink:0;width:36px;padding-top:2px;text-align:center">
          <div style="font-size:11px;font-weight:900;color:var(--p);letter-spacing:1px">AI</div>
          <div style="font-size:9px;color:var(--tx3);margin-top:3px">兜底</div>
        </div>
        <div style="flex:1">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;flex-wrap:wrap">
            <span style="font-size:13px;font-weight:800;color:var(--tx)">LLM 自由决策</span>
            <span style="font-size:9px;padding:2px 8px;background:rgba(124,58,237,.1);border:1px solid rgba(124,58,237,.25);border-radius:20px;color:var(--p);letter-spacing:1px">GPT-5.4</span>
          </div>
          <div style="font-size:12px;color:var(--tx2);line-height:1.8;margin-bottom:10px">以上规则均未命中时，将全量信号（价格、成交量、资金费率、鲸鱼数据、任务历史）输入 GPT-5.4，由模型综合推理输出最优任务方案。</div>
          <div style="font-size:11px;color:var(--tx3);background:rgba(255,255,255,.02);border-radius:8px;padding:8px 12px;border-left:2px solid rgba(124,58,237,.3)">LLM 输出受 Prompt 约束，只能选择合法任务类型，奖励金额不超过单次上限，防止幻觉乱发。</div>
        </div>
      </div>
    </div>
  </div>

  <!-- PERSONA -->
  <div style="margin-bottom:56px">
    <div style="font-size:9px;font-weight:700;letter-spacing:4px;color:var(--tx3);text-transform:uppercase;margin-bottom:8px">PERSONA &nbsp;·&nbsp; 人格系统</div>
    <div style="font-size:12px;color:var(--tx3);margin-bottom:24px;line-height:1.8">每 30 分钟自动评估市场状态，切换至最匹配的运营人格。人格影响任务频率、奖励力度和类型偏好。</div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px">
      <div style="background:rgba(239,68,68,.05);border:1px solid rgba(239,68,68,.15);border-radius:16px;padding:20px">
        <div style="width:32px;height:32px;background:#dc2626;border-radius:6px;margin:0 0 12px"></div>
        <div style="font-size:14px;font-weight:900;letter-spacing:.5px;margin-bottom:2px">猎手</div>
        <div style="font-size:9px;color:#f87171;letter-spacing:2px;margin-bottom:14px">HUNTER</div>
        <div style="font-size:11px;color:var(--tx3);line-height:1.9">
          <div style="color:var(--tx2);margin-bottom:4px;font-weight:600">触发：</div>
          <div style="padding-left:8px;border-left:2px solid rgba(239,68,68,.3);color:var(--tx2);margin-bottom:10px">BNB 急跌 &gt;8%<br>任务完成率 &lt;20%</div>
          <div style="color:var(--tx2);margin-bottom:4px;font-weight:600">策略：</div>
          <div style="padding-left:8px;border-left:2px solid rgba(239,68,68,.3);color:var(--tx2)">短平快高频小额<br>制造持续 FOMO</div>
        </div>
      </div>
      <div style="background:rgba(217,119,6,.05);border:1px solid rgba(217,119,6,.15);border-radius:16px;padding:20px">
        <div style="width:32px;height:32px;background:#d97706;border-radius:6px;margin:0 0 12px"></div>
        <div style="font-size:14px;font-weight:900;letter-spacing:.5px;margin-bottom:2px">军师</div>
        <div style="font-size:9px;color:#fbbf24;letter-spacing:2px;margin-bottom:14px">STRATEGIST</div>
        <div style="font-size:11px;color:var(--tx3);line-height:1.9">
          <div style="color:var(--tx2);margin-bottom:4px;font-weight:600">触发：</div>
          <div style="padding-left:8px;border-left:2px solid rgba(217,119,6,.3);color:var(--tx2);margin-bottom:10px">任务完成率 &gt;70%<br>市场平稳横盘</div>
          <div style="color:var(--tx2);margin-bottom:4px;font-weight:600">策略：</div>
          <div style="padding-left:8px;border-left:2px solid rgba(217,119,6,.3);color:var(--tx2)">低频大额精准<br>最大化资金效率</div>
        </div>
      </div>
      <div style="background:rgba(5,150,105,.05);border:1px solid rgba(5,150,105,.15);border-radius:16px;padding:20px">
        <div style="width:32px;height:32px;background:#059669;border-radius:6px;margin:0 0 12px"></div>
        <div style="font-size:14px;font-weight:900;letter-spacing:.5px;margin-bottom:2px">传令官</div>
        <div style="font-size:9px;color:#34d399;letter-spacing:2px;margin-bottom:14px">HERALD</div>
        <div style="font-size:11px;color:var(--tx3);line-height:1.9">
          <div style="color:var(--tx2);margin-bottom:4px;font-weight:600">触发：</div>
          <div style="padding-left:8px;border-left:2px solid rgba(5,150,105,.3);color:var(--tx2);margin-bottom:10px">BNB 大涨 &gt;5%<br>热度处于峰值</div>
          <div style="color:var(--tx2);margin-bottom:4px;font-weight:600">策略：</div>
          <div style="padding-left:8px;border-left:2px solid rgba(5,150,105,.3);color:var(--tx2)">造势狂欢趁热打<br>最大化参与人数</div>
        </div>
      </div>
    </div>
  </div>
  <!-- FUND SAFETY -->
  <div style="margin-bottom:56px">
    <div style="font-size:9px;font-weight:700;letter-spacing:4px;color:var(--tx3);text-transform:uppercase;margin-bottom:24px">FUND SAFETY &nbsp;·&nbsp; 资金安全</div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px">
      <div style="background:rgba(52,211,153,.05);border:1px solid rgba(52,211,153,.15);border-radius:16px;padding:20px">
        <div style="font-size:10px;font-weight:700;letter-spacing:2px;color:#34d399;margin-bottom:14px">Agent 能做</div>
        <div style="display:flex;flex-direction:column;gap:9px;font-size:12px;color:var(--tx2)">
          <div style="display:flex;gap:8px"><span style="color:#34d399;flex-shrink:0">◆</span>从 taxPool 发布任务</div>
          <div style="display:flex;gap:8px"><span style="color:#34d399;flex-shrink:0">◆</span>调用合约白名单函数</div>
          <div style="display:flex;gap:8px"><span style="color:#34d399;flex-shrink:0">◆</span>支付交易 Gas 费用</div>
          <div style="display:flex;gap:8px"><span style="color:#34d399;flex-shrink:0">◆</span>自动退款过期任务</div>
        </div>
      </div>
      <div style="background:rgba(239,68,68,.05);border:1px solid rgba(239,68,68,.15);border-radius:16px;padding:20px">
        <div style="font-size:10px;font-weight:700;letter-spacing:2px;color:#f87171;margin-bottom:14px">Agent 不能做</div>
        <div style="display:flex;flex-direction:column;gap:9px;font-size:12px;color:var(--tx2)">
          <div style="display:flex;gap:8px"><span style="color:#f87171;flex-shrink:0">×</span>提取 taxPool 资金</div>
          <div style="display:flex;gap:8px"><span style="color:#f87171;flex-shrink:0">×</span>修改合约规则</div>
          <div style="display:flex;gap:8px"><span style="color:#f87171;flex-shrink:0">×</span>用自己的钱发任务</div>
          <div style="display:flex;gap:8px"><span style="color:#f87171;flex-shrink:0">×</span>绕过合约直接转账</div>
        </div>
      </div>
    </div>
    <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:12px;padding:14px 18px;font-size:12px;color:var(--tx2);line-height:1.9">taxPool 锁在 <strong style="color:var(--tx)">AgentRegistry 合约</strong>，任何人（包括 Agent 本身）无法直接提取。奖励只能通过合约函数定向发放给任务完成者，全程链上可查，代码即规则。</div>
  </div>


  <!-- HOW IT WORKS: 完整决策流程 -->
  <div style="margin-bottom:56px">
    <div style="font-size:9px;font-weight:700;letter-spacing:4px;color:var(--tx3);text-transform:uppercase;margin-bottom:8px">DECISION FLOW &nbsp;·&nbsp; 完整决策示例</div>
    <div style="font-size:12px;color:var(--tx3);margin-bottom:24px;line-height:1.8">以下是一个真实场景：某代币委托 Agent 后，一次完整的 3 分钟循环内发生了什么。</div>
    <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:20px;overflow:hidden">
      <div style="padding:20px 24px;border-bottom:1px solid rgba(255,255,255,.05);display:flex;gap:16px;align-items:flex-start">
        <div style="flex-shrink:0;width:28px;height:28px;background:rgba(167,139,250,.15);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:900;color:var(--p)">1</div>
        <div>
          <div style="font-size:12px;font-weight:700;color:var(--tx);margin-bottom:4px">采集信号 &nbsp;<span style="font-weight:400;color:var(--tx3)">T=0:00</span></div>
          <div style="font-size:12px;color:var(--tx2);line-height:1.8">Agent 从链上读取 BNB 报价 <strong style="color:var(--tx)">+2.3%</strong>，资金费率 <strong style="color:var(--tx)">+0.012%</strong>（偏多但未过热）；从 DexScreener 读取该代币 10m 成交量 <strong style="color:var(--tx)">1.8×</strong> 均值（未达峰值阈值 3×）；任务完成率 <strong style="color:var(--tx)">55%</strong>，taxPool 余额 <strong style="color:var(--tx)">0.04 BNB（BSC）</strong>。</div>
        </div>
      </div>
      <div style="padding:20px 24px;border-bottom:1px solid rgba(255,255,255,.05);display:flex;gap:16px;align-items:flex-start">
        <div style="flex-shrink:0;width:28px;height:28px;background:rgba(59,130,246,.15);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:900;color:#3b82f6">2</div>
        <div>
          <div style="font-size:12px;font-weight:700;color:var(--tx);margin-bottom:4px">规则匹配 &nbsp;<span style="font-weight:400;color:var(--tx3)">T=0:01</span></div>
          <div style="font-size:12px;color:var(--tx2);line-height:1.8">依次检查 5 条触发规则：热度峰值（否，1.8× &lt; 3×）→ 抄底（否，未跌）→ BNB恐慌（否，BNB涨）→ <strong style="color:#34d399">BNB 上涨联动（命中！BNB +2.3% &gt; +5%？否，未达）</strong> → 成交量萎缩（否，量正常）。全部未命中，进入 LLM 阶段。</div>
        </div>
      </div>
      <div style="padding:20px 24px;border-bottom:1px solid rgba(255,255,255,.05);display:flex;gap:16px;align-items:flex-start">
        <div style="flex-shrink:0;width:28px;height:28px;background:rgba(124,58,237,.15);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:900;color:var(--p)">3</div>
        <div>
          <div style="font-size:12px;font-weight:700;color:var(--tx);margin-bottom:4px">LLM 推理 &nbsp;<span style="font-weight:400;color:var(--tx3)">T=0:02</span></div>
          <div style="font-size:12px;color:var(--tx2);line-height:1.8">将全量信号组装成 Prompt 发送给 GPT-5.4：<span style="font-family:monospace;font-size:11px;color:var(--p);background:rgba(124,58,237,.08);padding:2px 6px;border-radius:4px">BNB小涨，量适中，完成率中等，人格=军师</span>。模型输出：发布<strong style="color:var(--tx)">持仓任务</strong>，奖励 <strong style="color:var(--tx)">0.0018 Gas 代币</strong>，窗口期 <strong style="color:var(--tx)">20 分钟</strong>，持仓门槛 <strong style="color:var(--tx)">888万 token</strong>。</div>
        </div>
      </div>
      <div style="padding:20px 24px;display:flex;gap:16px;align-items:flex-start">
        <div style="flex-shrink:0;width:28px;height:28px;background:rgba(52,211,153,.15);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:900;color:#34d399">4</div>
        <div>
          <div style="font-size:12px;font-weight:700;color:var(--tx);margin-bottom:4px">链上执行 &nbsp;<span style="font-weight:400;color:var(--tx3)">T=0:03</span></div>
          <div style="font-size:12px;color:var(--tx2);line-height:1.8">Agent 签名调用 <span style="font-family:monospace;font-size:11px;color:var(--p);background:rgba(124,58,237,.08);padding:2px 6px;border-radius:4px">createTask()</span>，从 taxPool 扣款 0.009 Gas 代币（5 人 × 0.0018），链上记录任务 ID 写入日志。20 分钟后若未满员，合约自动退款，进入下一轮循环。</div>
        </div>
      </div>
    </div>
  </div>

  <!-- FAQ -->
  <div style="margin-bottom:56px">
    <div style="font-size:9px;font-weight:700;letter-spacing:4px;color:var(--tx3);text-transform:uppercase;margin-bottom:24px">FAQ &nbsp;·&nbsp; 常见问题</div>
    <div style="display:flex;flex-direction:column;gap:8px">
      <details style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:14px;padding:16px 20px;cursor:pointer">
        <summary style="font-size:13px;font-weight:700;color:var(--tx);list-style:none;display:flex;justify-content:space-between;align-items:center">Agent 会不会乱发任务烧光预算？<span style="color:var(--tx3);font-size:16px">+</span></summary>
        <div style="font-size:12px;color:var(--tx2);line-height:1.9;margin-top:12px;padding-top:12px;border-top:1px solid rgba(255,255,255,.05)">不会。每次发任务前，Agent 会检查 <strong style="color:var(--tx)">taxPool 或 job.budget 余额是否充足</strong>。单次奖励上限由委托参数决定，Agent 无法超出。若余额不足以支付一次完整任务，Agent 跳过本轮，等待下次循环。</div>
      </details>
      <details style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:14px;padding:16px 20px;cursor:pointer">
        <summary style="font-size:13px;font-weight:700;color:var(--tx);list-style:none;display:flex;justify-content:space-between;align-items:center">Agent 私钥泄露了怎么办？<span style="color:var(--tx3);font-size:16px">+</span></summary>
        <div style="font-size:12px;color:var(--tx2);line-height:1.9;margin-top:12px;padding-top:12px;border-top:1px solid rgba(255,255,255,.05)">Agent 私钥只能调用合约白名单函数（createTask、cancelTask 等），<strong style="color:var(--tx)">无法转账、无法提取 taxPool</strong>。即使私钥泄露，攻击者最多能：发布无效任务（会被合约校验拦截）、浪费少量 Gas。真正的资金在合约里，与 Agent 私钥完全隔离。</div>
      </details>
      <details style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:14px;padding:16px 20px;cursor:pointer">
        <summary style="font-size:13px;font-weight:700;color:var(--tx);list-style:none;display:flex;justify-content:space-between;align-items:center">taxPool 里的钱我还能取出来吗？<span style="color:var(--tx3);font-size:16px">+</span></summary>
        <div style="font-size:12px;color:var(--tx2);line-height:1.9;margin-top:12px;padding-top:12px;border-top:1px solid rgba(255,255,255,.05)">taxPool 来自 four.meme 交易税，属于平台公共资金，<strong style="color:var(--tx)">任何人都无法单方面提取</strong>，包括项目方和 Seki 团队。委托方存入的 job.budget 可通过 <strong style="color:var(--tx)">cancelJob → claimRefund</strong> 退回，到期自动退款，链上可查。</div>
      </details>
      <details style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:14px;padding:16px 20px;cursor:pointer">
        <summary style="font-size:13px;font-weight:700;color:var(--tx);list-style:none;display:flex;justify-content:space-between;align-items:center">LLM 会不会输出有害内容或异常任务？<span style="color:var(--tx3);font-size:16px">+</span></summary>
        <div style="font-size:12px;color:var(--tx2);line-height:1.9;margin-top:12px;padding-top:12px;border-top:1px solid rgba(255,255,255,.05)">LLM 输出经过 <strong style="color:var(--tx)">严格的后处理校验</strong>：任务类型必须在枚举范围内（持仓/买入/早鸟/锦标赛），奖励金额不超过单次上限，窗口期在 10~45 分钟之间。解析失败或超限时，Agent 本轮跳过，不执行任何操作。</div>
      </details>
      <details style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:14px;padding:16px 20px;cursor:pointer">
        <summary style="font-size:13px;font-weight:700;color:var(--tx);list-style:none;display:flex;justify-content:space-between;align-items:center">持仓任务怎么验证我真的持有了？<span style="color:var(--tx3);font-size:16px">+</span></summary>
