 <div style="font-size:15px;font-weight:800" id="mkt-ob">—</div>
 </div>
 <div style="background:rgba(255,255,255,.04);border-radius:12px;padding:10px">
 <div style="font-size:10px;color:var(--tx3);margin-bottom:4px">BNB 24h</div>
 <div style="font-size:15px;font-weight:800" id="mkt-bnb">—</div>
 </div>
 <div style="background:rgba(255,255,255,.04);border-radius:12px;padding:10px">
 <div style="font-size:10px;color:var(--tx3);margin-bottom:4px">鲸鱼大单(3m)</div>
 <div style="font-size:15px;font-weight:800" id="mkt-whale">—</div>
 </div>
