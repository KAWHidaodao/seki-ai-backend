            <div style="font-size:13px;font-weight:700;margin-bottom:6px">配置 Agent</div>
            <div style="font-size:11px;color:var(--tx3)">填写 .env 环境变量，配置 RPC、私钥、LLM Key</div>
          </div>
          <div style="padding:20px;background:rgba(52,211,153,.06);border:1px solid rgba(52,211,153,.2);border-radius:16px;text-align:center">
