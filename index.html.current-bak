<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Seki — AI Agent 链上激励平台</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/ethers/6.7.0/ethers.umd.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
 --bg:rgba(255,255,255,.04);--bg2:rgba(255,255,255,.07);--bg3:rgba(255,255,255,.12);
 --bd:rgba(255,255,255,.1);--bd2:rgba(255,255,255,.18);
 --tx:#f0f0f8;--tx2:#a8a8c0;--tx3:#5a5a78;
 --p:#a78bfa;--p2:#7c3aed;--pl:rgba(167,139,250,.12);
 --gr:#34d399;--re:#f87171;
 --chain-accent:#f59e0b;
 --font:-apple-system,BlinkMacSystemFont,"Inter","SF Pro Display",sans-serif;
}
/* BSC 主题 */
body.world-xlayer{
 background:#08050f !important;
 background-image:
   radial-gradient(ellipse 100% 60% at 50% -10%,rgba(88,28,220,.3) 0%,transparent 65%),
   radial-gradient(ellipse 60% 40% at 90% 100%,rgba(99,58,237,.15) 0%,transparent 60%) !important;
}
body.world-xlayer .nav{
 background:transparent;
 
}
body.world-xlayer .nav-logo-sub{color:#a78bfa !important;}
body.world-xlayer .nl.on{color:#a78bfa;border-bottom-color:#a78bfa;}
body.world-xlayer .hero-btn-primary{
 background:linear-gradient(135deg,#5b21b6,#4338ca) !important;
 box-shadow:0 4px 24px rgba(88,28,220,.5) !important;
}
body.world-xlayer .hero-panel{background:linear-gradient(145deg,rgba(255,255,255,.07) 0%,rgba(120,40,255,.06) 100%);backdrop-filter:blur(32px) saturate(180%);border:1px solid rgba(255,255,255,.12);border-top:1px solid rgba(255,255,255,.22);border-radius:24px;padding:28px;position:relative;overflow:hidden;box-shadow:0 20px 80px rgba(0,0,0,.4),inset 0 1px 0 rgba(255,255,255,.15)}
body.world-xlayer .hero-bg-orb.orb1{
 width:700px;height:700px;top:-200px;left:-150px;
 background:radial-gradient(circle,rgba(120,40,255,.4) 0%,rgba(88,28,220,.15) 40%,transparent 70%);
 filter:blur(90px);
 animation:orbFloat1 12s ease-in-out infinite;
}
.hero-bg-orb.orb2{
 width:500px;height:500px;bottom:-100px;right:-100px;
 background:radial-gradient(circle,rgba(59,130,246,.3) 0%,rgba(99,58,237,.12) 40%,transparent 70%);
 filter:blur(80px);
 animation:orbFloat2 15s ease-in-out infinite;
}
.hero-bg-orb.orb3{
 width:300px;height:300px;top:40%;left:55%;
 background:radial-gradient(circle,rgba(167,139,250,.2) 0%,transparent 70%);
 filter:blur(60px);
 animation:orbFloat1 18s ease-in-out infinite reverse;
}
@keyframes orbFloat1{
 0%,100%{transform:translate(0,0) scale(1);}
 33%{transform:translate(30px,-40px) scale(1.05);}
 66%{transform:translate(-20px,20px) scale(.97);}
}
@keyframes orbFloat2{
 0%,100%{transform:translate(0,0) scale(1);}
 50%{transform:translate(-40px,-30px) scale(1.08);}
}
body.world-xlayer .card::before{content:'';position:absolute;inset:0;border-radius:20px;background:radial-gradient(ellipse 80% 50% at 50% -20%,rgba(167,139,250,.08),transparent);pointer-events:none;}
.card:hover{
 border-color:rgba(167,139,250,.4);
 box-shadow:0 8px 48px rgba(120,40,255,.2),0 0 0 1px rgba(167,139,250,.15);
 transform:translateY(-2px);
}
body.world-xlayer #chain-switcher{
 border-color:rgba(99,58,237,.45) !important;
 background:rgba(88,28,220,.1) !important;
}
body.world-xlayer .tc{border-color:rgba(88,28,220,.2);}
body.world-xlayer .tc:hover{border-color:rgba(88,28,220,.5) !important;box-shadow:0 4px 24px rgba(88,28,220,.2);}
body.world-xlayer .cbg{background:rgba(88,28,220,.15);color:#a78bfa;border-color:rgba(88,28,220,.3);}
body.world-xlayer .cbg.ag{background:rgba(88,28,220,.2);}
body.world-xlayer .hero-h1{color:#e0d4ff;letter-spacing:-3px;line-height:.9;}
body.world-xlayer .pn-btn-main{background:linear-gradient(135deg,#5b21b6,#4338ca) !important;}
body.world-xlayer .agd-header .ldot{background:#a78bfa;}
body.world-xlayer #wbtn{background:rgba(88,28,220,.25);border-color:rgba(99,58,237,.4);color:#c4b5fd;}
/* 切链过渡动画 */
body{transition:background .4s ease;}
.nav{transition:background .3s ease, border-bottom .3s ease;}
#hero-line1,#hero-line2,#hero-desc,#hero-tagline{transition:opacity .2s ease;}

html{scroll-behavior:smooth}
body{
 background:#06050f;
 background-image:
   radial-gradient(ellipse 140% 70% at 50% -5%,rgba(99,102,241,.18) 0%,transparent 60%),
   radial-gradient(ellipse 60% 50% at 10% 30%,rgba(139,92,246,.1) 0%,transparent 55%),
   radial-gradient(ellipse 50% 40% at 90% 70%,rgba(59,130,246,.08) 0%,transparent 55%);
 color:var(--tx);font-family:var(--font);-webkit-font-smoothing:antialiased;line-height:1.5;min-height:100vh
}
.display{font-size:clamp(48px,7vw,88px);font-weight:900;letter-spacing:-3px;line-height:.92}
.headline{font-size:clamp(28px,4vw,52px);font-weight:900;letter-spacing:-2px;line-height:.95}
.label{font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--p)}
.accent{color:var(--p)}
.pw,.page{}.pw.on,.page.on{display:block}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:24px}
.grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
/* NAV */
.nav{position:fixed;top:0;left:0;right:0;z-index:100;background:transparent;border-bottom:none;height:48px;display:flex;align-items:center;transition:background .25s ease}
.nav.scrolled{background:rgba(6,4,18,.6);backdrop-filter:blur(14px);border-bottom:1px solid rgba(255,255,255,.05)}
.nav-inner{max-width:1200px;margin:0 auto;padding:0 40px;display:flex;align-items:center;width:100%}
.nav-logo{display:flex;align-items:center;gap:8px;margin-right:32px;flex-shrink:0;cursor:pointer;border:none;background:transparent;font-family:var(--font);padding:0}
.nav-logo-avatar{width:26px;height:26px;border-radius:50%;object-fit:cover;border:1px solid rgba(255,255,255,.15);flex-shrink:0}
.nav-logo-text{display:flex;flex-direction:column;align-items:flex-start;line-height:1}
.nav-logo-name{font-size:13px;font-weight:700;letter-spacing:-.3px;color:#fff}
.nav-logo-sub{font-size:8px;font-weight:500;color:rgba(255,255,255,.3);letter-spacing:2px;text-transform:uppercase;margin-top:2px}
.nav-links{display:flex;flex:1;overflow-x:auto}
.nl{padding:0 12px;height:48px;font-size:12px;font-weight:400;color:rgba(255,255,255,.5);background:transparent;border:none;cursor:pointer;font-family:var(--font);border-bottom:2px solid transparent;transition:all .15s;white-space:nowrap;letter-spacing:.1px}
.nl:hover{color:rgba(255,255,255,.85)}.nl.on{color:rgba(255,255,255,.9);font-weight:600;border-bottom-color:rgba(255,255,255,.4)}
.nav-right{margin-left:auto;display:flex;align-items:center;gap:8px;flex-shrink:0}
.nav-wallet{padding:7px 16px;font-size:12px;font-weight:600;background:#3730a3;color:#fff;border:none;border-radius:7px;cursor:pointer;font-family:var(--font);letter-spacing:.2px}
.nav-wallet:hover{background:#4338ca}.nav-wallet.connected{background:rgba(5,150,105,.8)}
/* BUTTONS */
.btn-primary{display:inline-flex;align-items:center;gap:8px;padding:12px 24px;font-size:14px;font-weight:700;background:linear-gradient(135deg,#7c3aed,#6d28d9);color:#fff;border:none;border-radius:10px;cursor:pointer;font-family:var(--font);transition:all .2s;box-shadow:0 4px 16px rgba(124,58,237,.4)}
.btn-primary:hover{background:linear-gradient(135deg,#8b5cf6,#7c3aed);transform:translateY(-2px);box-shadow:0 6px 24px rgba(124,58,237,.55)}
.btn-secondary{display:inline-flex;align-items:center;gap:8px;padding:12px 24px;font-size:14px;font-weight:700;background:rgba(255,255,255,.05);color:var(--tx);border:1px solid rgba(255,255,255,.18);border-radius:10px;cursor:pointer;font-family:var(--font);transition:all .2s;backdrop-filter:blur(8px)}
.btn-secondary:hover{background:rgba(255,255,255,.1);border-color:var(--p);transform:translateY(-1px)}
.btnp{background:linear-gradient(135deg,#7c3aed,#6d28d9);color:#fff;border:none;border-radius:10px;cursor:pointer;font-family:var(--font);font-size:14px;font-weight:700;padding:11px 20px;transition:all .2s;box-shadow:0 4px 16px rgba(124,58,237,.35)}
.btnp:hover{background:var(--p2)}
.btns{background:rgba(255,255,255,.05);color:var(--tx);border:1px solid rgba(255,255,255,.15);border-radius:10px;cursor:pointer;font-family:var(--font);font-size:13px;font-weight:600;padding:10px 18px;transition:all .2s;backdrop-filter:blur(8px)}
.btns:hover{border-color:var(--p);background:rgba(255,255,255,.09)}.cb{
 width:100%;padding:11px;
 background:rgba(124,58,237,.1);
 border:1px solid rgba(124,58,237,.25);
 border-radius:12px;
 color:var(--p);
 font-size:13px;font-weight:700;
 cursor:pointer;font-family:var(--font);
 transition:all .2s;letter-spacing:.3px;
}
.cb:hover:not(:disabled){background:rgba(124,58,237,.2);border-color:rgba(124,58,237,.5);color:#c4b5fd}
.cb:disabled{opacity:.35;cursor:default}
.cb.dn{background:rgba(5,150,105,.08);border-color:rgba(5,150,105,.2);color:var(--gr)}
/* CARDS */
.card{background:linear-gradient(145deg,rgba(255,255,255,.055) 0%,rgba(255,255,255,.025) 100%);backdrop-filter:blur(20px) saturate(150%);border:1px solid rgba(255,255,255,.1);border-top:1px solid rgba(255,255,255,.18);border-radius:20px;padding:24px;transition:all .3s cubic-bezier(.23,1,.32,1);position:relative;overflow:hidden}
.card:hover{border-color:var(--p);box-shadow:0 4px 32px rgba(124,58,237,.2);transform:translateY(-2px)}
.card-flat{background:rgba(255,255,255,.04);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.09);border-radius:16px;padding:24px}
/* FORM */
.fg{display:flex;flex-direction:column;gap:6px;margin-bottom:16px}
.fl{font-size:12px;font-weight:600;color:var(--tx2);letter-spacing:.3px}
.fi{padding:11px 14px;font-size:14px;color:var(--tx);background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:10px;font-family:var(--font);outline:none;transition:all .2s;width:100%}
.fi:focus{border-color:var(--p);background:rgba(255,255,255,.1);box-shadow:0 0 0 3px rgba(167,139,250,.15)}
textarea.fi{resize:vertical}
.fs{padding:11px 14px;font-size:14px;color:var(--tx);background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:10px;font-family:var(--font);outline:none;width:100%;cursor:pointer}
.fs:focus{border-color:var(--p)}.fr2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.df{background:rgba(255,255,255,.04);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.09);border-radius:16px;padding:24px}
/* TASK CARDS */
.tg{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px}
.tc{
 background:rgba(12,12,28,.6);
 backdrop-filter:blur(16px);
 border:1px solid rgba(255,255,255,.07);
 border-radius:20px;
 padding:24px;
 cursor:pointer;
 transition:all .25s cubic-bezier(.4,0,.2,1);
 position:relative;
 overflow:hidden;
}
.tc::before{
 content:'';position:absolute;inset:0;
 background:radial-gradient(ellipse at top left,rgba(124,58,237,.08) 0%,transparent 60%);
 pointer-events:none;opacity:0;transition:opacity .3s;
}
.tc:hover{border-color:rgba(124,58,237,.35);transform:translateY(-2px);box-shadow:0 12px 40px rgba(0,0,0,.4),0 0 0 1px rgba(124,58,237,.15)}
.tc:hover::before{opacity:1}
.tc.full{opacity:.55;filter:saturate(.6)}
.tch{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.cti{font-size:15px;font-weight:800;color:var(--tx);margin-bottom:6px;line-height:1.35;letter-spacing:-.3px}
.ctk{font-size:10px;color:var(--tx3);font-family:monospace;margin-bottom:12px;opacity:.7}
.cde{font-size:12px;color:var(--tx3);line-height:1.6;margin-bottom:16px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.crw{font-size:26px;font-weight:900;background:linear-gradient(135deg,#a78bfa,#60a5fa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:-1px;line-height:1}
.crl{font-size:11px;color:var(--tx3);margin-top:3px;margin-bottom:16px}
.cpb{height:2px;background:rgba(255,255,255,.06);border-radius:2px;margin-bottom:8px}
.cbr{height:2px;background:rgba(255,255,255,.06);border-radius:2px;margin-bottom:8px;overflow:hidden}
.cbf{height:100%;background:linear-gradient(90deg,#7c3aed,#3b82f6);border-radius:2px;transition:width .6s}
.cft{display:flex;justify-content:space-between;font-size:11px;color:var(--tx3);margin-bottom:16px}
.cbg{font-size:10px;font-weight:700;letter-spacing:.5px;padding:4px 10px;border-radius:8px;background:rgba(124,58,237,.12);color:var(--p);border:1px solid rgba(124,58,237,.2)}
.cbg.ag{background:rgba(96,165,250,.1);color:#60a5fa;border-color:rgba(96,165,250,.2)}
.cs{font-size:10px;font-weight:700;padding:4px 10px;border-radius:8px;letter-spacing:.3px}
.cs.go{background:rgba(5,150,105,.12);color:var(--gr);border:1px solid rgba(5,150,105,.2)}
.cs.no{background:rgba(239,68,68,.08);color:#ef4444;border:1px solid rgba(239,68,68,.15)}

.cb{
 width:100%;padding:11px;
 background:rgba(124,58,237,.1);
 border:1px solid rgba(124,58,237,.25);
 border-radius:12px;
 color:var(--p);
 font-size:13px;font-weight:700;
 cursor:pointer;font-family:var(--font);
 transition:all .2s;letter-spacing:.3px;
}
.cb:hover:not(:disabled){background:rgba(124,58,237,.2);border-color:rgba(124,58,237,.5);color:#c4b5fd}
.cb:disabled{opacity:.35;cursor:default}
.cb.dn{background:rgba(5,150,105,.08);border-color:rgba(5,150,105,.2);color:var(--gr)}
/* CARDS */
.card{background:rgba(255,255,255,.04);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.09);border-radius:16px;padding:24px;transition:all .2s}
.card:hover{border-color:var(--p);box-shadow:0 4px 32px rgba(124,58,237,.2);transform:translateY(-2px)}
.card-flat{background:rgba(255,255,255,.04);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.09);border-radius:16px;padding:24px}
/* FORM */
.fg{display:flex;flex-direction:column;gap:6px;margin-bottom:16px}
.fl{font-size:12px;font-weight:600;color:var(--tx2);letter-spacing:.3px}
.fi{padding:11px 14px;font-size:14px;color:var(--tx);background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:10px;font-family:var(--font);outline:none;transition:all .2s;width:100%}
.fi:focus{border-color:var(--p);background:rgba(255,255,255,.1);box-shadow:0 0 0 3px rgba(167,139,250,.15)}
textarea.fi{resize:vertical}
.fs{padding:11px 14px;font-size:14px;color:var(--tx);background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:10px;font-family:var(--font);outline:none;width:100%;cursor:pointer}
.fs:focus{border-color:var(--p)}.fr2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.df{background:rgba(255,255,255,.04);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.09);border-radius:16px;padding:24px}
/* TASK CARDS */
.tg{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px}
.tc{background:rgba(255,255,255,.04);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.08);border-radius:16px;padding:20px;cursor:pointer;transition:all .2s;position:relative;overflow:hidden}
.tc::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px}
.tc.t0::before{background:#8b5cf6}.tc.t1::before{background:#3b82f6}
.tc.t2::before{background:#f59e0b}.tc.t3::before{background:#10b981}.tc.t4::before{background:#ef4444}
.tc:hover{border-color:var(--p);box-shadow:0 4px 32px rgba(124,58,237,.25);transform:translateY(-2px)}
.tc.done{opacity:.5}
.tch{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.cti{font-size:16px;font-weight:800;color:var(--tx);margin-bottom:4px;line-height:1.3}
.ctk{font-size:11px;color:var(--tx3);font-family:monospace;margin-bottom:8px}
.cde{font-size:13px;color:var(--tx2);line-height:1.5;margin-bottom:12px}
.crw{font-size:24px;font-weight:900;color:var(--p);letter-spacing:-1px}
.crl{font-size:12px;color:var(--tx3);margin-top:2px;margin-bottom:12px}
.cpb{height:4px;background:var(--bd);border-radius:2px;overflow:hidden}
.cpb-fill{height:100%;background:var(--p);border-radius:2px}
.cpb-txt{display:flex;justify-content:space-between;font-size:11px;color:var(--tx3);margin-top:4px}
.cbg{font-size:10px;font-weight:700;letter-spacing:.5px;padding:3px 8px;border-radius:6px;background:var(--pl);color:var(--p);border:1px solid #ddd6fe}
.cbg.ag{background:var(--tx);color:#fff;border-color:var(--tx)}
.cs{font-size:11px;font-weight:700;padding:3px 8px;border-radius:6px}
.cs.go{background:#f0fdf4;color:var(--gr)}.cs.no{background:var(--bg2);color:var(--tx3)}
.dn{opacity:.5}
.empty{text-align:center;padding:48px 20px;color:var(--tx3);font-size:14px;border:1px dashed rgba(255,255,255,.1);border-radius:12px}
.ft-wrap{display:flex;border-bottom:1px solid rgba(255,255,255,.08);margin-bottom:28px;overflow-x:auto}
.ft{padding:10px 18px;font-size:13px;font-weight:500;color:var(--tx3);background:transparent;border:none;cursor:pointer;font-family:var(--font);border-bottom:2px solid transparent;margin-bottom:-1px;white-space:nowrap;transition:all .2s}
.ft:hover{color:var(--tx)}.ft.on{color:var(--p);font-weight:700;border-bottom-color:var(--p)}
/* PANEL */
.pw2{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:200;display:none;align-items:center;justify-content:center;backdrop-filter:blur(8px)}
.pw2.on{display:flex}
.pn{background:rgba(8,7,20,.97);backdrop-filter:blur(32px);width:520px;max-height:88vh;overflow-y:auto;border:1px solid rgba(124,58,237,.2);border-radius:24px;box-shadow:0 0 80px rgba(124,58,237,.2),0 24px 60px rgba(0,0,0,.8);display:flex;flex-direction:column;position:relative}
.pn::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;border-radius:24px 24px 0 0;background:linear-gradient(90deg,transparent 0%,rgba(124,58,237,.8) 30%,rgba(96,165,250,.5) 70%,transparent 100%)}

/* 头部 */
.pn-header{display:flex;align-items:center;justify-content:space-between;padding:20px 24px 0;flex-shrink:0}
.pc{background:transparent;border:1px solid rgba(255,255,255,.1);color:var(--tx3);width:36px;height:36px;border-radius:10px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s}
.pc:hover{border-color:rgba(255,255,255,.3);color:var(--tx)}
.pn-header-center{flex:1;text-align:center}
.pn-tag{display:inline-block;padding:4px 12px;background:rgba(124,58,237,.12);border:1px solid rgba(124,58,237,.2);border-radius:20px;font-size:11px;font-weight:700;color:var(--p);letter-spacing:.5px}
.pn-header-right{width:36px;text-align:right}
.pn-id{font-size:12px;color:var(--tx3);font-family:monospace}

/* 奖励英雄区 */
.pn-reward-hero{padding:28px 24px 24px;text-align:center;position:relative;border-bottom:1px solid rgba(255,255,255,.05);flex-shrink:0}
.pn-reward-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%,rgba(124,58,237,.12) 0%,transparent 70%);pointer-events:none}
.pn-reward-val{font-size:48px;font-weight:900;letter-spacing:-2px;background:linear-gradient(135deg,#e9d5ff,#a78bfa,#60a5fa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1;margin-bottom:6px}
.pn-reward-sub{font-size:11px;color:var(--tx3);letter-spacing:1px;text-transform:uppercase;margin-bottom:16px}
.pn-reward-progress{height:2px;background:rgba(255,255,255,.06);border-radius:2px;margin:0 auto 10px;max-width:200px}
.pn-reward-bar{height:100%;background:linear-gradient(90deg,#7c3aed,#3b82f6);border-radius:2px;transition:width .6s}
.pn-reward-stat{font-size:12px;color:var(--tx3)}

/* 面板内容区 */
#pbody{padding:20px 24px 32px;flex:1}

/* 参与步骤 */
.pn-steps{margin-bottom:20px}
.pn-step{display:flex;gap:12px;align-items:flex-start;padding:10px 0;border-bottom:1px solid rgba(255,255,255,.04)}
.pn-step:last-child{border-bottom:none}
.pn-step-num{width:22px;height:22px;border-radius:50%;background:rgba(124,58,237,.15);border:1px solid rgba(124,58,237,.25);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:var(--p);flex-shrink:0;margin-top:1px}
.pn-step-txt{font-size:13px;color:var(--tx2);line-height:1.5}

/* 门槛卡片 */
.pn-thresholds{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:20px}
.pn-th{padding:12px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:12px}
.pn-th-ico{font-size:20px;margin-bottom:6px}
.pn-th-key{font-size:10px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--tx3);margin-bottom:4px}
.pn-th-val{font-size:12px;color:var(--tx);line-height:1.4}

/* meta 行 */
.pr{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid rgba(255,255,255,.04)}
.pr:last-of-type{border-bottom:none}
.pk{font-size:12px;color:var(--tx3)}
.pv{font-size:13px;font-weight:600;color:var(--tx)}

/* 动作按钮区 */
.pn-action{margin-top:20px}
.pn-btn-main{width:100%;padding:14px;background:linear-gradient(135deg,#7c3aed,#6d28d9);color:#fff;border:none;border-radius:14px;font-size:14px;font-weight:700;cursor:pointer;font-family:var(--font);transition:all .2s;box-shadow:0 4px 20px rgba(124,58,237,.3)}
.pn-btn-main:hover{transform:translateY(-1px);box-shadow:0 8px 28px rgba(124,58,237,.4)}
.pn-btn-cancel{width:100%;padding:11px;background:rgba(239,68,68,.06);border:1px solid rgba(239,68,68,.18);border-radius:12px;color:#f87171;font-size:13px;cursor:pointer;font-family:var(--font);margin-top:10px;transition:all .2s}
.pn-btn-cancel:hover{background:rgba(239,68,68,.12)}
.pn-timer{padding:14px;background:rgba(124,58,237,.08);border:1px solid rgba(124,58,237,.18);border-radius:12px;text-align:center;margin-top:16px}
.pn-timer-val{font-size:28px;font-weight:900;color:var(--p);letter-spacing:-1px}
.pn-success{text-align:center;padding:14px;color:var(--gr);font-weight:700;font-size:14px}
.pc{background:transparent;border:none;font-size:13px;color:var(--tx3);cursor:pointer;font-family:var(--font);margin-bottom:24px;padding:0}
.pc:hover{color:var(--tx)}.pn h3{font-size:20px;font-weight:800;margin-bottom:20px;letter-spacing:-.5px}
.pr{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid rgba(255,255,255,.06)}
.pk{font-size:12px;color:var(--tx3)}.pv{font-size:13px;font-weight:600}
/* TOAST */
.tw{position:fixed;bottom:28px;right:28px;z-index:1000;display:flex;flex-direction:column;gap:8px;pointer-events:none}
.toast{padding:12px 18px;background:rgba(18,15,38,.95);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,.12);border-radius:12px;font-size:13px;font-weight:600;box-shadow:0 8px 32px rgba(0,0,0,.5);display:flex;align-items:center;gap:8px;animation:slideIn .3s ease}
@keyframes slideIn{from{transform:translateX(100%);opacity:0}to{transform:translateX(0);opacity:1}}
.sb{background:rgba(167,139,250,.1);border:1px solid rgba(167,139,250,.25);border-radius:10px;padding:12px 16px;font-size:13px;color:var(--p);margin-bottom:16px}
.ldot{display:inline-block;width:7px;height:7px;border-radius:50%;background:#10b981;animation:pulse 1.5s infinite}
@keyframes pulse{0%{box-shadow:0 0 0 0 rgba(16,185,129,.5)}70%{box-shadow:0 0 0 6px rgba(16,185,129,0)}100%{box-shadow:0 0 0 0 rgba(16,185,129,0)}}
.ai-step{margin-bottom:24px}
.ai-loading{display:flex;flex-direction:column;align-items:center;gap:12px;padding:40px;color:var(--tx2);font-size:14px}
.ai-spinner{width:32px;height:32px;border:3px solid var(--bd);border-top-color:var(--p);border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.ai-preview{background:rgba(255,255,255,.05);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:20px}
.ai-preview-head{display:flex;align-items:center;gap:10px;margin-bottom:12px}
.ai-type-badge{padding:4px 10px;background:var(--pl);color:var(--p);border-radius:6px;font-size:11px;font-weight:700}
.ai-reasoning{font-size:12px;color:var(--tx3)}
.ai-preview-title{font-size:16px;font-weight:800;margin-bottom:6px}
.ai-preview-desc{font-size:13px;color:var(--tx2);line-height:1.5;margin-bottom:12px}
.ai-params{display:flex;flex-wrap:wrap;gap:6px}
.ai-param{font-size:11px;padding:4px 10px;background:var(--bg);border:1px solid var(--bd);border-radius:6px;color:var(--tx2)}
.ai-examples{display:flex;flex-wrap:wrap;gap:6px;margin-top:10px}
.ai-ex-label{font-size:11px;color:var(--tx3);width:100%;margin-bottom:2px;font-weight:600;letter-spacing:.5px;text-transform:uppercase}
.ai-ex{padding:7px 12px;font-size:12px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:8px;cursor:pointer;font-family:var(--font);color:var(--tx2);transition:all .2s}
.ai-ex:hover{border-color:var(--p);color:var(--p);background:rgba(167,139,250,.1)}
.dlg-tabs-wrap{padding:0;margin:0 0 32px}
.dlg-tabs{display:flex;border-bottom:1px solid var(--bd)}
.dlg-tab{padding:12px 20px;font-size:14px;font-weight:500;color:var(--tx2);background:transparent;border:none;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;font-family:var(--font);transition:all .2s}
.dlg-tab:hover{color:var(--tx)}.dlg-tab.on{color:var(--p);font-weight:700;border-bottom-color:var(--p)}
.dlg-cap-item{display:flex;align-items:flex-start;gap:16px;padding:16px;background:rgba(255,255,255,.03);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.08);border-radius:12px;transition:all .2s}
.dlg-cap-item:hover{border-color:var(--p);background:rgba(167,139,250,.08)}
.dlg-cap-n{font-size:28px;font-weight:900;color:var(--p);letter-spacing:-1px;line-height:1;min-width:36px}
.dlg-cap-t{font-size:13px;font-weight:700;margin-bottom:3px}.dlg-cap-d{font-size:12px;color:var(--tx2);line-height:1.5}
.lh-upload{border:2px dashed rgba(255,255,255,.15);border-radius:12px;padding:20px;text-align:center;cursor:pointer;transition:all .2s;background:rgba(255,255,255,.04);min-height:88px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px}
.lh-upload:hover{border-color:var(--p);background:rgba(167,139,250,.08)}.lh-upload.has-img{border-style:solid;border-color:var(--p)}
#lh-upload-icon{font-size:20px}#lh-upload-tip{font-size:12px;color:var(--tx3);line-height:1.4}
.lh-preview-wrap{margin-bottom:20px;display:flex;justify-content:center}
.lh-preview{background:rgba(167,139,250,.08);backdrop-filter:blur(8px);border:1px solid rgba(167,139,250,.2);border-radius:16px;padding:20px 28px;text-align:center;min-width:180px}
.lh-preview-img{width:56px;height:56px;border-radius:50%;background:var(--bd2);margin:0 auto 10px;display:flex;align-items:center;justify-content:center;font-size:24px;background-size:cover;background-position:center}
.lh-preview-name{font-size:15px;font-weight:800}.lh-preview-sym{font-size:12px;color:var(--p);font-weight:700;margin-top:2px}
.lh-tax-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-top:6px}
.lh-tax-opt{display:flex;align-items:center;justify-content:center;padding:9px 4px;border:1px solid rgba(255,255,255,.12);border-radius:8px;cursor:pointer;font-size:12px;font-weight:600;color:var(--tx2);transition:all .2s}
.lh-tax-opt input{display:none}.lh-tax-opt:has(input:checked){border-color:var(--p);background:rgba(167,139,250,.15);color:var(--p)}
.lh-tax-rec{position:relative}.lh-tax-rec::after{content:'推荐';position:absolute;top:-7px;right:-4px;background:var(--tx);color:#fff;font-size:9px;padding:1px 4px;border-radius:4px}
.lh-type-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:6px}
.lh-type-opt{cursor:pointer;border:1px solid rgba(255,255,255,.1);border-radius:12px;transition:all .2s}
.lh-type-opt input{display:none}.lh-type-opt:has(input:checked){border-color:var(--p);background:rgba(167,139,250,.1)}
.lh-type-body{padding:14px;text-align:center}.lh-type-ico{font-size:22px;margin-bottom:4px}
.lh-type-name{font-size:13px;font-weight:700}.lh-type-desc{font-size:11px;color:var(--tx3);margin-top:2px}
.lh-budget-tip{background:rgba(52,211,153,.08);border:1px solid rgba(52,211,153,.2);border-radius:8px;padding:10px 14px;font-size:12px;color:var(--gr);margin-top:12px}
.lh-progress{position:fixed;inset:0;background:rgba(10,8,20,.85);backdrop-filter:blur(16px);display:flex;align-items:center;justify-content:center;z-index:200}
.lh-progress-inner{text-align:center;display:flex;flex-direction:column;align-items:center;padding:40px}
.lh-result{position:fixed;inset:0;background:rgba(10,8,20,.9);backdrop-filter:blur(20px);display:flex;align-items:center;justify-content:center;z-index:200}
.lh-result-inner{text-align:center;max-width:480px;padding:40px;background:rgba(18,14,38,.96);backdrop-filter:blur(24px);border:1px solid rgba(167,139,250,.2);border-radius:24px;box-shadow:0 8px 48px rgba(124,58,237,.35)}
.lh-result-title{font-size:28px;font-weight:900;letter-spacing:-1px;margin-bottom:8px}
.lh-result-addr{font-family:monospace;font-size:12px;color:var(--p);background:var(--pl);padding:8px 12px;border-radius:8px;word-break:break-all}
.dash-log-panel{background:rgba(255,255,255,.03);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.08);border-radius:16px;overflow:hidden}
.dash-log-head{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid rgba(255,255,255,.07)}
.dash-log-title{font-size:14px;font-weight:700;display:flex;align-items:center;gap:8px}
.dash-log-count{font-size:12px;color:var(--tx3)}
.dash-log-body{min-height:280px;max-height:520px;overflow-y:auto}
.dash-log-body .le{border-bottom:1px solid rgba(255,255,255,.04);transition:background .15s}
.dash-log-body .le:hover{background:rgba(255,255,255,.04)}.dash-log-body .le:last-child{border-bottom:none}
.erc-states{display:flex;align-items:center;flex-wrap:wrap;margin:32px 0}
.erc-state{text-align:center;flex:1;min-width:100px}.erc-s-dot{width:16px;height:16px;border-radius:50%;margin:0 auto 8px}
.erc-s-name{font-size:13px;font-weight:800;margin-bottom:4px}.erc-s-desc{font-size:11px;color:var(--tx3);line-height:1.4}
.s-open .erc-s-dot{background:#94a3b8}.s-funded .erc-s-dot{background:#3b82f6}
.s-submitted .erc-s-dot{background:#f59e0b}.s-completed .erc-s-dot{background:var(--gr)}
.erc-arrow{font-size:18px;color:rgba(167,139,250,.35);padding:0 4px;flex-shrink:0}
.erc-exits{display:flex;gap:12px;margin-bottom:32px;flex-wrap:wrap}
.erc-exit{flex:1;min-width:240px;padding:12px 16px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:10px;font-size:12px;color:var(--tx2);line-height:1.5}
.erc-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:32px}
.erc-card{background:rgba(255,255,255,.04);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.08);border-radius:14px;padding:20px}
.erc-card-ico{font-size:24px;margin-bottom:10px}.erc-card-title{font-size:14px;font-weight:800;margin-bottom:6px}
.erc-card-desc{font-size:12px;color:var(--tx2);line-height:1.6}
.erc-contracts{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:12px;padding:20px}
.erc-ct-label{font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--tx3);margin-bottom:14px}
.erc-ct-row{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--bd)}
.erc-ct-row:last-child{border-bottom:none}
.erc-ct-name{font-size:12px;font-weight:700;min-width:180px}
.erc-ct-addr{font-family:monospace;font-size:11px;color:var(--tx3);flex:1;overflow:hidden;text-overflow:ellipsis}
.erc-ct-link{font-size:11px;font-weight:700;color:var(--p);text-decoration:none;white-space:nowrap}
.erc-ct-link:hover{text-decoration:underline}
.hs-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin:32px 0}
.hs-item{padding:20px;background:rgba(255,255,255,.03);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.08);border-radius:14px}
.hs-num{font-size:36px;font-weight:900;color:var(--bd2);letter-spacing:-2px;margin-bottom:8px}
.hs-title{font-size:14px;font-weight:800;margin-bottom:6px}.hs-desc{font-size:12px;color:var(--tx2);line-height:1.6}
.hs-modes{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin:32px 0}
.hs-mode{padding:24px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:14px}
.hs-mode-title{font-size:15px;font-weight:800;margin-bottom:8px}.hs-mode-desc{font-size:12px;color:var(--tx2);line-height:1.6}
.dc{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin:24px 0}
.dcard{padding:20px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:14px;text-align:center}
.dci{font-size:28px;margin-bottom:10px}.dcard h3{font-size:14px;font-weight:700;margin-bottom:6px}
.dcard p{font-size:12px;color:var(--tx2);line-height:1.5}
.ms{margin-bottom:32px}
.mst{font-size:12px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--p);margin-bottom:16px}
.dh{max-width:680px;margin:0 auto;padding:80px 28px 40px;text-align:center}
.dh h2{font-size:clamp(28px,4vw,48px);font-weight:900;letter-spacing:-1.5px;margin-bottom:12px}
.dh p{font-size:15px;color:var(--tx2)}
.gd{color:var(--p)}
.how-stat{max-width:900px;margin:0 auto;padding:0 28px}
@media(max-width:768px){
 .grid2,.grid3,.erc-cards,.hs-grid,.hs-modes,.fr2,.dc{grid-template-columns:1fr}
 .display{font-size:48px;letter-spacing:-2px}.headline{font-size:32px}
 .pn{width:100vw}
 #page-home > div:first-child{grid-template-columns:1fr}
 #page-launch > div:first-child{grid-template-columns:1fr}
 .dlg-cap-item:nth-child(n+3){display:none}
}

.agent-card{background:rgba(255,255,255,.04);backdrop-filter:blur(12px);border:1.5px solid rgba(255,255,255,.09);border-radius:20px;padding:24px;cursor:pointer;transition:all .25s;position:relative}
.agent-card:hover{border-color:rgba(255,255,255,.2);transform:translateY(-3px);box-shadow:0 8px 40px rgba(0,0,0,.25)}
.agent-card.selected{border-color:var(--p);box-shadow:0 0 0 1px var(--p),0 8px 40px rgba(124,58,237,.25)}
.ac-head{display:flex;align-items:center;gap:14px;margin-bottom:14px}
.ac-avatar{width:48px;height:48px;border-radius:12px;display:grid;place-items:center;font-size:20px;flex-shrink:0}
.ac-name{font-size:16px;font-weight:900;letter-spacing:-.3px;margin-bottom:4px}
.ac-tag{display:inline-block;font-size:10px;font-weight:700;letter-spacing:.5px;padding:2px 8px;border-radius:6px;border:1px solid}
.ac-desc{font-size:12px;color:var(--tx2);line-height:1.7;margin-bottom:14px}
.ac-traits{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px}
.ac-trait{font-size:11px;padding:3px 9px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:20px;color:var(--tx2)}
.ac-preview-title{font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--p);margin-bottom:10px}
.ac-samples{display:flex;flex-direction:column;gap:8px}
.ac-sample{background:rgba(0,0,0,.2);border:1px solid rgba(255,255,255,.07);border-radius:12px;padding:12px}
.ac-s-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px}
.ac-s-badge{font-size:10px;font-weight:700;padding:2px 8px;border-radius:6px}
.ac-s-time{font-size:10px;color:var(--tx3)}
.ac-s-title{font-size:13px;font-weight:800;margin-bottom:4px;line-height:1.4}
.ac-s-body{font-size:11px;color:var(--tx3);line-height:1.5;margin-bottom:6px;font-style:italic}
.ac-s-reward{font-size:12px;font-weight:700;color:var(--p)}
.ac-select-btn{margin-top:16px;width:100%;padding:10px;text-align:center;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:10px;font-size:13px;font-weight:700;color:var(--tx2);transition:all .2s}
.agent-card:hover .ac-select-btn{background:rgba(167,139,250,.12);border-color:var(--p);color:var(--p)}
.agent-card.selected .ac-select-btn{background:linear-gradient(135deg,#7c3aed,#6d28d9);border-color:transparent;color:#fff}


/* ── 任务大厅 v2 全宽列表 ── */
.hall2-wrap{border-top:1px solid rgba(255,255,255,.06);max-width:1100px;margin:0 auto;padding:0 28px 100px}
.hall2-bar{display:flex;align-items:center;gap:16px;padding:32px 0 24px;flex-wrap:wrap;border-bottom:1px solid rgba(255,255,255,.05);margin-bottom:0}
.hall2-bar-left{display:flex;align-items:center;gap:16px;flex:1;min-width:0}
.hall2-live{display:flex;align-items:center;gap:6px;font-size:10px;font-weight:800;letter-spacing:2px;color:rgba(124,58,237,.8);flex-shrink:0}
.hall2-dot{width:6px;height:6px;border-radius:50%;background:#7c3aed;box-shadow:0 0 8px rgba(124,58,237,.9);animation:pulse 2s infinite;flex-shrink:0}
.hall2-title{font-size:22px;font-weight:900;letter-spacing:-1px;color:var(--tx);white-space:nowrap}
.hall2-filters{display:flex;gap:4px;flex-wrap:wrap}
.hf2{padding:6px 14px;background:transparent;border:1px solid rgba(255,255,255,.08);border-radius:20px;color:var(--tx3);font-size:12px;font-weight:600;cursor:pointer;font-family:var(--font);transition:all .18s}
.hf2:hover{color:var(--tx);border-color:rgba(255,255,255,.2)}
.hf2.on{color:#c4b5fd;background:rgba(124,58,237,.1);border-color:rgba(124,58,237,.3)}
.hall2-bar-right{display:flex;align-items:center;gap:12px;flex-shrink:0}
.hall2-count{font-size:11px;color:var(--tx3)}
.hall2-post{padding:7px 16px;background:rgba(124,58,237,.12);border:1px solid rgba(124,58,237,.25);border-radius:20px;color:var(--p);font-size:12px;font-weight:700;cursor:pointer;font-family:var(--font);transition:all .2s}
.hall2-post:hover{background:rgba(124,58,237,.2)}
.hall2-list{display:flex;flex-direction:column}
.tc{background:transparent;border:none;border-bottom:1px solid rgba(255,255,255,.05);border-radius:0;padding:24px 0;cursor:pointer;transition:background .15s;position:relative;display:grid;grid-template-columns:36px 1fr auto;gap:20px;align-items:center}
.tc::after{content:'';position:absolute;left:-28px;right:-28px;top:0;bottom:0;background:rgba(124,58,237,.03);border-left:2px solid rgba(124,58,237,.4);opacity:0;transition:opacity .15s;pointer-events:none}
.tc:hover::after{opacity:1}
.tc:hover .tc-num{color:#c4b5fd}
.tc.full{opacity:.35}
.tc-num{font-size:11px;font-weight:800;color:rgba(255,255,255,.12);font-family:monospace;text-align:right;transition:color .15s;flex-shrink:0}
.tc-body{min-width:0}
.tch{display:flex;align-items:center;gap:6px;margin-bottom:6px}
.cti{font-size:15px;font-weight:800;color:var(--tx);letter-spacing:-.4px;line-height:1.3}
.ctk{display:none}.cde{font-size:12px;color:var(--tx3);margin-top:4px;line-height:1.5;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden}.crl{display:none}.cbr{display:none}.cft{display:none}
.tc-meta{display:flex;flex-direction:column;align-items:flex-end;gap:3px;flex-shrink:0;min-width:90px}
.crw{font-size:17px;font-weight:900;background:linear-gradient(135deg,#a78bfa,#60a5fa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:-.5px}
.tc-remain{font-size:10px;color:var(--tx3)}.tc-dl{font-size:10px;color:var(--tx3)}
.cbg{font-size:10px;font-weight:700;letter-spacing:.3px;padding:3px 8px;border-radius:6px;background:rgba(124,58,237,.1);color:rgba(167,139,250,.8);border:1px solid rgba(124,58,237,.12)}
.cbg.ag{background:rgba(96,165,250,.08);color:rgba(96,165,250,.8);border-color:rgba(96,165,250,.12)}
.cs{font-size:10px;font-weight:700;padding:3px 8px;border-radius:6px}
.cs.go{background:rgba(5,150,105,.1);color:#34d399;border:1px solid rgba(5,150,105,.12)}
.cs.no{background:rgba(239,68,68,.06);color:#f87171;border:1px solid rgba(239,68,68,.1)}
.cb{display:none}
@media(max-width:768px){.hall-wrap{grid-template-columns:1fr}.hall-sidebar{display:none}.hall-feed{padding:20px 20px 80px}.tc{grid-template-columns:1fr auto}.tc-num{display:none}}


/* ── Hero ── */
.hero-root{position:relative;min-height:calc(100vh - 64px);display:flex;align-items:center;overflow:hidden;padding:0 28px}
.hero-bg-orb{position:absolute;border-radius:50%;pointer-events:none;will-change:transform}
.orb1{width:600px;height:600px;background:radial-gradient(circle,rgba(124,58,237,.18) 0%,transparent 70%);top:-100px;left:-100px}
.orb2{width:500px;height:500px;background:radial-gradient(circle,rgba(59,130,246,.12) 0%,transparent 70%);bottom:-80px;right:-80px}
.hero-bg-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(167,139,250,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(167,139,250,.04) 1px,transparent 1px);background-size:48px 48px;mask-image:radial-gradient(ellipse 100% 100% at 50% 50%,black 30%,transparent 85%);pointer-events:none}
.hero-inner{position:relative;z-index:1;max-width:1100px;margin:0 auto;width:100%;display:grid;grid-template-columns:1fr 400px;gap:80px;align-items:center;padding:80px 0}

/* 左侧 */
.hero-left{display:flex;flex-direction:column;gap:0}
.hero-badge{display:inline-flex;align-items:center;gap:12px;margin-bottom:36px;padding:8px 16px 8px 8px;background:rgba(124,58,237,.07);border:1px solid rgba(124,58,237,.18);border-radius:100px;width:fit-content}
.hero-badge-avatar{position:relative;width:36px;height:36px;flex-shrink:0}
.hero-badge-avatar img{width:100%;height:100%;border-radius:50%;object-fit:cover;border:1.5px solid rgba(167,139,250,.4)}
.hero-badge-dot{position:absolute;bottom:0;right:0;width:10px;height:10px;border-radius:50%;background:#22c55e;border:2px solid var(--bg);box-shadow:0 0 6px rgba(34,197,94,.6)}
.hero-badge-text{display:flex;flex-direction:column;line-height:1.2}
.hero-badge-name{font-size:13px;font-weight:800;color:var(--tx)}
.hero-badge-role{font-size:10px;color:var(--tx3);letter-spacing:.5px}
.hero-h1{margin:0 0 24px;line-height:1.05;letter-spacing:-3px}
.hero-h1-line1{display:block;font-size:clamp(48px,6.5vw,88px);font-weight:200;letter-spacing:-4px;background:linear-gradient(135deg,#fff 0%,#e2e0ff 40%,#a5b4fc 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.hero-h1 em{font-style:normal;background:linear-gradient(90deg,#c084fc,#60a5fa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.hero-h1-line2{display:block;font-size:clamp(52px,7vw,96px);font-weight:200;letter-spacing:-4px;background:linear-gradient(135deg,#a78bfa 0%,#60a5fa 60%,#34d399 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.hero-h1-line2 em{font-style:normal;background:linear-gradient(135deg,#a78bfa 0%,#60a5fa 50%,#a78bfa 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-size:200%;animation:shimmer 4s linear infinite}
@keyframes shimmer{0%{background-position:0% 50%}100%{background-position:200% 50%}}
.hero-sub{font-size:15px;color:var(--tx3);line-height:1.8;margin:0 0 40px;max-width:400px}
.hero-cta{display:flex;gap:14px;align-items:center;flex-wrap:wrap}
.hero-btn-primary{display:inline-flex;align-items:center;gap:10px;padding:15px 32px;background:linear-gradient(135deg,#9333ea,#6d28d9,#4f46e5);color:#fff;border:none;border-radius:14px;font-size:15px;font-weight:700;cursor:pointer;font-family:var(--font);box-shadow:0 4px 28px rgba(139,92,246,.45),0 0 0 1px rgba(167,139,250,.2);transition:all .25s cubic-bezier(.23,1,.32,1);position:relative;overflow:hidden}
.hero-btn-primary:hover{transform:translateY(-2px) scale(1.02);box-shadow:0 12px 44px rgba(139,92,246,.6),0 0 0 1px rgba(167,139,250,.35)}
.hero-btn-secondary{padding:14px 24px;background:transparent;border:1px solid rgba(255,255,255,.12);color:var(--tx2);border-radius:14px;font-size:15px;font-weight:600;cursor:pointer;font-family:var(--font);transition:all .2s}
.hero-btn-secondary:hover{border-color:rgba(255,255,255,.3);color:var(--tx)}

/* 右侧面板 */
.hero-right{display:flex;justify-content:center}
.hero-panel{background:rgba(12,12,28,.7);backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,.08);border-radius:28px;padding:32px;display:flex;flex-direction:column;align-items:center;gap:24px;position:relative;overflow:hidden;width:100%;max-width:340px}
.hero-panel::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(124,58,237,.6),rgba(96,165,250,.4),transparent)}
.hero-panel-avatar{position:relative;width:120px;height:120px}
.hero-panel-avatar img{width:100%;height:100%;border-radius:50%;object-fit:cover;border:2px solid rgba(167,139,250,.3);box-shadow:0 0 40px rgba(124,58,237,.3)}
.hero-panel-halo{position:absolute;inset:-8px;border-radius:50%;background:conic-gradient(from 0deg,rgba(124,58,237,.4),rgba(96,165,250,.2),rgba(124,58,237,.4));animation:spin 6s linear infinite;z-index:-1;filter:blur(4px)}
@keyframes spin{to{transform:rotate(360deg)}}
.hero-panel-stats{display:flex;align-items:center;gap:0;width:100%;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:14px;overflow:hidden}
.hero-stat{flex:1;padding:14px 12px;text-align:center}
.hero-stat-div{width:1px;height:40px;background:rgba(255,255,255,.07)}
.hero-stat-val{font-size:24px;font-weight:900;letter-spacing:-1px;color:var(--tx);line-height:1}
.hero-stat-key{font-size:10px;color:var(--tx3);margin-top:4px;letter-spacing:.5px}
.hero-panel-footer{display:flex;gap:8px;flex-wrap:wrap;justify-content:center}
.hero-panel-tag{padding:4px 10px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:20px;font-size:10px;font-weight:700;color:var(--tx3);letter-spacing:.5px}

@media(max-width:768px){
 .hero-inner{grid-template-columns:1fr;gap:40px;padding:60px 0 40px}
 .hero-right{display:none}
 .hero-h1-line1,.hero-h1-line2{font-size:52px}
}


/* ── Agent 日志页 ── */
.agd-wrap{max-width:1100px;margin:0 auto;padding:32px 28px 80px}
.agd-header{display:flex;align-items:flex-start;justify-content:space-between;gap:20px;margin-bottom:40px;flex-wrap:wrap}
.agd-label{font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--p);margin-bottom:10px}
.agd-title{font-size:36px;font-weight:900;letter-spacing:-1.5px;color:var(--tx);margin-bottom:8px}
.agd-accent{background:linear-gradient(135deg,#a78bfa,#60a5fa);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.agd-sub{font-size:13px;color:var(--tx3);line-height:1.6;max-width:500px}
.agd-status{display:flex;align-items:center;gap:8px;padding:8px 16px;background:rgba(34,197,94,.06);border:1px solid rgba(34,197,94,.15);border-radius:20px;font-size:12px;font-weight:700;color:var(--gr);flex-shrink:0;height:fit-content}

/* 指标 */
.agd-metrics{display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr;gap:12px;margin-bottom:32px}
.agd-metric{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:20px 20px 18px;position:relative;overflow:hidden}
.agd-metric-main{background:rgba(124,58,237,.06);border-color:rgba(124,58,237,.2)}
.agd-metric-main::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 0% 0%,rgba(124,58,237,.15) 0%,transparent 60%);pointer-events:none}
.agd-metric-icon{font-size:20px;margin-bottom:10px}
.agd-metric-val{font-size:26px;font-weight:900;letter-spacing:-1px;color:var(--tx);line-height:1;margin-bottom:4px}
.agd-metric-main .agd-metric-val{background:linear-gradient(135deg,#a78bfa,#60a5fa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;font-size:28px}
.agd-metric-key{font-size:11px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--tx3)}
.agd-metric-sub{font-size:10px;color:var(--tx3);margin-top:2px;opacity:.7}

/* 税金流转 */
.agd-flow{display:flex;align-items:center;gap:0;margin-bottom:32px;background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.06);border-radius:16px;padding:20px 24px;overflow-x:auto}
.agd-flow-node{flex:1;min-width:100px;text-align:center;padding:0 8px}
.agd-flow-active{position:relative}
.agd-flow-active::before{content:'';position:absolute;inset:-4px;border-radius:12px;border:1px solid rgba(124,58,237,.3);background:rgba(124,58,237,.05)}
.agd-flow-ico{font-size:24px;margin-bottom:6px}
.agd-flow-name{font-size:12px;font-weight:700;color:var(--tx);margin-bottom:2px}
.agd-flow-desc{font-size:10px;color:var(--tx3)}
.agd-flow-arrow{font-size:18px;color:rgba(124,58,237,.4);padding:0 4px;flex-shrink:0;padding-bottom:16px}

/* 日志面板 */
.agd-log{background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.07);border-radius:16px;overflow:hidden}
.agd-log-head{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid rgba(255,255,255,.06)}
.agd-log-title{display:flex;align-items:center;gap:8px;font-size:13px;font-weight:700;color:var(--tx)}
.agd-log-count{font-size:11px;color:var(--tx3)}
.agd-log-body{max-height:400px;overflow-y:auto}
.agd-log-empty{padding:48px;text-align:center;color:var(--tx3);font-size:13px}

@media(max-width:768px){
 .agd-metrics{grid-template-columns:1fr 1fr}
 .agd-metric-main{grid-column:1/-1}
 .agd-flow{flex-wrap:wrap;justify-content:center}
 .agd-flow-arrow{transform:rotate(90deg)}
}


/* ── 策略描述框 ── */
.strat-box{background:rgba(124,58,237,.05);border:1px solid rgba(124,58,237,.2);border-radius:16px;padding:20px;margin-bottom:28px;position:relative;overflow:hidden}
.strat-box::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(124,58,237,.5),transparent)}
.strat-header{display:flex;align-items:flex-start;gap:12px;margin-bottom:14px}
.strat-icon{font-size:20px;flex-shrink:0;margin-top:1px}
.strat-title{font-size:14px;font-weight:700;color:var(--tx);margin-bottom:3px}
.strat-sub{font-size:12px;color:var(--tx3)}
.strat-input{width:100%;background:rgba(0,0,0,.3);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:12px 14px;color:var(--tx);font-size:13px;line-height:1.6;font-family:var(--font);resize:none;box-sizing:border-box;transition:border-color .2s}
.strat-input:focus{outline:none;border-color:rgba(124,58,237,.4)}
.strat-input::placeholder{color:var(--tx3)}
.strat-examples{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px}
.strat-tag{padding:5px 12px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:20px;font-size:11px;color:var(--tx3);cursor:pointer;transition:all .18s}
.strat-tag:hover{background:rgba(124,58,237,.1);border-color:rgba(124,58,237,.3);color:var(--p)}


/* ── 手动/自动模式切换 ── */
.mode-tabs{display:flex;gap:4px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:12px;padding:4px;margin-bottom:12px}
.mode-tab{flex:1;padding:8px 12px;border:none;border-radius:9px;font-size:12px;font-weight:600;cursor:pointer;font-family:var(--font);color:var(--tx3);background:transparent;transition:all .2s}
.mode-tab.on{background:rgba(124,58,237,.2);color:#c4b5fd;box-shadow:0 2px 8px rgba(124,58,237,.2)}
.mode-desc{font-size:11px;color:var(--tx3);line-height:1.5;padding:0 2px}



.hero-sponsor-label{font-size:11px;font-weight:700;letter-spacing:.5px;color:var(--tx3)}
.hero-sponsor-addr{font-size:12px;font-family:monospace;color:var(--p);cursor:pointer;transition:color .2s}
.hero-sponsor-addr:hover{color:#e9d5ff}

@keyframes tickerScroll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
/* AGENT_CSS_INSERTED */
