 <div style="min-width:36px;height:36px;background:rgba(124,58,237,.12);border:1px solid rgba(124,58,237,.25);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:900;color:var(--p)">4</div>
