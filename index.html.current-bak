<div id="okx-wallet-banner" style="display:none;align-items:center;justify-content:space-between;padding:10px 24px;background:linear-gradient(90deg,rgba(99,58,237,.15),rgba(59,130,246,.1));border-bottom:1px solid rgba(99,58,237,.3);gap:12px;flex-wrap:wrap">
  <div style="display:flex;align-items:center;gap:10px">
    <div style="width:28px;height:28px;background:linear-gradient(135deg,#6332ed,#3b82f6);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:900;color:#fff;flex-shrink:0">X</div>
    <div>
      <div style="font-size:12px;font-weight:800;color:var(--tx)">当前链：BSC · 建议使用 BSC Web3 钱包</div>
      <div style="font-size:11px;color:var(--tx3)">连接钱包，体验更流畅</div>
    </div>
  </div>
  <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
    
    <a href="https://www.okx.com/web3" target="_blank" style="padding:6px 14px;background:rgba(99,58,237,.8);border-radius:8px;color:#fff;font-size:12px;font-weight:700;text-decoration:none;white-space:nowrap">下载钱包 ↗</a>
    <button onclick="document.getElementById('okx-wallet-banner').style.display='none'" style="padding:6px 10px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.1);border-radius:8px;color:var(--tx3);font-size:12px;cursor:pointer">×</button>
  </div>
</div>

<div id="page-home" class="pw active" style="display:block">
<div style="min-height:100vh;background:radial-gradient(ellipse 160% 140% at 90% 115%,#5b2fd4 0%,#3d1fa0 12%,#2a1468 28%,#100930 55%,#060310 100%);position:relative;overflow:hidden">

 <!-- ── HERO ── -->
 <div style="display:flex;align-items:center;min-height:100vh;padding:0 60px;gap:60px;max-width:1200px;margin:0 auto;box-sizing:border-box">

  <!-- 左 -->
  <div style="flex:0 0 auto;padding-top:20px">

   <!-- badge -->
   <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:20px;padding:4px 12px;margin-bottom:24px">
    <img src="/seki-avatar.jpg" style="width:18px;height:18px;border-radius:50%;object-fit:cover">
    <span style="font-size:11px;font-weight:600;color:rgba(255,255,255,.85)">Seki</span>
    <span style="font-size:9px;color:rgba(255,255,255,.3);letter-spacing:1px;font-weight:400">MEME · ON-CHAIN AI AGENT</span>
   </div>

   <!-- 主标题 -->
   <div style="margin:0 0 14px">
    <div style="font-size:clamp(72px,7.5vw,100px);font-weight:800;color:#fff;line-height:1.02;letter-spacing:-4px;font-family:inherit">链上激励</div>
    <div style="font-size:clamp(72px,7.5vw,100px);font-weight:800;color:#fff;line-height:1.02;letter-spacing:-4px;font-family:inherit">由 <span style="background:linear-gradient(90deg,#a78bfa,#818cf8);-webkit-background-clip:text;-webkit-text-fill-color:transparent">Seki</span> 驱动</div>
   </div>

   <!-- 副标题 -->
   <p style="font-size:13px;color:rgba(255,255,255,.45);line-height:1.8;margin:0 0 26px;letter-spacing:.1px">自主感知链上数据，结合市场信号<br>智能决策并自动结算激励任务</p>

   <!-- CTA -->
   <div style="display:flex;align-items:center;gap:0;margin-bottom:32px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);border-radius:8px;overflow:hidden;width:fit-content">
    <button onclick="G('launch',document.querySelectorAll('.nl')[3])" style="padding:9px 20px;background:transparent;border:none;border-right:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.9);font-size:13px;font-weight:500;cursor:pointer;font-family:inherit;white-space:nowrap">一键发币 →</button>
    <button onclick="G('how',document.querySelectorAll('.nl')[0])" style="padding:9px 18px;background:transparent;border:none;color:rgba(255,255,255,.5);font-size:13px;cursor:pointer;font-family:inherit;white-space:nowrap">了解协议</button>
   </div>

   <!-- 统计 -->
   <div style="display:flex;gap:10px">
    <div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:10px;padding:12px 16px;min-width:78px">
     <div style="font-size:9px;color:rgba(255,255,255,.3);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:4px">Tasks</div>
     <div style="font-size:20px;font-weight:300;color:#fff;line-height:1" id="hero-tasks">—</div>
     <div style="font-size:9px;color:rgba(255,255,255,.2);margin-top:3px">链上任务</div>
    </div>
    <div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:10px;padding:12px 16px;min-width:78px">
     <div style="font-size:9px;color:rgba(255,255,255,.3);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:4px">Holders</div>
     <div style="font-size:20px;font-weight:300;color:#fff;line-height:1" id="hero-holders">847</div>
     <div style="font-size:9px;color:rgba(255,255,255,.2);margin-top:3px">活跃持币人</div>
    </div>
    <div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:10px;padding:12px 16px;min-width:78px">
     <div style="font-size:9px;color:rgba(255,255,255,.3);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:4px">● Live</div>
     <div style="font-size:20px;font-weight:300;color:#fff;line-height:1">3<span style="font-size:10px;color:rgba(255,255,255,.35)">min</span></div>
     <div style="font-size:9px;color:rgba(255,255,255,.2);margin-top:3px">扫描间隔</div>
    </div>
   </div>


  </div>

  <!-- 右: 市场面板 -->
  <div style="flex:1;max-width:460px">

