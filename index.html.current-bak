     <span style="color:var(--p);font-weight:700">Decision</span>
     <span>→ 决策传递 →</span>
     <span style="color:#34d399;font-weight:700">Executor</span>
     <span>→ 链上支付 →</span>
     <span style="color:#f59e0b;font-weight:700">任务上链</span>
   </div>
 </div>
 <!-- Personal Agent 状态 -->
 <div style="background:rgba(52,211,153,.04);border:1px solid rgba(52,211,153,.15);border-radius:16px;padding:18px;margin-bottom:16px">
   <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px">
     <div style="font-size:14px">🤖</div>
     <div style="font-size:12px;font-weight:800;color:var(--tx)">Personal Agent</div>
     <div style="font-size:9px;font-weight:700;letter-spacing:1px;padding:2px 7px;border-radius:5px;background:rgba(52,211,153,.12);border:1px solid rgba(52,211,153,.3);color:#34d399;text-transform:uppercase;margin-left:auto">前端执行层</div>
   </div>
   <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:10px">
     <div style="background:rgba(255,255,255,.03);border-radius:10px;padding:10px;text-align:center">
       <div style="font-size:11px;color:var(--tx3);margin-bottom:4px">执行模式</div>
       <div id="pa-dash-mode" style="font-size:13px;font-weight:800;color:#34d399">Web Worker</div>
     </div>
     <div style="background:rgba(255,255,255,.03);border-radius:10px;padding:10px;text-align:center">
       <div style="font-size:11px;color:var(--tx3);margin-bottom:4px">今日完成</div>
       <div id="pa-dash-count" style="font-size:13px;font-weight:800;color:var(--p)">—</div>
     </div>
     <div style="background:rgba(255,255,255,.03);border-radius:10px;padding:10px;text-align:center">
