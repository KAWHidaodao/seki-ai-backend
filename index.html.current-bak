              <div style="width:44px;height:44px;border-radius:12px;background:rgba(245,158,11,.2);border:1px solid rgba(245,158,11,.4);margin:0 auto 10px;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:900;color:#f59e0b">R</div>
              <div style="font-size:12px;font-weight:800;margin-bottom:4px">REFUND</div>
              <div style="font-size:10px;color:var(--tx3);line-height:1.6">自动退款<br>过期任务<br>链上核销</div>
            </div>
          </div>
          <div style="margin-top:16px;padding:12px 16px;background:rgba(52,211,153,.04);border-radius:10px;font-size:11px;color:var(--tx3);text-align:center">每 3 分钟执行一次 · BSC · 资金始终在合约中，Agent 无法动用</div>
        </div>
      </div>

      <!-- 合约 ABI 关键接口 -->
      <div style="margin-bottom:48px">
        <div style="font-size:11px;font-weight:700;letter-spacing:1.5px;color:#34d399;margin-bottom:16px">◆ &nbsp;核心合约接口</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
          <div style="background:#0d0d1a;border:1px solid rgba(255,255,255,.08);border-radius:14px;padding:20px">
            <div style="font-size:11px;font-weight:700;color:var(--p);margin-bottom:12px">MemeBountyV5</div>
            <div style="font-family:monospace;font-size:11px;line-height:2;color:var(--tx2)">
              <div style="color:#60a5fa">createTask(</div>
              <div style="padding-left:16px;color:var(--tx3)">address token,</div>
              <div style="padding-left:16px;color:var(--tx3)">uint8 taskType,</div>
              <div style="padding-left:16px;color:var(--tx3)">uint256 rewardPerWinner,</div>
              <div style="padding-left:16px;color:var(--tx3)">uint256 maxWinners,</div>
              <div style="padding-left:16px;color:var(--tx3)">uint256 deadline</div>
              <div style="color:#60a5fa">)</div>
              <div style="margin-top:8px;color:#60a5fa">claimHold(uint256 id)</div>
              <div style="color:#60a5fa">claimBuy(uint256 id)</div>
              <div style="color:#60a5fa">claimFree(uint256 id)</div>
              <div style="color:#60a5fa">cancelTask(uint256 id)</div>
            </div>
          </div>
          <div style="background:#0d0d1a;border:1px solid rgba(255,255,255,.08);border-radius:14px;padding:20px">
            <div style="font-size:11px;font-weight:700;color:#a78bfa;margin-bottom:12px">AgentRegistry</div>
            <div style="font-family:monospace;font-size:11px;line-height:2;color:var(--tx2)">
              <div style="color:#a78bfa">createJob(</div>
              <div style="padding-left:16px;color:var(--tx3)">address token,</div>
              <div style="padding-left:16px;color:var(--tx3)">uint8 agentType,</div>
              <div style="padding-left:16px;color:var(--tx3)">uint256 durationHours</div>
              <div style="color:#a78bfa">)</div>
              <div style="margin-top:8px;color:#a78bfa">setBudget(uint256 jobId)</div>
              <div style="color:#a78bfa">fundJob(uint256 jobId)</div>
              <div style="color:#a78bfa">cancelJob(uint256 jobId)</div>
              <div style="color:#a78bfa">claimRefund(uint256 jobId)</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Personal Agent API -->
      <div style="margin-bottom:48px">
        <div style="font-size:11px;font-weight:700;letter-spacing:1.5px;color:#34d399;margin-bottom:16px">◆ &nbsp;PERSONAL AGENT API</div>
        <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:16px;padding:28px">

          <!-- /api/chat -->
          <div style="margin-bottom:24px">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px">
              <span style="font-size:10px;font-weight:800;padding:2px 8px;border-radius:5px;background:rgba(52,211,153,.12);border:1px solid rgba(52,211,153,.3);color:#34d399">POST</span>
              <span style="font-family:monospace;font-size:13px;color:var(--tx)">/api/chat</span>
              <span style="font-size:10px;color:var(--tx3)">AI 对话 · 策略解析</span>
            </div>
            <div style="background:rgba(13,13,26,.8);border-radius:10px;padding:14px;font-family:monospace;font-size:11px;color:#a78bfa;line-height:1.8">
              <span style="color:var(--tx3)">// Request</span><br>
              { "messages": [{ "role": "user", "content": "帮我配置策略..." }] }<br><br>
              <span style="color:var(--tx3)">// Response: SSE stream</span><br>
              data: {"choices":[{"delta":{"content":"..."}}]}<br>
              data: [DONE]
            </div>
            <div style="font-size:11px;color:var(--tx3);margin-top:8px;line-height:1.7">SSE 流式输出。System prompt 注入策略解析指令，AI 返回含 autoExecute JSON 的回复时，前端自动识别并应用策略。</div>
          </div>

          <!-- /api/agent-status -->
          <div style="margin-bottom:24px">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px">
              <span style="font-size:10px;font-weight:800;padding:2px 8px;border-radius:5px;background:rgba(96,165,250,.12);border:1px solid rgba(96,165,250,.3);color:#60a5fa">GET</span>
              <span style="font-family:monospace;font-size:13px;color:var(--tx)">/api/agent-status</span>
              <span style="font-size:10px;color:var(--tx3)">服务端 ODA Agent 状态</span>
            </div>
            <div style="background:rgba(13,13,26,.8);border-radius:10px;padding:14px;font-family:monospace;font-size:11px;color:#a78bfa;line-height:1.8">
              { "ok": true, "agents": { "observer": {...}, "decision": {...}, "executor": {...} },<br>
              &nbsp;&nbsp;"lastDecision": { "action": "CREATE", "reason": "...", "source": "..." } }
            </div>
          </div>

          <!-- pa-worker.js -->
          <div>
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px">
              <span style="font-size:10px;font-weight:800;padding:2px 8px;border-radius:5px;background:rgba(245,158,11,.12);border:1px solid rgba(245,158,11,.3);color:#f59e0b">JS</span>
              <span style="font-family:monospace;font-size:13px;color:var(--tx)">/pa-worker.js</span>
              <span style="font-size:10px;color:var(--tx3)">Web Worker 自动执行器</span>
            </div>
            <div style="background:rgba(13,13,26,.8);border-radius:10px;padding:14px;font-family:monospace;font-size:11px;color:#a78bfa;line-height:1.8">
              <span style="color:var(--tx3)">// 启动 Worker</span><br>
              const w = new Worker('/pa-worker.js');<br>
              w.postMessage({ action: 'start', privateKey: pk, strategy: {...} });<br><br>
              <span style="color:var(--tx3)">// Worker 消息类型</span><br>
              scanning | found | need_sign | done | stopped | error | idle
            </div>
            <div style="font-size:11px;color:var(--tx3);margin-top:8px;line-height:1.7">独立后台线程，每3分钟调用 BSC RPC 扫描链上任务，发现符合策略的任务通过 <code style="background:rgba(255,255,255,.06);padding:1px 5px;border-radius:4px">need_sign</code> 消息通知主线程签名执行，服务器零介入。</div>
          </div>

        </div>
      </div>

      <!-- 复现步骤 -->
      <div style="margin-bottom:48px">
        <div style="font-size:11px;font-weight:700;letter-spacing:1.5px;color:#34d399;margin-bottom:16px">◆ &nbsp;完整复现步骤</div>
        <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:16px;overflow:hidden">
          <div style="padding:16px 20px;border-bottom:1px solid rgba(255,255,255,.06);display:flex;gap:16px;align-items:flex-start">
            <div style="width:24px;height:24px;border-radius:6px;background:rgba(52,211,153,.2);color:#34d399;font-size:11px;font-weight:900;display:flex;align-items:center;justify-content:center;flex-shrink:0">1</div>
            <div><div style="font-size:13px;font-weight:700;margin-bottom:4px">克隆 / 下载合约</div><div style="font-size:11px;color:var(--tx3)">下载 MemeBountyV2.sol 和 AgentRegistry.sol，通过 Remix IDE 或 Hardhat 编译部署到 BSC</div></div>
          </div>
          <div style="padding:16px 20px;border-bottom:1px solid rgba(255,255,255,.06);display:flex;gap:16px;align-items:flex-start">
            <div style="width:24px;height:24px;border-radius:6px;background:rgba(52,211,153,.2);color:#34d399;font-size:11px;font-weight:900;display:flex;align-items:center;justify-content:center;flex-shrink:0">2</div>
            <div><div style="font-size:13px;font-weight:700;margin-bottom:4px">配置 .env</div><div style="font-size:11px;color:var(--tx3)">填写合约地址、Agent 钱包私钥、RPC URL、LLM API Key（支持任意 OpenAI 兼容接口）</div></div>
          </div>
          <div style="padding:16px 20px;border-bottom:1px solid rgba(255,255,255,.06);display:flex;gap:16px;align-items:flex-start">
            <div style="width:24px;height:24px;border-radius:6px;background:rgba(52,211,153,.2);color:#34d399;font-size:11px;font-weight:900;display:flex;align-items:center;justify-content:center;flex-shrink:0">3</div>
            <div><div style="font-size:13px;font-weight:700;margin-bottom:4px">启动后端</div><div style="font-size:11px;color:var(--tx3)">npm install && node server.js（端口 3000）+ node loop.js（Agent 每 3 分钟自动运行）</div></div>
          </div>
          <div style="padding:16px 20px;border-bottom:1px solid rgba(255,255,255,.06);display:flex;gap:16px;align-items:flex-start">
            <div style="width:24px;height:24px;border-radius:6px;background:rgba(52,211,153,.2);color:#34d399;font-size:11px;font-weight:900;display:flex;align-items:center;justify-content:center;flex-shrink:0">4</div>
            <div><div style="font-size:13px;font-weight:700;margin-bottom:4px">发币并委托</div><div style="font-size:11px;color:var(--tx3)">在「发币」页用 MetaMask 发射 meme 代币（BSC: four.meme），然后到「委托」页选择 Agent 类型并注资</div></div>
          </div>
          <div style="padding:16px 20px;display:flex;gap:16px;align-items:flex-start">
            <div style="width:24px;height:24px;border-radius:6px;background:rgba(52,211,153,.2);color:#34d399;font-size:11px;font-weight:900;display:flex;align-items:center;justify-content:center;flex-shrink:0">5</div>
            <div><div style="font-size:13px;font-weight:700;margin-bottom:4px">Agent 自动运行</div><div style="font-size:11px;color:var(--tx3)">3 分钟后 Agent 开始观察市场信号，根据 5 条触发规则自动发布链上任务，用户完成任务可领取奖励</div></div>
          </div>
        </div>
      </div>

      <!-- 下载 & 链接 -->
      <div style="margin-bottom:40px">
        <div style="font-size:11px;font-weight:700;letter-spacing:1.5px;color:#34d399;margin-bottom:16px">◆ &nbsp;下载 & 资源</div>
        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:12px">
          <a href="/contract" style="display:flex;align-items:center;gap:12px;padding:16px 20px;background:rgba(52,211,153,.06);border:1px solid rgba(52,211,153,.2);border-radius:14px;text-decoration:none;color:var(--tx)">
            <div style="width:36px;height:36px;border-radius:10px;background:rgba(52,211,153,.15);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0">◈</div>
            <div><div style="font-size:13px;font-weight:700">MemeBountyV2.sol</div><div style="font-size:11px;color:var(--tx3)">下载主合约源码</div></div>
          </a>
          <a href="/registry" style="display:flex;align-items:center;gap:12px;padding:16px 20px;background:rgba(52,211,153,.06);border:1px solid rgba(52,211,153,.2);border-radius:14px;text-decoration:none;color:var(--tx)">
            <div style="width:36px;height:36px;border-radius:10px;background:rgba(52,211,153,.15);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0">◈</div>
            <div><div style="font-size:13px;font-weight:700">AgentRegistry.sol</div><div style="font-size:11px;color:var(--tx3)">下载 Agent 注册合约</div></div>
          </a>
          <a href="https://www.oklink.com/xlayer/address/0xBce8A6124255c0bB1e65DF6bb72A53833261455f" target="_blank" style="display:flex;align-items:center;gap:12px;padding:16px 20px;background:rgba(167,139,250,.06);border:1px solid rgba(167,139,250,.2);border-radius:14px;text-decoration:none;color:var(--tx)">
            <div style="width:36px;height:36px;border-radius:10px;background:rgba(167,139,250,.15);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0">◈</div>
            <div><div style="font-size:11px;color:var(--tx3)">OKLink 浏览器查看</div></div>
          </a>
          <a href="https://bscscan.com/address/0xea43a24a1baefb89494126c12fe8921b5b8e3d8d" target="_blank" style="display:flex;align-items:center;gap:12px;padding:16px 20px;background:rgba(245,158,11,.06);border:1px solid rgba(245,158,11,.2);border-radius:14px;text-decoration:none;color:var(--tx)">
            <div style="width:36px;height:36px;border-radius:10px;background:rgba(245,158,11,.15);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0">◈</div>
            <div><div style="font-size:13px;font-weight:700">BSC 合约 ↗</div><div style="font-size:11px;color:var(--tx3)">BSCScan 浏览器查看</div></div>
          </a>
        </div>
      </div>
    </div>
</div></div></div>
