       <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px">
         <div style="width:32px;height:32px;border-radius:10px;background:rgba(59,130,246,.15);border:1px solid rgba(59,130,246,.3);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:900;color:#60a5fa">O</div>
