 </div>
 <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;flex:1;min-width:200px">
 <div style="background:rgba(255,255,255,.04);border-radius:12px;padding:10px">
 <div style="font-size:10px;color:var(--tx3);margin-bottom:4px">资金费率</div>
 <div style="font-size:15px;font-weight:800" id="mkt-fr">—</div>
 </div>
