            <div style="font-size:13px;font-weight:700;margin-bottom:6px">启动服务</div>
            <div style="font-size:11px;color:var(--tx3)">node server.js + node loop.js，或用 systemd 管理</div>
          </div>
        </div>
      </div>

      <!-- 环境变量 -->
      <div style="margin-bottom:48px">
        <div style="font-size:11px;font-weight:700;letter-spacing:1.5px;color:#34d399;margin-bottom:16px">◆ &nbsp;环境变量 (.env)</div>
        <div style="background:#0d0d1a;border:1px solid rgba(52,211,153,.2);border-radius:16px;padding:24px;font-family:monospace;font-size:12px;line-height:2;color:#a3e635;overflow-x:auto">
          <div style="color:#6b7280;margin-bottom:4px"># 链配置</div>
          <div>BSC_RPC_URL=https://bsc-dataseed.binance.org/</div>
          <div></div>
          <div style="color:#6b7280;margin-top:8px;margin-bottom:4px"># 合约地址（BSC）</div>
          <div>CONTRACT_ADDRESS=0xea43a24a1baefb89494126c12fe8921b5b8e3d8d</div>
          <div>REGISTRY_ADDRESS=0x8c98f9821299e531353dd004b722851cf1b4c8a2</div>
          <div style="color:#6b7280;margin-top:8px;margin-bottom:4px"></div>
          <div></div>
          <div>XLAYER_REGISTRY=0xCB778Ac6A811A2712764F2cee69748CaCb71b80f</div>
          <div style="color:#6b7280;margin-top:8px;margin-bottom:4px"># Agent 配置</div>
