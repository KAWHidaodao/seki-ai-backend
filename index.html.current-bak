 <!-- Agent 决策逻辑说明 -->
 <div style="background:linear-gradient(135deg,rgba(124,58,237,.06),rgba(59,130,246,.04));border:1px solid rgba(124,58,237,.15);border-radius:20px;padding:20px;margin-bottom:20px">
 <div style="font-size:11px;font-weight:700;letter-spacing:2px;color:var(--p);margin-bottom:12px">WHY AI · 为什么让 AI 来决策</div>
 <div style="font-size:13px;color:var(--tx2);line-height:1.9;margin-bottom:16px">
 人工发任务有三个致命缺陷：<strong style="color:var(--tx)">慢、主观、不透明</strong>。项目方决定给谁发多少，用户只能被动接受。<br>
 Seki Agent 解决的是信任问题——所有决策基于公开的链上数据和市场信号，任何人可以查验逻辑，没有人为干预。
 </div>
 <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:10px">
 <div style="background:rgba(255,255,255,.04);border-radius:12px;padding:12px">
 <div style="font-size:18px;margin-bottom:6px"></div>
 <div style="font-size:12px;font-weight:700;margin-bottom:4px">链上数据驱动</div>
 <div style="font-size:11px;color:var(--tx2);line-height:1.6">价格、流动性、任务完成率——Agent 每3分钟扫链，数据说话</div>
 </div>
 <div style="background:rgba(255,255,255,.04);border-radius:12px;padding:12px">
 <div style="font-size:18px;margin-bottom:6px"></div>
 <div style="font-size:12px;font-weight:700;margin-bottom:4px">大盘感知</div>
 <div style="font-size:11px;color:var(--tx2);line-height:1.6">鲸鱼大单、资金费率、买卖盘深度——比散户提前2分钟感知市场变化</div>
 </div>
 <div style="background:rgba(255,255,255,.04);border-radius:12px;padding:12px">
 <div style="font-size:18px;margin-bottom:6px"></div>
 <div style="font-size:12px;font-weight:700;margin-bottom:4px">LLM 综合推理</div>
 <div style="font-size:11px;color:var(--tx2);line-height:1.6">所有信号输入大语言模型，输出最适合当前行情的任务类型和奖励金额</div>
 </div>
 <div style="background:rgba(255,255,255,.04);border-radius:12px;padding:12px">
 <div style="font-size:18px;margin-bottom:6px"></div>
 <div style="font-size:12px;font-weight:700;margin-bottom:4px">链上执行，不可篡改</div>
 <div style="font-size:11px;color:var(--tx2);line-height:1.6">决策结果直接写入合约，奖励从 taxPool 扣除，全程可链上验证</div>
 </div>
 </div>
 <!-- 当前决策状态 -->
 <div style="margin-top:14px;padding:12px 16px;background:rgba(13,13,26,.6);border-radius:12px;font-size:12px;color:var(--tx2)" id="agent-reasoning">
 <span style="color:var(--tx3)">等待 Agent 下一轮决策...</span>
 </div>
 </div>


 <!-- 多 Agent 协作状态 -->
 <div style="margin-bottom:20px">
   <div style="font-size:11px;font-weight:700;letter-spacing:2px;color:var(--tx3);margin-bottom:12px">◆ &nbsp;MULTI-AGENT SYSTEM · 三Agent协作</div>
   <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px" id="agent-cards">
     <!-- ObserverAgent -->
     <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:16px;padding:18px;position:relative;overflow:hidden">
       <div style="position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,rgba(59,130,246,.8),transparent)" id="obs-bar"></div>
       <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px">
         <div style="width:32px;height:32px;border-radius:10px;background:rgba(59,130,246,.15);border:1px solid rgba(59,130,246,.3);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:900;color:#60a5fa">O</div>
         <div>
           <div style="font-size:12px;font-weight:800">ObserverAgent</div>
           <div style="font-size:10px;color:var(--tx3)">链上信号采集</div>
         </div>
         <div id="obs-dot" style="margin-left:auto;width:8px;height:8px;border-radius:50%;background:#374151"></div>
       </div>
       <div style="font-size:11px;color:var(--tx3);line-height:1.7">每 3 分钟扫描 BSC<br>采集价格、流动性、市场情绪</div>
       <div style="margin-top:10px;font-size:10px;color:var(--tx3)" id="obs-last">上次运行：—</div>
     </div>
     <!-- DecisionAgent -->
     <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:16px;padding:18px;position:relative;overflow:hidden">
       <div style="position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,rgba(124,58,237,.8),transparent)" id="dec-bar"></div>
       <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px">
         <div style="width:32px;height:32px;border-radius:10px;background:rgba(124,58,237,.15);border:1px solid rgba(124,58,237,.3);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:900;color:var(--p)">D</div>
         <div>
           <div style="font-size:12px;font-weight:800">DecisionAgent</div>
           <div style="font-size:10px;color:var(--tx3)">AI 推理决策</div>
         </div>
         <div id="dec-dot" style="margin-left:auto;width:8px;height:8px;border-radius:50%;background:#374151"></div>
       </div>
       <div style="font-size:11px;color:var(--tx3);line-height:1.7">规则引擎 + LLM 双重推理<br>输出结构化任务决策</div>
       <div style="margin-top:10px;font-size:10px;color:var(--p);font-weight:700" id="dec-last">等待决策...</div>
     </div>
     <!-- ExecutorAgent -->
     <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:16px;padding:18px;position:relative;overflow:hidden">
       <div style="position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,rgba(52,211,153,.8),transparent)" id="exe-bar"></div>
       <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px">
         <div style="width:32px;height:32px;border-radius:10px;background:rgba(52,211,153,.15);border:1px solid rgba(52,211,153,.3);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:900;color:#34d399">E</div>
         <div>
           <div style="font-size:12px;font-weight:800">ExecutorAgent</div>
           <div style="font-size:10px;color:var(--tx3)">自主支付执行</div>
         </div>
         <div id="exe-dot" style="margin-left:auto;width:8px;height:8px;border-radius:50%;background:#374151"></div>
       </div>
       <div style="font-size:11px;color:var(--tx3);line-height:1.7">BSC 链自主支付<br>taxPool → 合约任务无需人工</div>
       <div style="margin-top:10px;font-size:10px;color:var(--tx3)" id="exe-last">上次执行：—</div>
     </div>
   </div>
   <!-- 协作箭头说明 -->
   <div style="margin-top:12px;display:flex;align-items:center;justify-content:center;gap:8px;font-size:11px;color:var(--tx3)">
     <span style="color:#60a5fa;font-weight:700">Observer</span>
