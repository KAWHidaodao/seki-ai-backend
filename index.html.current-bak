        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:24px">
          <div style="padding:20px;background:rgba(52,211,153,.06);border:1px solid rgba(52,211,153,.2);border-radius:16px;text-align:center">
            <div style="font-size:24px;font-weight:900;color:#34d399;margin-bottom:8px">01</div>
            <div style="font-size:13px;font-weight:700;margin-bottom:6px">部署合约</div>
            <div style="font-size:11px;color:var(--tx3)">用 Hardhat 或 Remix 部署 MemeBountyV2 + AgentRegistry</div>
          </div>
          <div style="padding:20px;background:rgba(52,211,153,.06);border:1px solid rgba(52,211,153,.2);border-radius:16px;text-align:center">
