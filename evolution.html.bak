<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Seki 进化大厅</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:system-ui,-apple-system,sans-serif;background:#f8f9fa;color:#1a1a2e;line-height:1.6}
a{color:#6c5ce7;text-decoration:none}
.container{max-width:1200px;margin:0 auto;padding:20px}

/* Header */
.header{background:#fff;border-bottom:1px solid #eee;padding:16px 0;margin-bottom:32px}
.header .container{display:flex;align-items:center;justify-content:space-between}
.header h1{font-size:24px;font-weight:700;color:#1a1a2e}
.header h1 span{color:#6c5ce7}
.back-link{font-size:14px;color:#888;transition:color .2s}
.back-link:hover{color:#6c5ce7}

/* KPI Cards */
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:20px;margin-bottom:36px}
.kpi-card{background:#fff;border-radius:16px;padding:24px;box-shadow:0 2px 12px rgba(0,0,0,.06);text-align:center;transition:transform .2s,box-shadow .2s}
.kpi-card:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,0,0,.1)}
.kpi-value{font-size:36px;font-weight:800;color:#6c5ce7;margin:8px 0}
.kpi-label{font-size:13px;color:#888;text-transform:uppercase;letter-spacing:1px}
.kpi-icon{font-size:28px;margin-bottom:4px}

/* Section */
.section{margin-bottom:36px}
.section-title{font-size:20px;font-weight:700;margin-bottom:16px;padding-left:12px;border-left:4px solid #6c5ce7}

/* Reflections Timeline */
.timeline{position:relative;padding-left:28px}
.timeline::before{content:'';position:absolute;left:8px;top:0;bottom:0;width:2px;background:linear-gradient(to bottom,#6c5ce7,#a29bfe,#ddd)}
.refl-card{background:#fff;border-radius:16px;padding:20px 24px;margin-bottom:16px;box-shadow:0 2px 12px rgba(0,0,0,.06);position:relative;animation:fadeInUp .5s ease both}
.refl-card::before{content:'';position:absolute;left:-24px;top:24px;width:12px;height:12px;border-radius:50%;background:#6c5ce7;border:3px solid #f8f9fa}
.refl-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;flex-wrap:wrap;gap:8px}
.refl-title{font-size:16px;font-weight:700;color:#1a1a2e}
.refl-date{font-size:12px;color:#aaa}
.score-badge{display:inline-block;padding:4px 12px;border-radius:20px;font-size:13px;font-weight:700;color:#fff}
.score-high{background:linear-gradient(135deg,#00b894,#00cec9)}
.score-mid{background:linear-gradient(135deg,#fdcb6e,#e17055)}
.score-low{background:linear-gradient(135deg,#e17055,#d63031)}
.refl-insights{margin:8px 0}
.refl-insights li{font-size:13px;color:#555;margin:4px 0;padding-left:16px;position:relative}
.refl-insights li::before{content:'💡';position:absolute;left:0;font-size:11px}
.refl-improvements li{font-size:13px;color:#6c5ce7;margin:4px 0;padding-left:16px;position:relative}
.refl-improvements li::before{content:'🔧';position:absolute;left:0;font-size:11px}
.refl-metrics{display:flex;gap:16px;margin-top:10px;flex-wrap:wrap}
.metric-tag{font-size:11px;background:#f0f0f0;padding:4px 10px;border-radius:8px;color:#666}

/* Skills Grid */
.skills-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:16px}
.skill-card{background:#fff;border-radius:16px;padding:20px;box-shadow:0 2px 12px rgba(0,0,0,.06);transition:transform .2s}
.skill-card:hover{transform:translateY(-2px)}
.skill-header{display:flex;align-items:center;gap:10px;margin-bottom:12px}
.skill-icon{font-size:24px}
.skill-name{font-size:15px;font-weight:700}
.skill-bar-bg{width:100%;height:8px;background:#f0f0f0;border-radius:4px;overflow:hidden}
.skill-bar{height:100%;background:linear-gradient(90deg,#6c5ce7,#a29bfe);border-radius:4px;transition:width 1s ease}
.skill-meta{display:flex;justify-content:space-between;margin-top:8px;font-size:11px;color:#aaa}

/* Proposals */
.proposal-list{display:flex;flex-direction:column;gap:12px}
.proposal-card{background:#fff;border-radius:16px;padding:18px 24px;box-shadow:0 2px 12px rgba(0,0,0,.06);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px}
.proposal-title{font-size:14px;font-weight:600;flex:1}
.proposal-score{font-size:13px;color:#888}
.status-badge{padding:4px 12px;border-radius:12px;font-size:12px;font-weight:600}
.status-approved{background:#dfe6e9;color:#00b894}
.status-pending{background:#ffeaa7;color:#d68910}
.status-rejected{background:#fab1a0;color:#d63031}

/* Chart placeholder */
.chart-container{background:#fff;border-radius:16px;padding:24px;box-shadow:0 2px 12px rgba(0,0,0,.06);margin-bottom:36px;min-height:200px}
.chart-canvas{width:100%;height:200px}

/* Animations */
@keyframes fadeInUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.kpi-card:nth-child(1){animation:fadeInUp .4s ease both}
.kpi-card:nth-child(2){animation:fadeInUp .5s ease both}
.kpi-card:nth-child(3){animation:fadeInUp .6s ease both}
.kpi-card:nth-child(4){animation:fadeInUp .7s ease both}
.kpi-card:nth-child(5){animation:fadeInUp .8s ease both}

/* Responsive */
@media(max-width:600px){
  .kpi-grid{grid-template-columns:1fr 1fr}
  .skills-grid{grid-template-columns:1fr}
  .proposal-card{flex-direction:column;align-items:flex-start}
}

.loading{text-align:center;padding:40px;color:#aaa;font-size:14px}
.refresh-hint{text-align:center;font-size:11px;color:#ccc;margin-top:24px}
</style>
</head>
<body>

<div class="header">
  <div class="container">
    <h1>🧬 <span>Seki</span> 进化大厅</h1>
    <a class="back-link" href="/">← 返回主站</a>
  </div>
</div>

<div class="container">
  <!-- KPI -->
  <div class="kpi-grid" id="kpiGrid">
    <div class="kpi-card"><div class="kpi-icon">🧠</div><div class="kpi-value" id="kpiReflections">--</div><div class="kpi-label">总反思次数</div></div>
    <div class="kpi-card"><div class="kpi-icon">🔄</div><div class="kpi-value" id="kpiCycles">--</div><div class="kpi-label">进化周期</div></div>
    <div class="kpi-card"><div class="kpi-icon">🎯</div><div class="kpi-value" id="kpiRate">--</div><div class="kpi-label">平均成功率</div></div>
    <div class="kpi-card"><div class="kpi-icon">⚡</div><div class="kpi-value" id="kpiSkills">--</div><div class="kpi-label">已学技能</div></div>
    <div class="kpi-card"><div class="kpi-icon">📦</div><div class="kpi-value" id="kpiVersion">--</div><div class="kpi-label">当前版本</div></div>
  </div>

  <!-- Score Chart -->
  <div class="chart-container section">
    <div class="section-title">反思分数趋势</div>
    <canvas id="scoreChart" class="chart-canvas"></canvas>
  </div>

  <!-- Reflections Timeline -->
  <div class="section">
    <div class="section-title">反思时间线</div>
    <div class="timeline" id="timeline"><div class="loading">加载中...</div></div>
  </div>

  <!-- Skills -->
  <div class="section">
    <div class="section-title">技能库</div>
    <div class="skills-grid" id="skillsGrid"><div class="loading">加载中...</div></div>
  </div>

  <!-- Proposals -->
  <div class="section">
    <div class="section-title">进化提案</div>
    <div class="proposal-list" id="proposalList"><div class="loading">加载中...</div></div>
  </div>

  <div class="refresh-hint">每 60 秒自动刷新 · Seki 每日反思中</div>
</div>

<script>
const API = {
  dashboard: '/api/evolution/dashboard',
  reflections: '/api/evolution/reflections',
  skills: '/api/evolution/skills',
  proposals: '/api/evolution/proposals',
};

async function fetchJSON(url) {
  try { const r = await fetch(url); return r.ok ? r.json() : null; }
  catch(e) { return null; }
}

function scoreClass(s) {
  if (s >= 7) return 'score-high';
  if (s >= 5) return 'score-mid';
  return 'score-low';
}

function fmtDate(iso) {
  const d = new Date(iso);
  return d.toLocaleDateString('zh-CN', { year:'numeric', month:'long', day:'numeric' });
}

// ── KPI ──
async function loadDashboard() {
  const d = await fetchJSON(API.dashboard);
  if (!d) return;
  document.getElementById('kpiReflections').textContent = d.totalReflections || 0;
  document.getElementById('kpiCycles').textContent = d.totalCycles || 0;
  document.getElementById('kpiRate').textContent = (d.completionRate || 0) + '%';
  document.getElementById('kpiSkills').textContent = d.totalSkills || 0;
  document.getElementById('kpiVersion').textContent = d.version || 'v1.0.0';
}

// ── Reflections ──
async function loadReflections() {
  const data = await fetchJSON(API.reflections);
  const el = document.getElementById('timeline');
  if (!data || !data.length) { el.innerHTML = '<div class="loading">暂无反思数据</div>'; return; }
  
  // Sort newest first
  const sorted = [...data].sort((a,b) => new Date(b.timestamp) - new Date(a.timestamp));
  
  el.innerHTML = sorted.map((r, i) => `
    <div class="refl-card" style="animation-delay:${i * 0.08}s">
      <div class="refl-header">
        <div>
          <span class="refl-title">${r.title || '反思 #' + r.id}</span>
          <span class="refl-date">${fmtDate(r.timestamp)}</span>
        </div>
        <span class="score-badge ${scoreClass(r.score)}">${r.score}/10</span>
      </div>
      ${r.summary ? `<div style="font-size:13px;color:#666;margin-bottom:8px">${r.summary}</div>` : ''}
      ${r.insights && r.insights.length ? `
        <ul class="refl-insights">${r.insights.map(i => `<li>${i}</li>`).join('')}</ul>
      ` : ''}
      ${r.improvements && r.improvements.length ? `
        <ul class="refl-improvements">${r.improvements.map(i => `<li>${i}</li>`).join('')}</ul>
      ` : ''}
      <div class="refl-metrics">
        ${r.metrics ? `
          <span class="metric-tag">📋 ${r.metrics.tasksCompleted} 任务</span>
          <span class="metric-tag">✅ ${(r.metrics.successRate * 100).toFixed(1)}% 成功</span>
          <span class="metric-tag">⏱️ ${r.metrics.avgResponseTime}ms 响应</span>
        ` : ''}
      </div>
    </div>
  `).join('');
  
  return sorted;
}

// ── Skills ──
async function loadSkills() {
  const data = await fetchJSON(API.skills);
  const el = document.getElementById('skillsGrid');
  if (!data || !data.length) { el.innerHTML = '<div class="loading">暂无技能数据</div>'; return; }
  
  el.innerHTML = data.sort((a,b) => b.proficiency - a.proficiency).map(s => `
    <div class="skill-card">
      <div class="skill-header">
        <span class="skill-icon">${s.icon || '🔹'}</span>
        <span class="skill-name">${s.name}</span>
      </div>
      <div class="skill-bar-bg">
        <div class="skill-bar" style="width:${Math.round(s.proficiency * 100)}%"></div>
      </div>
      <div class="skill-meta">
        <span>熟练度 ${Math.round(s.proficiency * 100)}%</span>
        <span>使用 ${s.usageCount || 0} 次</span>
      </div>
    </div>
  `).join('');
}

// ── Proposals ──
async function loadProposals() {
  const data = await fetchJSON(API.proposals);
  const el = document.getElementById('proposalList');
  if (!data || !data.length) { el.innerHTML = '<div class="loading">暂无提案</div>'; return; }
  
  const statusMap = { approved: '已通过', pending: '待审核', rejected: '已拒绝' };
  el.innerHTML = data.map(p => `
    <div class="proposal-card">
      <span class="proposal-title">${p.title}</span>
      <span class="proposal-score">评分 ${p.score}</span>
      <span class="status-badge status-${p.status}">${statusMap[p.status] || p.status}</span>
    </div>
  `).join('');
}

// ── Simple Canvas Chart ──
function drawScoreChart(reflections) {
  const canvas = document.getElementById('scoreChart');
  if (!canvas || !reflections || !reflections.length) return;
  const ctx = canvas.getContext('2d');
  const sorted = [...reflections].sort((a,b) => new Date(a.timestamp) - new Date(b.timestamp));
  
  const W = canvas.width = canvas.parentElement.clientWidth - 48;
  const H = canvas.height = 200;
  const pad = { top: 20, bottom: 30, left: 40, right: 20 };
  const plotW = W - pad.left - pad.right;
  const plotH = H - pad.top - pad.bottom;
  
  ctx.clearRect(0, 0, W, H);
  
  // Grid lines
  ctx.strokeStyle = '#f0f0f0';
  ctx.lineWidth = 1;
  for (let i = 0; i <= 10; i += 2) {
    const y = pad.top + plotH - (i / 10) * plotH;
    ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(W - pad.right, y); ctx.stroke();
    ctx.fillStyle = '#ccc'; ctx.font = '11px system-ui'; ctx.textAlign = 'right';
    ctx.fillText(i, pad.left - 6, y + 4);
  }
  
  // Data points
  const pts = sorted.map((r, i) => ({
    x: pad.left + (i / (sorted.length - 1)) * plotW,
    y: pad.top + plotH - (r.score / 10) * plotH,
    score: r.score,
    date: new Date(r.timestamp),
  }));
  
  // Gradient fill
  const grad = ctx.createLinearGradient(0, pad.top, 0, H - pad.bottom);
  grad.addColorStop(0, 'rgba(108,92,231,0.15)');
  grad.addColorStop(1, 'rgba(108,92,231,0)');
  ctx.beginPath();
  ctx.moveTo(pts[0].x, H - pad.bottom);
  pts.forEach(p => ctx.lineTo(p.x, p.y));
  ctx.lineTo(pts[pts.length-1].x, H - pad.bottom);
  ctx.closePath();
  ctx.fillStyle = grad;
  ctx.fill();
  
  // Line
  ctx.beginPath();
  ctx.strokeStyle = '#6c5ce7';
  ctx.lineWidth = 2.5;
  ctx.lineJoin = 'round';
  pts.forEach((p, i) => i === 0 ? ctx.moveTo(p.x, p.y) : ctx.lineTo(p.x, p.y));
  ctx.stroke();
  
  // Dots
  pts.forEach(p => {
    ctx.beginPath();
    ctx.arc(p.x, p.y, 4, 0, Math.PI * 2);
    ctx.fillStyle = '#fff';
    ctx.fill();
    ctx.strokeStyle = '#6c5ce7';
    ctx.lineWidth = 2;
    ctx.stroke();
  });
  
  // X-axis labels (every 5th)
  ctx.fillStyle = '#aaa';
  ctx.font = '10px system-ui';
  ctx.textAlign = 'center';
  pts.forEach((p, i) => {
    if (i % 5 === 0 || i === pts.length - 1) {
      ctx.fillText(`${p.date.getMonth()+1}/${p.date.getDate()}`, p.x, H - 8);
    }
  });
}

// ── Init ──
async function init() {
  loadDashboard();
  loadSkills();
  loadProposals();
  const refls = await loadReflections();
  if (refls) {
    const sorted = [...refls].sort((a,b) => new Date(a.timestamp) - new Date(b.timestamp));
    setTimeout(() => drawScoreChart(sorted), 100);
  }
}

init();
setInterval(init, 60000);
window.addEventListener('resize', async () => {
  const refls = await fetchJSON(API.reflections);
  if (refls) drawScoreChart(refls);
});
</script>
</body>
</html>
