  <div id="fair-section-howto" style="display:none">
    <div style="max-width:1100px;margin:0 auto;padding:40px 28px 60px">

    <div style="margin-bottom:52px">
      <div class="label" style="margin-bottom:16px">◆ &nbsp;TOKEN LAUNCH TRANSPARENCY</div>
      <h2 class="display" style="margin-bottom:20px">发币流程<br><span class="accent">完全透明</span></h2>
      <p style="font-size:15px;color:var(--tx2);max-width:580px;line-height:1.9">所有代币由<strong style="color:var(--tx)">用户自己的钱包</strong>发行，平台服务器只做 API 中转，不持有任何私钥或资产。税收由合约自动托管，代码即规则。</p>
    </div>

    <!-- 流程步骤 -->
    <div style="position:relative;padding-left:32px;margin-bottom:64px">
      <div style="position:absolute;left:19px;top:24px;bottom:24px;width:2px;background:linear-gradient(to bottom,rgba(124,58,237,.7),rgba(5,150,105,.7))"></div>

      <!-- 1 -->
      <div style="display:flex;gap:28px;align-items:flex-start;margin-bottom:28px">
        <div style="width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,#7c3aed,#6d28d9);display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:900;color:#fff;flex-shrink:0;box-shadow:0 4px 20px rgba(124,58,237,.5)">1</div>
        <div style="flex:1">
          <div style="padding:24px 28px;background:rgba(124,58,237,.06);border:1px solid rgba(124,58,237,.2);border-radius:18px">
            <div style="font-size:16px;font-weight:800;margin-bottom:10px">填写代币信息 &amp; 上传 Logo</div>
            <div style="font-size:14px;color:var(--tx2);line-height:1.8">名称、符号、描述，选择交易税率（推荐 3%），上传项目头像。</div>
            <div style="margin-top:12px;padding:10px 14px;background:rgba(255,255,255,.04);border-radius:10px;font-size:12px;color:var(--tx3)">💡 图片直传 four.meme 服务器，平台不保存任何副本</div>
          </div>
        </div>
      </div>

      <!-- 2 -->
      <div style="display:flex;gap:28px;align-items:flex-start;margin-bottom:28px">
        <div style="width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,#6d28d9,#3b82f6);display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:900;color:#fff;flex-shrink:0;box-shadow:0 4px 20px rgba(59,130,246,.4)">2</div>
        <div style="flex:1">
          <div style="padding:24px 28px;background:rgba(59,130,246,.05);border:1px solid rgba(59,130,246,.18);border-radius:18px">
            <div style="font-size:16px;font-weight:800;margin-bottom:10px">服务器调 four.meme API <span style="font-size:13px;font-weight:400;color:var(--tx3)">— 仅参数准备</span></div>
            <div style="font-size:14px;color:var(--tx2);line-height:1.8">后端用服务账号调用 four.meme <code style="font-size:12px;padding:2px 8px;background:rgba(255,255,255,.08);border-radius:5px">create-api</code>，获取代币创建参数后返回给前端。</div>
            <div style="margin-top:12px;padding:10px 14px;background:rgba(5,150,105,.06);border-radius:10px;font-size:12px;color:var(--gr)">✅ 此步骤不广播任何链上交易，服务器无法替用户签名</div>
          </div>
        </div>
      </div>

      <!-- 3 -->
      <div style="display:flex;gap:28px;align-items:flex-start;margin-bottom:28px">
        <div style="width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,#f59e0b,#d97706);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;box-shadow:0 4px 20px rgba(245,158,11,.4)">🔑</div>
        <div style="flex:1">
          <div style="padding:24px 28px;background:rgba(245,158,11,.06);border:1px solid rgba(245,158,11,.25);border-radius:18px">
            <div style="font-size:16px;font-weight:800;margin-bottom:10px">你的钱包签名上链 <span style="font-size:13px;font-weight:400;color:var(--tx3)">— Gas 由你支付</span></div>
            <div style="font-size:14px;color:var(--tx2);line-height:1.8">MetaMask 弹出确认请求，<strong style="color:var(--tx)">你自己的钱包</strong>调用 four.meme 合约 <code style="font-size:12px;padding:2px 8px;background:rgba(255,255,255,.08);border-radius:5px">createToken(createArg, signature)</code>，代币所有权归你。</div>
            <div style="margin-top:12px;padding:10px 14px;background:rgba(245,158,11,.08);border-radius:10px;font-size:12px;color:#fbbf24">⚡ 平台服务器无法代替你签名，无法控制你的代币</div>
          </div>
        </div>
      </div>

      <!-- 4 -->
      <div style="display:flex;gap:28px;align-items:flex-start;margin-bottom:28px">
        <div style="width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,#059669,#0d9488);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;box-shadow:0 4px 20px rgba(5,150,105,.4)">💰</div>
        <div style="flex:1">
          <div style="padding:24px 28px;background:rgba(5,150,105,.06);border:1px solid rgba(5,150,105,.22);border-radius:18px">
            <div style="font-size:16px;font-weight:800;margin-bottom:10px">税收 → AgentRegistry 合约 <code style="font-size:12px;font-weight:400;padding:2px 8px;background:rgba(255,255,255,.08);border-radius:5px">taxPool</code></div>
            <div style="font-size:14px;color:var(--tx2);line-height:1.8">每笔买卖产生的税收，由 four.meme 合约直接转入 AgentRegistry <strong>合约地址</strong>（非 EOA 钱包）。合约 <code style="font-size:12px;padding:2px 8px;background:rgba(255,255,255,.08);border-radius:5px">receive()</code> 自动累积到 <code style="font-size:12px;padding:2px 8px;background:rgba(255,255,255,.08);border-radius:5px">taxPool</code>。</div>
            <div style="margin-top:12px;padding:10px 14px;background:rgba(5,150,105,.08);border-radius:10px;font-size:12px;color:var(--gr)">✅ Agent 私钥泄露最多损失 Gas，税收资金全程在合约里</div>
          </div>
        </div>
      </div>

      <!-- 5 -->
      <div style="display:flex;gap:28px;align-items:flex-start">
        <div style="width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,#059669,#065f46);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;box-shadow:0 4px 24px rgba(5,150,105,.5)">🤖</div>
        <div style="flex:1">
          <div style="padding:24px 28px;background:rgba(5,150,105,.08);border:1px solid rgba(5,150,105,.3);border-radius:18px">
            <div style="font-size:16px;font-weight:800;margin-bottom:10px">Agent 从 taxPool 自动发激励任务</div>
            <div style="font-size:14px;color:var(--tx2);line-height:1.8">AI Agent 每3分钟观察链上数据，调用 <code style="font-size:12px;padding:2px 8px;background:rgba(255,255,255,.08);border-radius:5px">createTaskFromTax()</code> 从 taxPool 划拨资金发任务。无需人工干预，完全链上自动化。</div>
            <!-- 飞轮 -->
            <div style="margin-top:20px;padding:16px;background:rgba(0,0,0,.2);border-radius:12px">
              <div style="font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--tx3);margin-bottom:12px">激励飞轮</div>
              <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;font-size:13px;font-weight:700">
                <div style="padding:8px 14px;background:rgba(5,150,105,.15);border:1px solid rgba(5,150,105,.3);border-radius:24px;color:var(--gr)">税收积累</div>
                <div style="color:var(--tx3);font-size:16px">→</div>
                <div style="padding:8px 14px;background:rgba(124,58,237,.15);border:1px solid rgba(124,58,237,.3);border-radius:24px;color:var(--p)">Agent 发任务</div>
                <div style="color:var(--tx3);font-size:16px">→</div>
                <div style="padding:8px 14px;background:rgba(59,130,246,.12);border:1px solid rgba(59,130,246,.25);border-radius:24px;color:#60a5fa">用户参与领奖</div>
                <div style="color:var(--tx3);font-size:16px">→</div>
                <div style="padding:8px 14px;background:rgba(245,158,11,.12);border:1px solid rgba(245,158,11,.25);border-radius:24px;color:#fbbf24">更多买入</div>
                <div style="color:var(--p);font-size:18px;font-weight:900">↗</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 4个保证 -->
    <div style="margin-bottom:56px">
      <div style="font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--tx3);margin-bottom:20px">四大保证</div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:14px">
        <div style="padding:24px 20px;background:rgba(124,58,237,.06);border:1px solid rgba(124,58,237,.18);border-radius:18px;text-align:center">
          <div style="font-size:36px;margin-bottom:12px">🔑</div>
          <div style="font-size:14px;font-weight:800;margin-bottom:6px">用户自己签名</div>
          <div style="font-size:12px;color:var(--tx3);line-height:1.6">平台无法代替发币或转移代币</div>
        </div>
        <div style="padding:24px 20px;background:rgba(5,150,105,.06);border:1px solid rgba(5,150,105,.18);border-radius:18px;text-align:center">
          <div style="font-size:36px;margin-bottom:12px">🏦</div>
          <div style="font-size:14px;font-weight:800;margin-bottom:6px">税收合约托管</div>
          <div style="font-size:12px;color:var(--tx3);line-height:1.6">Agent 私钥泄露最多损失 Gas</div>
        </div>
        <div style="padding:24px 20px;background:rgba(59,130,246,.05);border:1px solid rgba(59,130,246,.18);border-radius:18px;text-align:center">
          <div style="font-size:36px;margin-bottom:12px">⚡</div>
          <div style="font-size:14px;font-weight:800;margin-bottom:6px">Gas 完全透明</div>
          <div style="font-size:12px;color:var(--tx3);line-height:1.6">各自钱包支付，平台不垫付</div>
        </div>
        <div style="padding:24px 20px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.12);border-radius:18px;text-align:center">
          <div style="font-size:36px;margin-bottom:12px">🔍</div>
          <div style="font-size:14px;font-weight:800;margin-bottom:6px">BSCScan 可验证</div>
          <div style="font-size:12px;color:var(--tx3);line-height:1.6">所有资金流动链上实时可查</div>
        </div>
      </div>
    </div>

    <!-- 合约地址 -->
    <div style="padding:24px 28px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:18px">
      <div style="font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--tx3);margin-bottom:16px">已部署合约（BSC 主网）</div>
      <div style="display:flex;flex-direction:column;gap:10px">
        <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
          <span style="font-size:12px;font-weight:700;min-width:160px;color:var(--tx2)">SekiV2</span>
          <span style="font-family:monospace;font-size:11px;color:var(--tx3);flex:1">0x6C21E926C5afE05fc263BD9223aAabb8B6B82aE0</span>
          <a class="erc-ct-link" href="https://bscscan.com/address/0x6C21E926C5afE05fc263BD9223aAabb8B6B82aE0" target="_blank">BSCScan ↗</a>
        
        <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
          <span style="font-size:12px;font-weight:700;min-width:160px;color:var(--tx2)">AgentRegistry</span>
          <span style="font-family:monospace;font-size:11px;color:var(--tx3);flex:1">0xABBB59fC5Ca85DC4b15B2f8698a0395A72F932bf</span>
          <a class="erc-ct-link" href="https://bscscan.com/address/0xABBB59fC5Ca85DC4b15B2f8698a0395A72F932bf" target="_blank">BSCScan ↗</a>
        
        <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
          <span style="font-size:12px;font-weight:700;min-width:160px;color:var(--tx2)">AgentReportHook</span>
          <span style="font-family:monospace;font-size:11px;color:var(--tx3);flex:1">0xad5e4Cf8774D8cAB3e6f2bF4128E358E2A1d4Fa3</span>
          <a class="erc-ct-link" href="https://bscscan.com/address/0xad5e4Cf8774D8cAB3e6f2bF4128E358E2A1d4Fa3" target="_blank">BSCScan ↗</a>
</div>
</div>
</div>
</div>
</div>
</div>
</div>
</div>
</div>
</div>

<div id="page-delegate" class="pw">

<!-- 顶部 Hero -->
<div style="position:relative;overflow:hidden;padding:80px 24px 60px;text-align:center">
  <div style="position:absolute;top:-60px;left:50%;transform:translateX(-50%);width:600px;height:400px;background:radial-gradient(ellipse,rgba(124,58,237,.18) 0%,transparent 70%);pointer-events:none"></div>
  <div class="label" style="margin-bottom:14px;justify-content:center">◆ AI AGENT MARKETPLACE</div>
  <h2 class="headline" style="font-size:clamp(32px,5vw,52px);margin-bottom:16px;line-height:1.1">选一个 <span class="accent">AI Agent</span><br>替你经营代币社区</h2>
  <p style="font-size:14px;color:var(--tx2);max-width:480px;margin:0 auto;line-height:1.9">你只需充值预算并委托，Agent 全自动观察链上数据、生成任务、发放奖励<br>资金全程托管在合约，随时可退</p>
</div>

<!-- Agent 能力展示 -->
<div style="max-width:1100px;margin:0 auto;padding:0 24px 60px">

  <!-- 4大能力横幅 -->
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:60px">
    <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:20px 16px;text-align:center">
      <div style="font-size:28px;margin-bottom:10px">👁️</div>
      <div style="font-size:13px;font-weight:800;color:var(--tx);margin-bottom:6px">实时观察</div>
      <div style="font-size:11px;color:var(--tx3);line-height:1.6">每3分钟扫描链上数据、持币人数、价格波动</div>
    </div>
    <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:20px 16px;text-align:center">
      <div style="font-size:28px;margin-bottom:10px">🧠</div>
      <div style="font-size:13px;font-weight:800;color:var(--tx);margin-bottom:6px">AI 决策</div>
      <div style="font-size:11px;color:var(--tx3);line-height:1.6">LLM 分析生态，自主决定发什么任务、给多少奖励</div>
    </div>
    <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:20px 16px;text-align:center">
      <div style="font-size:28px;margin-bottom:10px">⚡</div>
      <div style="font-size:13px;font-weight:800;color:var(--tx);margin-bottom:6px">自动执行</div>
      <div style="font-size:11px;color:var(--tx3);line-height:1.6">直接调合约发任务、核查完成、链上打款，零人工</div>
    </div>
    <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:20px 16px;text-align:center">
      <div style="font-size:28px;margin-bottom:10px">🔒</div>
      <div style="font-size:13px;font-weight:800;color:var(--tx);margin-bottom:6px">资金安全</div>
      <div style="font-size:11px;color:var(--tx3);line-height:1.6">预算锁在 ERC-8183 合约，Agent 私钥只能出 Gas</div>
    </div>
  </div>

  <!-- Agent 卡片 + 表单 两栏 -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:start">

    <!-- 左栏：4个 Agent 详细介绍 -->
    <div>
      <div style="font-size:11px;font-weight:700;letter-spacing:2px;color:var(--tx3);text-transform:uppercase;margin-bottom:20px">选择你的 Agent</div>

      <div style="display:flex;flex-direction:column;gap:12px">

        <div class="dg-agent-card" id="dga-hunter" onclick="dgSelectAgent('hunter')" style="padding:20px;background:rgba(255,255,255,.03);border:1.5px solid rgba(255,255,255,.08);border-radius:16px;cursor:pointer;transition:all .2s">
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px">
            <div style="width:40px;height:40px;background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.3);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px">🔴</div>
            <div>
              <div style="font-size:14px;font-weight:800;color:var(--tx)">猎手 Hunter</div>
              <div style="font-size:10px;color:#f87171;font-weight:600;letter-spacing:1px">AGGRESSIVE · 拉新优先</div>
            </div>
          </div>
          <div style="font-size:12px;color:var(--tx2);line-height:1.7">激进策略，持续发布高频小额任务，快速积累持币人数和买入量。适合新盘冷启动、破零阶段。</div>
          <div style="display:flex;gap:8px;margin-top:12px;flex-wrap:wrap">
            <span style="font-size:10px;padding:3px 8px;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.2);border-radius:20px;color:#f87171">持仓任务</span>
            <span style="font-size:10px;padding:3px 8px;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.2);border-radius:20px;color:#f87171">买入任务</span>
            <span style="font-size:10px;padding:3px 8px;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.2);border-radius:20px;color:#f87171">早鸟任务</span>
          </div>
        </div>

        <div class="dg-agent-card" id="dga-strategist" onclick="dgSelectAgent('strategist')" style="padding:20px;background:rgba(255,255,255,.03);border:1.5px solid rgba(255,255,255,.08);border-radius:16px;cursor:pointer;transition:all .2s">
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px">
            <div style="width:40px;height:40px;background:rgba(234,179,8,.1);border:1px solid rgba(234,179,8,.3);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px">🟡</div>
            <div>
              <div style="font-size:14px;font-weight:800;color:var(--tx)">军师 Strategist</div>
              <div style="font-size:10px;color:#fbbf24;font-weight:600;letter-spacing:1px">ADAPTIVE · 数据驱动</div>
            </div>
          </div>
          <div style="font-size:12px;color:var(--tx2);line-height:1.7">实时分析链上数据，动态调整任务强度和奖励。行情好时加码，行情差时保守。最省预算的策略。</div>
          <div style="display:flex;gap:8px;margin-top:12px;flex-wrap:wrap">
            <span style="font-size:10px;padding:3px 8px;background:rgba(234,179,8,.1);border:1px solid rgba(234,179,8,.2);border-radius:20px;color:#fbbf24">动态奖励</span>
            <span style="font-size:10px;padding:3px 8px;background:rgba(234,179,8,.1);border:1px solid rgba(234,179,8,.2);border-radius:20px;color:#fbbf24">自适应频率</span>
          </div>
        </div>

        <div class="dg-agent-card" id="dga-herald" onclick="dgSelectAgent('herald')" style="padding:20px;background:rgba(255,255,255,.03);border:1.5px solid rgba(255,255,255,.08);border-radius:16px;cursor:pointer;transition:all .2s">
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px">
            <div style="width:40px;height:40px;background:rgba(52,211,153,.1);border:1px solid rgba(52,211,153,.3);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px">🟢</div>
            <div>
              <div style="font-size:14px;font-weight:800;color:var(--tx)">传令官 Herald</div>
              <div style="font-size:10px;color:#34d399;font-weight:600;letter-spacing:1px">NARRATIVE · 故事叙事</div>
            </div>
          </div>
          <div style="font-size:12px;color:var(--tx2);line-height:1.7">构建连续故事线，每个任务有剧情背景和仪式感。提升社区归属感，适合想做长期品牌的项目。</div>
          <div style="display:flex;gap:8px;margin-top:12px;flex-wrap:wrap">
            <span style="font-size:10px;padding:3px 8px;background:rgba(52,211,153,.1);border:1px solid rgba(52,211,153,.2);border-radius:20px;color:#34d399">故事章节</span>
            <span style="font-size:10px;padding:3px 8px;background:rgba(52,211,153,.1);border:1px solid rgba(52,211,153,.2);border-radius:20px;color:#34d399">推荐任务</span>
          </div>
        </div>

        <div class="dg-agent-card" id="dga-custom" onclick="dgSelectAgent('custom')" style="padding:20px;background:rgba(255,255,255,.03);border:1.5px solid rgba(255,255,255,.08);border-radius:16px;cursor:pointer;transition:all .2s">
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px">
            <div style="width:40px;height:40px;background:rgba(124,58,237,.1);border:1px solid rgba(124,58,237,.3);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px">⚙️</div>
            <div>
              <div style="font-size:14px;font-weight:800;color:var(--tx)">自定义</div>
              <div style="font-size:10px;color:var(--p);font-weight:600;letter-spacing:1px">CUSTOM · 完全掌控</div>
            </div>
          </div>
          <div style="font-size:12px;color:var(--tx2);line-height:1.7">手动设置所有任务参数，Agent 严格按你的策略执行。适合有明确运营方案的进阶用户。</div>
          <div style="display:flex;gap:8px;margin-top:12px;flex-wrap:wrap">
            <span style="font-size:10px;padding:3px 8px;background:rgba(124,58,237,.1);border:1px solid rgba(124,58,237,.2);border-radius:20px;color:var(--p)">自定义门槛</span>
            <span style="font-size:10px;padding:3px 8px;background:rgba(124,58,237,.1);border:1px solid rgba(124,58,237,.2);border-radius:20px;color:var(--p)">手动参数</span>
          </div>
        </div>

      </div>
    </div><!-- /左栏 -->

    <!-- 右栏：委托表单 -->
    <div style="position:sticky;top:90px">

      <!-- 步骤指示器 -->
      <div style="display:flex;gap:0;margin-bottom:24px">
        <div id="dgs-1" style="flex:1;padding:12px 14px;background:rgba(124,58,237,.12);border:1px solid rgba(124,58,237,.35);border-right:none;border-radius:10px 0 0 10px">
          <div style="font-size:10px;font-weight:700;color:var(--p);letter-spacing:1px">STEP 1</div>
          <div style="font-size:12px;font-weight:700;color:var(--tx);margin-top:2px">配置参数</div>
        </div>
        <div id="dgs-2" style="flex:1;padding:12px 14px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:0 10px 10px 0;opacity:.5">
          <div style="font-size:10px;font-weight:700;color:var(--tx3);letter-spacing:1px">STEP 2</div>
          <div style="font-size:12px;font-weight:700;color:var(--tx3);margin-top:2px">签名（共2次）</div>
        </div>
      </div>

      <div id="dg-form">
        <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:16px;padding:20px;margin-bottom:16px">
          <div style="font-size:10px;font-weight:700;letter-spacing:1.5px;color:var(--tx3);text-transform:uppercase;margin-bottom:14px">基础配置</div>
          <div style="display:flex;flex-direction:column;gap:12px">
            <div>
              <label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:5px">目标代币地址 *</label>
              <input class="fi" id="d0" placeholder="0x..." style="width:100%;font-family:monospace;font-size:12px">
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
              <div>
                <label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:5px">预算 BNB *</label>
                <input class="fi" id="d1" type="number" placeholder="0.05" min="0.01" step="0.01" oninput="dgCalc()">
                <div style="font-size:10px;color:var(--su);margin-top:3px">建议 ≥ 0.05 BNB</div>
              </div>
              <div>
                <label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:5px">运营时长（分钟）</label>
                <input class="fi" id="d2" type="number" placeholder="120" min="10" step="10" value="120">
              </div>
            </div>
            <div>
              <label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:5px">Telegram 通知（选填）</label>
              <input class="fi" id="d4" placeholder="@your_channel">
            </div>
          </div>
        </div>

        <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:16px;padding:20px;margin-bottom:16px">
          <div style="font-size:10px;font-weight:700;letter-spacing:1.5px;color:var(--tx3);text-transform:uppercase;margin-bottom:14px">任务门槛（选填）</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
            <div><label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:5px">最低持币量</label><input class="fi" id="th-amount" type="number" placeholder="0"></div>
            <div><label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:5px">最低买入 BNB</label><input class="fi" id="th-buy" type="number" placeholder="0" step="0.001"></div>
            <div><label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:5px">最短持仓（秒）</label><input class="fi" id="th-hold" type="number" placeholder="300" min="120" max="3600"></div>
            <div><label style="font-size:11px;color:var(--tx3);display:block;margin-bottom:5px">最低推荐数</label><input class="fi" id="th-ref" type="number" placeholder="0"></div>
          </div>
        </div>

        <!-- 预算预览 -->
        <div style="background:rgba(124,58,237,.07);border:1px solid rgba(124,58,237,.18);border-radius:16px;padding:16px;margin-bottom:16px">
          <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:8px"><span style="color:var(--tx3)">预计可发任务</span><span style="font-weight:700;color:var(--tx)" id="dg-est-tasks">—</span></div>
          <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:8px"><span style="color:var(--tx3)">每任务均奖励</span><span style="color:var(--p)" id="dg-est-reward">—</span></div>
          <div style="display:flex;justify-content:space-between;font-size:12px"><span style="color:var(--tx3)">平台手续费 5%</span><span style="color:var(--tx3)" id="dg-est-fee">—</span></div>
        </div>

        <button class="btnp" style="width:100%;padding:14px;font-size:14px;font-weight:800" id="dg-submit-btn" onclick="submitDelegate()">
          🤖 开始委托 → <span id="df-btn-name">请先选择 Agent</span>
