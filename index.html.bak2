      </div><!-- /dg-form -->

      <!-- 进度 -->
      <div id="dg-progress" style="display:none">
        <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:20px;padding:28px;text-align:center">
          <div style="font-size:32px;margin-bottom:12px" id="dg-prog-icon">⏳</div>
          <div style="font-size:16px;font-weight:800;color:var(--tx);margin-bottom:6px" id="dg-prog-title">处理中</div>
          <div style="font-size:13px;color:var(--tx2)" id="dg-prog-desc">请在 MetaMask 确认</div>
          <div style="display:flex;flex-direction:column;gap:8px;margin-top:20px;text-align:left">
            <div id="dgps-1" style="display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:10px;background:rgba(255,255,255,.04)"><span id="dgps-1-ico">⏳</span><span style="font-size:12px;color:var(--tx2)">createJob（不扣费）</span></div>
            <div id="dgps-2" style="display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:10px;background:rgba(255,255,255,.04);opacity:.4"><span id="dgps-2-ico">⏳</span><span style="font-size:12px;color:var(--tx2)">fund（扣款 BNB）</span></div>
            <div id="dgps-3" style="display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:10px;background:rgba(255,255,255,.04);opacity:.4"><span id="dgps-3-ico">⏳</span><span style="font-size:12px;color:var(--tx2)">Agent 激活</span></div>
