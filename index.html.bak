<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>MemeBounty — AI Agent 链上激励</title>
<script src="https://cdn.jsdelivr.net/npm/ethers@6.9.0/dist/ethers.umd.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#f8f9fc;--g1:#ffffff;--g2:#f3f4f6;--bd:#e5e7eb;--bd2:rgba(124,58,237,.25);--tx:#1a1a2e;--su:#6b7280;--p:#7c3aed;--p2:#6d28d9;--p3:#5b21b6;--gr:#059669;--re:#dc2626;--ye:#d97706;--bl:#2563eb}
body{font-family:-apple-system,'SF Pro Display','PingFang SC',sans-serif;background:var(--bg);color:var(--tx);min-height:100vh;overflow-x:hidden}
#cvs{position:fixed;inset:0;z-index:0;pointer-events:none}
.orb{position:fixed;border-radius:50%;filter:blur(100px);pointer-events:none;z-index:0;opacity:.2}
.o1{width:500px;height:500px;background:radial-gradient(#7c3aed,transparent 70%);top:-150px;left:-150px}
.o2{width:400px;height:400px;background:radial-gradient(#1d4ed8,transparent 70%);bottom:-100px;right:-100px}
nav{position:fixed;top:0;left:0;right:0;height:60px;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:0 28px;background:rgba(6,6,8,.85);backdrop-filter:blur(20px);border-bottom:1px solid var(--bd)}
.logo{display:flex;align-items:center;gap:10px}
.li{width:28px;height:28px;background:linear-gradient(135deg,#7c3aed,#4f1db5);border-radius:7px;display:grid;place-items:center;font-size:13px}
.lt{font-size:15px;font-weight:700;background:linear-gradient(135deg,#c4b5fd,#7c3aed);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.nls{display:flex;gap:2px}
.nl{padding:6px 15px;border-radius:7px;font-size:13px;color:var(--su);cursor:pointer;transition:all .2s;border:none;background:transparent;font-family:inherit}
.nl:hover,.nl.on{color:var(--tx);background:var(--g2)}.nl.on{color:var(--p)}
.wbtn{background:linear-gradient(135deg,var(--p2),var(--p3));color:#fff;border:none;border-radius:8px;padding:7px 16px;font-size:13px;font-weight:600;cursor:pointer;transition:opacity .2s}
.wbtn:hover{opacity:.85}
.wi{display:none;align-items:center;gap:7px;font-size:12px;background:var(--g1);border:1px solid var(--bd);border-radius:8px;padding:5px 12px}
.wd{width:6px;height:6px;border-radius:50%;background:var(--gr);box-shadow:0 0 6px var(--gr)}
.pw{display:none;position:relative;z-index:1;padding:72px 0 80px}.pw.on{display:block}
.page{display:none;position:relative;z-index:1;padding:72px 28px 80px;max-width:1200px;margin:0 auto}.page.on{display:block}
.hero{padding:60px 28px 40px;max-width:1200px;margin:0 auto;text-align:center}
.hb{display:inline-flex;align-items:center;gap:8px;background:rgba(167,139,250,.1);border:1px solid rgba(167,139,250,.2);border-radius:20px;padding:5px 16px;font-size:12px;color:var(--p);margin-bottom:24px}
.hb::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--p);box-shadow:0 0 6px var(--p);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
h1.ht{font-size:clamp(36px,6vw,64px);font-weight:900;letter-spacing:-2.5px;line-height:1.05;margin-bottom:18px}
.gd{background:linear-gradient(135deg,#c4b5fd 0%,#7c3aed 45%,#60a5fa 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.hs{font-size:16px;color:var(--su);max-width:480px;margin:0 auto 32px;line-height:1.7}
.hbs{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin-bottom:48px}
.btnp{background:linear-gradient(135deg,var(--p2),var(--p3));color:#fff;padding:11px 24px;border-radius:9px;font-size:14px;font-weight:600;border:none;cursor:pointer;transition:transform .2s,box-shadow .2s}
.btnp:hover{transform:translateY(-2px);box-shadow:0 8px 20px rgba(124,58,237,.35)}
.btns{background:var(--g1);color:var(--tx);border:1px solid var(--bd);padding:11px 24px;border-radius:9px;font-size:14px;font-weight:600;cursor:pointer;transition:border-color .2s,transform .2s}
.btns:hover{border-color:var(--p);transform:translateY(-2px)}
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;max-width:1000px;margin:0 auto}
.stat{background:var(--g1);border:1px solid var(--bd);border-radius:14px;padding:20px;text-align:center;backdrop-filter:blur(10px);transition:border-color .3s}
.stat:hover{border-color:var(--bd2)}
.sn{font-size:28px;font-weight:900;letter-spacing:-1px;background:linear-gradient(135deg,#c4b5fd,#60a5fa);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.sl{font-size:11px;color:var(--su);margin-top:4px}
.sec{padding:0 28px;max-width:1200px;margin:0 auto}

/* ── HOW PAGE ── */
.how-hero{padding:80px 28px 60px;max-width:800px;margin:0 auto;text-align:center}
.how-label{font-size:11px;font-weight:700;color:var(--su);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:20px}
h2.how-title{font-size:clamp(32px,5vw,60px);font-weight:900;letter-spacing:-2px;line-height:1.05;margin-bottom:20px}
.how-sub{font-size:16px;color:var(--su);line-height:1.8}
.how-steps{max-width:900px;margin:0 auto;padding:0 28px 80px;position:relative}
.hs-line{position:absolute;left:calc(28px + 48px + 28px);top:0;bottom:0;width:1px;background:linear-gradient(180deg,transparent,rgba(167,139,250,.2) 10%,rgba(167,139,250,.2) 90%,transparent);pointer-events:none}
.hs-item{display:grid;grid-template-columns:48px 32px 1fr;gap:0 24px;padding:48px 0;align-items:start;animation:fadeUp .6s ease both;animation-delay:var(--d)}
@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:none}}
.hs-item.rev .hs-body{grid-column:3}
.hs-num{font-size:11px;font-weight:800;color:rgba(167,139,250,.35);letter-spacing:.5px;padding-top:4px;text-align:right}
.hs-dot{width:12px;height:12px;border-radius:50%;background:var(--p2);box-shadow:0 0 12px rgba(124,58,237,.5);margin-top:3px;flex-shrink:0;position:relative;z-index:1;justify-self:center}
.hs-body{padding-left:0}
.hs-tag{font-size:10px;font-weight:700;color:var(--p);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:8px}
.hs-title{font-size:clamp(22px,3vw,36px);font-weight:800;letter-spacing:-1px;margin-bottom:12px;line-height:1.1}
.hs-desc{font-size:14px;color:var(--su);line-height:1.8;margin-bottom:16px;max-width:560px}
.hs-pill{display:inline-flex;align-items:center;background:rgba(124,58,237,.08);border:1px solid rgba(124,58,237,.2);color:var(--p);font-size:12px;font-weight:600;padding:5px 14px;border-radius:20px}
.how-modes{padding:0 28px 80px;max-width:1000px;margin:0 auto}
.hm-label{font-size:11px;font-weight:700;color:var(--su);text-transform:uppercase;letter-spacing:1px;margin-bottom:32px;text-align:center}
.hm-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.hm-card{background:var(--g1);border:1px solid var(--bd);border-radius:20px;padding:28px;backdrop-filter:blur(12px);transition:border-color .3s}
.hm-card.hm-mbt{border-color:rgba(167,139,250,.15)}
.hm-card.hm-dlg{border-color:rgba(59,130,246,.12)}
.hm-card:hover{transform:translateY(-3px)}
.hm-head{display:flex;align-items:center;gap:14px;margin-bottom:24px}
.hm-icon{font-size:28px;width:52px;height:52px;background:var(--g2);border-radius:14px;display:grid;place-items:center}
.hm-mode{font-size:17px;font-weight:800;letter-spacing:-.3px}
.hm-mode-sub{font-size:12px;color:var(--su);margin-top:2px}
.hm-flow{display:flex;flex-direction:column;gap:4px;margin-bottom:20px}
.hm-node{background:rgba(255,255,255,.04);border-radius:9px;padding:10px 14px;font-size:13px;border:1px solid var(--bd)}
.hm-node-hl{background:rgba(124,58,237,.08);border-color:rgba(124,58,237,.2);color:var(--p);font-weight:600}
.hm-arrow{text-align:center;font-size:12px;color:rgba(167,139,250,.4);padding:2px 0}
.hm-note{font-size:12px;color:var(--su);text-align:center;padding-top:8px;border-top:1px solid var(--bd)}
.how-gate{max-width:1000px;margin:0 auto;padding:0 28px 100px;display:grid;grid-template-columns:1fr auto;gap:48px;align-items:center}
.hg-tag{font-size:11px;font-weight:700;color:var(--p);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:16px}
.hg-title{font-size:clamp(28px,4vw,48px);font-weight:900;letter-spacing:-1.5px;margin-bottom:16px;line-height:1.05}
.hg-desc{font-size:15px;color:var(--su);line-height:1.8;max-width:520px}
.hg-hl{color:var(--p);font-weight:700}
.hg-chips{display:flex;flex-wrap:wrap;gap:8px;margin-top:20px}
.hg-chip{background:var(--g1);border:1px solid var(--bd);border-radius:20px;padding:5px 13px;font-size:12px;color:var(--su)}
.hg-right{display:grid;grid-template-columns:1fr 1fr;gap:14px;min-width:220px}
.hg-stat{background:var(--g1);border:1px solid var(--bd);border-radius:14px;padding:20px;text-align:center;backdrop-filter:blur(10px)}
.hg-snum{font-size:26px;font-weight:900;letter-spacing:-1px;background:linear-gradient(135deg,#c4b5fd,#60a5fa);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.hg-slbl{font-size:11px;color:var(--su);margin-top:4px}
@media(max-width:768px){.hm-grid,.how-gate{grid-template-columns:1fr}.hs-line{display:none}.hs-item{grid-template-columns:32px 1fr;gap:0 16px}.hs-num{display:none}.hg-right{grid-template-columns:repeat(4,1fr)}}

/* FLYWHEEL */
.fw{padding:60px 28px;max-width:1100px;margin:0 auto}
.fw-title{text-align:center;font-size:13px;font-weight:700;color:var(--su);text-transform:uppercase;letter-spacing:.8px;margin-bottom:40px}
.fw-row{display:flex;align-items:stretch;gap:0;position:relative}
.fw-row::before{content:'';position:absolute;top:36px;left:calc(16.6% + 16px);right:calc(16.6% + 16px);height:1px;background:linear-gradient(90deg,transparent,rgba(167,139,250,.3) 20%,rgba(167,139,250,.3) 80%,transparent);pointer-events:none}
.fw-step{flex:1;display:flex;flex-direction:column;align-items:center;text-align:center;padding:0 8px;position:relative}
.fw-ico{width:72px;height:72px;border-radius:50%;border:1px solid var(--bd2);background:var(--g1);backdrop-filter:blur(10px);display:grid;place-items:center;font-size:26px;margin-bottom:16px;position:relative;z-index:1;transition:border-color .3s,transform .3s}
.fw-step:hover .fw-ico{border-color:var(--p);transform:scale(1.08)}
.fw-ico.hl{border-color:rgba(167,139,250,.5);background:rgba(124,58,237,.08)}
.fw-step-title{font-size:13px;font-weight:700;margin-bottom:6px}
.fw-step-desc{font-size:12px;color:var(--su);line-height:1.6;max-width:130px}
.fw-arr{display:flex;align-items:center;padding-top:22px;color:rgba(167,139,250,.35);font-size:20px;flex-shrink:0;margin:0 -4px}
/* 双向飞轮 */
.fw2{padding:32px 28px 0;max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:20px}
.fw2-card{background:var(--g1);border:1px solid var(--bd);border-radius:16px;padding:24px;backdrop-filter:blur(10px);transition:border-color .3s}
.fw2-card:hover{border-color:var(--bd2)}
.fw2-label{font-size:11px;font-weight:700;color:var(--su);text-transform:uppercase;letter-spacing:.5px;margin-bottom:14px;display:flex;align-items:center;gap:8px}
.fw2-label::before{content:'';width:6px;height:6px;border-radius:50%}
.fw2-card.mbt .fw2-label::before{background:var(--p);box-shadow:0 0 6px var(--p)}
.fw2-card.dlg .fw2-label::before{background:var(--bl);box-shadow:0 0 6px var(--bl)}
.fw2-flow{display:flex;flex-direction:column;gap:8px}
.fw2-item{display:flex;align-items:center;gap:10px;font-size:13px;padding:8px 12px;border-radius:8px;background:rgba(255,255,255,.03)}
.fw2-item-ico{font-size:16px;width:28px;text-align:center;flex-shrink:0}
.fw2-arr{text-align:center;color:rgba(167,139,250,.3);font-size:16px;padding:2px 0}
.stop{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:10px}
.stt{font-size:18px;font-weight:700;letter-spacing:-.3px}
.fts{display:flex;gap:6px;flex-wrap:wrap}
.ft{padding:5px 13px;border-radius:20px;font-size:12px;font-weight:600;border:1px solid var(--bd);background:transparent;color:var(--su);cursor:pointer;transition:all .2s}
.ft.on{background:var(--p2);color:#fff;border-color:var(--p2)}
.tg{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
.tc{background:#fff;border:1px solid #e5e7eb;box-shadow:0 2px 12px rgba(0,0,0,.07);border-radius:14px;padding:20px;cursor:pointer;transition:all .25s;backdrop-filter:blur(12px);position:relative;overflow:hidden}
.tc:hover{border-color:var(--bd2);transform:translateY(-2px);background:var(--g2)}
.tch{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px}
.cbg{font-size:10px;font-weight:700;letter-spacing:.4px;text-transform:uppercase;background:rgba(167,139,250,.12);color:var(--p);padding:3px 9px;border-radius:20px;border:1px solid rgba(167,139,250,.18)}
.cbg.ag{background:rgba(59,130,246,.1);color:var(--bl);border-color:rgba(59,130,246,.2)}
.cs{font-size:10px;padding:3px 9px;border-radius:20px;font-weight:600}
.cs.go{background:rgba(16,185,129,.08);color:var(--gr);border:1px solid rgba(16,185,129,.18)}
.cs.no{background:rgba(239,68,68,.07);color:var(--re);border:1px solid rgba(239,68,68,.15)}
.cti{font-size:14px;font-weight:700;margin-bottom:3px;line-height:1.3}
.ctk{font-size:11px;color:var(--su);font-family:monospace;margin-bottom:8px}
.cde{font-size:12px;color:var(--su);margin-bottom:14px;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.crw{font-size:24px;font-weight:900;letter-spacing:-1px;background:linear-gradient(135deg,#c4b5fd,#60a5fa);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.crl{font-size:11px;color:var(--su);margin-top:2px;margin-bottom:12px}
.cbr{height:2px;background:rgba(255,255,255,.05);border-radius:2px;margin-bottom:7px}
.cbf{height:100%;background:linear-gradient(90deg,var(--p2),var(--p));border-radius:2px}
.cft{display:flex;justify-content:space-between;font-size:11px;color:var(--su);margin-bottom:12px}
.cb{width:100%;padding:9px;border-radius:8px;font-size:13px;font-weight:600;background:linear-gradient(135deg,var(--p2),var(--p3));color:#fff;border:none;cursor:pointer;transition:opacity .2s,transform .15s}
.cb:hover:not(:disabled){opacity:.85;transform:translateY(-1px)}
.cb:disabled{opacity:.25;cursor:not-allowed}
.cb.dn{background:rgba(16,185,129,.1);color:var(--gr);border:1px solid rgba(16,185,129,.2)}

/* ── DELEGATE TABS ── */
.dtabs{display:flex;gap:8px;margin-bottom:0;border-bottom:1px solid var(--bd);padding-bottom:0}
.dtab{padding:10px 20px;font-size:14px;font-weight:600;color:var(--su);border:none;background:transparent;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .2s;font-family:inherit}
.dtab:hover{color:var(--tx)}
.dtab.on{color:var(--p);border-bottom-color:var(--p)}
/* AI PUBLISH */
.ai-step{margin-bottom:0}
.ai-step-num{font-size:11px;font-weight:800;color:var(--p);letter-spacing:1px;text-transform:uppercase;margin-bottom:20px;padding:12px 0;border-bottom:1px solid var(--bd)}
.ai-examples{display:flex;flex-wrap:wrap;gap:8px;margin-top:12px}
.ai-ex-label{font-size:11px;color:var(--su);width:100%;margin-bottom:4px}
.ai-ex{background:var(--g1);border:1px solid var(--bd);border-radius:20px;padding:6px 14px;font-size:12px;color:var(--su);cursor:pointer;transition:all .2s;font-family:inherit}
.ai-ex:hover{border-color:var(--p);color:var(--p);background:rgba(124,58,237,.06)}
.ai-loading{display:flex;flex-direction:column;align-items:center;gap:16px;padding:48px;color:var(--su);font-size:14px}
.ai-spinner{width:36px;height:36px;border:2px solid var(--bd);border-top-color:var(--p);border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.ai-preview{background:rgba(124,58,237,.05);border:1px solid rgba(124,58,237,.2);border-radius:14px;padding:20px}
.ai-preview-head{display:flex;align-items:center;gap:12px;margin-bottom:14px}
.ai-type-badge{font-size:11px;font-weight:700;background:rgba(167,139,250,.12);color:var(--p);border:1px solid rgba(167,139,250,.2);padding:4px 10px;border-radius:20px}
.ai-reasoning{font-size:12px;color:var(--su);flex:1}
.ai-preview-title{font-size:20px;font-weight:800;letter-spacing:-.5px;margin-bottom:8px}
.ai-preview-desc{font-size:14px;color:var(--su);line-height:1.7;margin-bottom:16px}
.ai-params{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.ai-param{background:rgba(255,255,255,.04);border-radius:8px;padding:10px 12px}
.ai-param-k{font-size:11px;color:var(--su);margin-bottom:3px}
.ai-param-v{font-size:14px;font-weight:700}

.dh{padding:60px 28px 40px;max-width:700px;margin:0 auto;text-align:center}
.dh h2{font-size:36px;font-weight:800;letter-spacing:-1px;margin-bottom:12px}
.dh p{font-size:15px;color:var(--su);line-height:1.7}
.dc{display:grid;grid-template-columns:1fr 1fr;gap:14px;max-width:900px;margin:0 auto 48px;padding:0 28px}
.dcard{background:var(--g1);border:1px solid var(--bd);border-radius:14px;padding:22px;backdrop-filter:blur(10px);transition:border-color .3s}
.dcard:hover{border-color:var(--bd2)}
.dci{font-size:26px;margin-bottom:10px}
.dcard h3{font-size:14px;font-weight:700;margin-bottom:6px}
.dcard p{font-size:12px;color:var(--su);line-height:1.6}
.df{max-width:560px;margin:0 auto;padding:0 28px}
.fg{margin-bottom:16px}
.fl{font-size:11px;font-weight:700;color:var(--su);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;display:block}
.fi,.fs{width:100%;padding:10px 13px;background:rgba(255,255,255,.04);border:1px solid var(--bd);border-radius:8px;font-size:13px;color:var(--tx);font-family:inherit;outline:none;transition:border-color .2s}
.fi:focus,.fs:focus{border-color:var(--p)}
.fs option{background:#13131a}
.fr2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.sb{background:rgba(124,58,237,.06);border:1px solid rgba(124,58,237,.2);border-radius:8px;padding:12px 14px;font-size:13px;color:var(--su);line-height:1.9;margin-bottom:16px}
.sb span{color:var(--tx);font-weight:600}
.dlrow{background:var(--g1);border:1px solid var(--bd);border-radius:12px;padding:16px 18px;margin-bottom:10px;display:flex;align-items:center;justify-content:space-between;gap:12px;backdrop-filter:blur(10px);transition:border-color .3s}
.dlrow:hover{border-color:var(--bd2)}
.dlinfo h4{font-size:13px;font-weight:700;margin-bottom:4px}
.dlmeta{font-size:12px;color:var(--su)}
.bsm{padding:5px 12px;border-radius:7px;font-size:12px;font-weight:600;border:1px solid var(--bd);background:transparent;color:var(--su);cursor:pointer;transition:all .2s}
.bsm:hover{border-color:var(--re);color:var(--re)}
.dg{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:24px}
.dk{background:var(--g1);border:1px solid var(--bd);border-radius:14px;padding:20px;backdrop-filter:blur(10px)}
.dk h3{font-size:11px;font-weight:700;color:var(--su);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px}
.dbig{font-size:32px;font-weight:900;letter-spacing:-1.5px;background:linear-gradient(135deg,#c4b5fd,#60a5fa);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.dlbl{font-size:12px;color:var(--su);margin-top:3px}
.lw{background:var(--g1);border:1px solid var(--bd);border-radius:14px;overflow:hidden;backdrop-filter:blur(10px)}
.lhd{padding:13px 18px;border-bottom:1px solid var(--bd);display:flex;align-items:center;justify-content:space-between}
.lt2{font-size:13px;font-weight:700;display:flex;align-items:center;gap:8px}
.ldot{width:7px;height:7px;border-radius:50%;background:var(--gr);box-shadow:0 0 8px var(--gr);animation:pulse 2s infinite}
.lb{max-height:420px;overflow-y:auto;font-size:12px}
.le{padding:10px 18px;border-bottom:1px solid rgba(255,255,255,.03);display:grid;grid-template-columns:auto 1fr auto;gap:10px;align-items:start}
.le:last-child{border-bottom:none}
.ltm{color:var(--su);white-space:nowrap;font-size:11px;margin-top:1px;font-family:monospace}
.ltg{font-size:10px;font-weight:700;padding:2px 7px;border-radius:10px;white-space:nowrap}
.tgc{background:rgba(16,185,129,.1);color:var(--gr)}
.tgx{background:rgba(239,68,68,.08);color:var(--re)}
.tgw{background:rgba(107,107,138,.1);color:var(--su)}
.ms{margin-bottom:32px}
.mst{font-size:11px;font-weight:700;color:var(--su);text-transform:uppercase;letter-spacing:.5px;margin-bottom:14px}
.pw2{display:none;position:fixed;inset:0;z-index:400;background:rgba(0,0,0,.65);backdrop-filter:blur(8px);align-items:center;justify-content:center}
.pw2.on{display:flex}
.pn{background:rgba(10,10,16,.97);border:1px solid var(--bd);border-radius:18px;padding:28px;width:480px;max-width:95vw;max-height:88vh;overflow-y:auto}
.pc{float:right;background:var(--g1);border:1px solid var(--bd);border-radius:6px;padding:3px 10px;font-size:12px;cursor:pointer;color:var(--su)}
.pn h3{font-size:18px;font-weight:700;margin-bottom:20px;clear:both}
.pr{display:flex;justify-content:space-between;padding:9px 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:13px}
.pk{color:var(--su)}.pv{color:var(--tx);font-weight:500;text-align:right;max-width:65%;word-break:break-all}
.tw{position:fixed;bottom:22px;right:22px;z-index:999;display:flex;flex-direction:column;gap:8px}
.toast{background:rgba(12,12,18,.95);border:1px solid var(--bd);border-radius:10px;padding:12px 16px;font-size:13px;display:flex;align-items:center;gap:10px;min-width:250px;backdrop-filter:blur(16px);animation:tIn .25s ease}
.toast.s{border-color:rgba(16,185,129,.4)}.toast.e{border-color:rgba(239,68,68,.4)}.toast.i{border-color:rgba(167,139,250,.4)}
@keyframes tIn{from{transform:translateX(110%);opacity:0}to{transform:none;opacity:1}}
.empty{text-align:center;padding:44px;color:var(--su);font-size:14px;background:var(--g1);border:1px solid var(--bd);border-radius:14px}
@media(max-width:900px){.tg,.dc,.dg,.stats{grid-template-columns:repeat(2,1fr)}}
@media(max-width:600px){.tg,.dc,.dg,.stats{grid-template-columns:1fr}.nls{display:none}.df{padding-left:16px;padding-right:16px}.sec{padding-left:16px;padding-right:16px}}

/* ── ERC-8183 ── */
.how-erc{max-width:1000px;margin:0 auto;padding:0 28px 100px;text-align:center}
.erc-label{font-size:11px;font-weight:700;color:#7c3aed;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:20px}
.erc-title{font-size:clamp(28px,4vw,48px);font-weight:900;letter-spacing:-1.5px;margin-bottom:16px;line-height:1.05;color:#1a1a2e}
.erc-sub{font-size:16px;color:#6b7280;line-height:1.8;max-width:580px;margin:0 auto 48px}
.erc-states{display:flex;align-items:center;justify-content:center;gap:8px;flex-wrap:wrap;margin-bottom:16px}
.erc-state{text-align:center;padding:16px 20px;background:#fff;border:1px solid #e5e7eb;border-radius:12px;min-width:110px;box-shadow:0 2px 8px rgba(0,0,0,.06)}
.erc-s-dot{width:10px;height:10px;border-radius:50%;margin:0 auto 8px}
.s-open .erc-s-dot{background:#94a3b8}
.s-funded .erc-s-dot{background:#3b82f6;box-shadow:0 0 8px rgba(59,130,246,.4)}
.s-submitted .erc-s-dot{background:#f59e0b;box-shadow:0 0 8px rgba(245,158,11,.4)}
.s-completed .erc-s-dot{background:#10b981;box-shadow:0 0 8px rgba(16,185,129,.4)}
.erc-s-name{font-size:13px;font-weight:800;margin-bottom:4px;color:#1a1a2e}
.erc-s-desc{font-size:11px;color:#6b7280;line-height:1.5}
.erc-arrow{font-size:20px;color:#d1d5db;line-height:60px}
.erc-exits{display:flex;flex-direction:column;gap:8px;margin:16px auto 48px;max-width:600px}
.erc-exit{background:#fef9ff;border:1px solid #e9d5ff;border-radius:8px;padding:10px 16px;font-size:13px;color:#6b7280;text-align:left}
.erc-exit strong{color:#7c3aed}
.erc-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:48px;text-align:left}
.erc-card{background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:24px;box-shadow:0 2px 12px rgba(0,0,0,.06);transition:box-shadow .2s}
.erc-card:hover{box-shadow:0 6px 24px rgba(0,0,0,.1)}
.erc-card-ico{font-size:28px;margin-bottom:12px}
.erc-card-title{font-size:16px;font-weight:800;color:#1a1a2e;margin-bottom:8px}
.erc-card-desc{font-size:13px;color:#6b7280;line-height:1.7}
.erc-contracts{background:#f9fafb;border:1px solid #e5e7eb;border-radius:16px;padding:24px;text-align:left}
.erc-ct-label{font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;margin-bottom:16px}
.erc-ct-row{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid #f3f4f6;flex-wrap:wrap}
.erc-ct-row:last-child{border-bottom:none}
.erc-ct-name{font-size:13px;font-weight:700;color:#1a1a2e;min-width:160px}
.erc-ct-addr{font-family:monospace;font-size:11px;color:#6b7280;flex:1;word-break:break-all}
.erc-ct-link{font-size:12px;color:#7c3aed;text-decoration:none;font-weight:600;white-space:nowrap}
.erc-ct-link:hover{text-decoration:underline}
@media(max-width:768px){.erc-cards{grid-template-columns:1fr}.erc-arrow{display:none}}

/* ── LAUNCH PAGE ── */
.lh-hero{padding:80px 28px 60px;text-align:center;max-width:700px;margin:0 auto}
.lh-tag{font-size:11px;font-weight:700;color:#7c3aed;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:20px}
h1.lh-title{font-size:clamp(40px,7vw,80px);font-weight:900;letter-spacing:-3px;line-height:.95;margin-bottom:20px;color:#1a1a2e}
.lh-grad{background:linear-gradient(135deg,#7c3aed,#3b82f6);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.lh-sub{font-size:16px;color:#6b7280;line-height:1.8;margin-bottom:40px}
.lh-steps{display:flex;align-items:center;justify-content:center;gap:0;flex-wrap:wrap;gap:0}
.lh-step{text-align:center;padding:0 8px}
.lh-step-n{font-size:22px;font-weight:900;color:#7c3aed;letter-spacing:-1px}
.lh-step-t{font-size:12px;color:#6b7280;margin-top:2px}
.lh-step-line{width:40px;height:1px;background:linear-gradient(90deg,#e5e7eb,#c4b5fd,#e5e7eb);flex-shrink:0}
.lh-form-wrap{display:grid;grid-template-columns:1fr 1fr;gap:20px;max-width:1000px;margin:0 auto;padding:0 28px 60px}
.lh-card{background:#fff;border:1px solid #e5e7eb;border-radius:20px;padding:28px;box-shadow:0 4px 24px rgba(0,0,0,.07)}
.lh-card-head{display:flex;align-items:center;gap:10px;margin-bottom:24px;padding-bottom:16px;border-bottom:1px solid #f3f4f6}
.lh-card-ico{font-size:20px}
.lh-card-title{font-size:16px;font-weight:800;color:#1a1a2e}
.lh-preview-wrap{margin-bottom:20px;display:flex;justify-content:center}
.lh-preview{background:linear-gradient(135deg,#f5f3ff,#ede9fe);border:1px solid #ddd6fe;border-radius:16px;padding:20px 28px;text-align:center;min-width:180px}
.lh-preview-img{width:56px;height:56px;border-radius:50%;background:#c4b5fd;margin:0 auto 10px;display:flex;align-items:center;justify-content:center;font-size:24px;background-size:cover;background-position:center}
.lh-preview-name{font-size:15px;font-weight:800;color:#1a1a2e}
.lh-preview-sym{font-size:12px;color:#7c3aed;font-weight:700;margin-top:2px}
.lh-tax-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-top:6px}
.lh-tax-opt{display:flex;align-items:center;justify-content:center;padding:8px 4px;border:1px solid #e5e7eb;border-radius:8px;cursor:pointer;font-size:12px;font-weight:600;color:#6b7280;transition:all .2s}
.lh-tax-opt input{display:none}
.lh-tax-opt:has(input:checked){border-color:#7c3aed;background:#f5f3ff;color:#7c3aed}
.lh-tax-rec{position:relative}
.lh-tax-rec::after{content:'推荐';position:absolute;top:-8px;right:-4px;background:#7c3aed;color:#fff;font-size:9px;padding:1px 4px;border-radius:4px}
.lh-type-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:6px}
.lh-type-opt{cursor:pointer;border:1px solid #e5e7eb;border-radius:12px;transition:all .2s}
.lh-type-opt input{display:none}
.lh-type-opt:has(input:checked){border-color:#7c3aed;background:#f5f3ff}
.lh-type-body{padding:14px;text-align:center}
.lh-type-ico{font-size:24px;margin-bottom:4px}
.lh-type-name{font-size:13px;font-weight:700;color:#1a1a2e}
.lh-type-desc{font-size:11px;color:#9ca3af;margin-top:2px}
.lh-budget-tip{background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:10px 14px;font-size:12px;color:#15803d;margin-top:12px}
.lh-progress{position:fixed;inset:0;background:rgba(255,255,255,.9);backdrop-filter:blur(8px);display:flex;align-items:center;justify-content:center;z-index:200}
.lh-progress-inner{text-align:center;display:flex;flex-direction:column;align-items:center;padding:40px}
.lh-result{position:fixed;inset:0;background:rgba(255,255,255,.95);backdrop-filter:blur(8px);display:flex;align-items:center;justify-content:center;z-index:200}
.lh-result-inner{text-align:center;max-width:480px;padding:40px;background:#fff;border-radius:24px;box-shadow:0 8px 40px rgba(0,0,0,.12)}
.lh-result-title{font-size:28px;font-weight:900;color:#1a1a2e;letter-spacing:-1px;margin-bottom:8px}
.lh-result-addr{font-family:monospace;font-size:12px;color:#7c3aed;background:#f5f3ff;padding:8px 12px;border-radius:8px;word-break:break-all}
@media(max-width:768px){.lh-form-wrap{grid-template-columns:1fr}.lh-step-line{display:none}}

.lh-upload{border:2px dashed #e5e7eb;border-radius:12px;padding:16px;text-align:center;cursor:pointer;transition:all .2s;background:#fafafa;min-height:80px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px}
.lh-upload:hover{border-color:#7c3aed;background:#f5f3ff}
.lh-upload.has-img{border-style:solid;border-color:#7c3aed;background:#f5f3ff;padding:8px}
#lh-upload-icon{font-size:24px;transition:all .2s}
#lh-upload-tip{font-size:12px;color:#6b7280;line-height:1.4}

/* ── DELEGATE PAGE ── */
.dlg-hero{padding:80px 28px 48px;max-width:800px;margin:0 auto;text-align:center}
.dlg-hero-tag{font-size:11px;font-weight:700;color:#7c3aed;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:16px}
h2.dlg-hero-title{font-size:clamp(32px,5vw,56px);font-weight:900;letter-spacing:-2px;line-height:1;margin-bottom:14px;color:#1a1a2e}
.dlg-grad{background:linear-gradient(135deg,#7c3aed,#3b82f6);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.dlg-hero-sub{font-size:15px;color:#6b7280;line-height:1.8;margin-bottom:32px}
.dlg-agent-card{display:flex;align-items:center;gap:16px;background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:20px 24px;box-shadow:0 2px 16px rgba(0,0,0,.07);max-width:520px;margin:0 auto;text-align:left}
.dlg-agent-avatar{font-size:32px;width:52px;height:52px;background:linear-gradient(135deg,#f5f3ff,#ede9fe);border-radius:14px;display:grid;place-items:center;flex-shrink:0}
.dlg-agent-info{flex:1}
.dlg-agent-name{font-size:15px;font-weight:800;color:#1a1a2e;margin-bottom:4px}
.dlg-agent-status{font-size:12px;color:#6b7280;display:flex;align-items:center;gap:6px}
.dlg-pulse{display:inline-block;width:7px;height:7px;border-radius:50%;background:#10b981;box-shadow:0 0 0 0 rgba(16,185,129,.5);animation:pulse 1.5s infinite}
@keyframes pulse{0%{box-shadow:0 0 0 0 rgba(16,185,129,.5)}70%{box-shadow:0 0 0 8px rgba(16,185,129,0)}100%{box-shadow:0 0 0 0 rgba(16,185,129,0)}}
.dlg-agent-stats{display:flex;gap:20px}
.dlg-agent-stat{text-align:center}
.dlg-stat-n{font-size:22px;font-weight:900;color:#7c3aed}
.dlg-stat-l{font-size:10px;color:#9ca3af;margin-top:1px}
.dlg-tabs-wrap{padding:0 28px;max-width:900px;margin:0 auto}
.dlg-tabs{display:flex;gap:4px;border-bottom:1px solid #e5e7eb;padding-bottom:0}
.dlg-tab{padding:10px 20px;font-size:14px;font-weight:600;color:#6b7280;border:none;background:transparent;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .2s;font-family:inherit;border-radius:8px 8px 0 0}
.dlg-tab:hover{color:#1a1a2e;background:#f9fafb}
.dlg-tab.on{color:#7c3aed;border-bottom-color:#7c3aed;background:#fff}
.dlg-form-wrap{display:grid;grid-template-columns:1fr 1fr;gap:24px;max-width:900px;margin:32px auto 0;padding:0 28px}
.dlg-caps{display:flex;flex-direction:column;gap:12px}
.dlg-cap-item{display:flex;align-items:flex-start;gap:12px;padding:14px;background:#fff;border:1px solid #f3f4f6;border-radius:12px;transition:border-color .2s}
.dlg-cap-item:hover{border-color:#e9d5ff}
.dlg-cap-ico{font-size:20px;width:36px;height:36px;background:#f5f3ff;border-radius:8px;display:grid;place-items:center;flex-shrink:0}
.dlg-cap-t{font-size:13px;font-weight:700;color:#1a1a2e;margin-bottom:2px}
.dlg-cap-d{font-size:12px;color:#6b7280;line-height:1.5}
.dlg-erc-badge{margin-top:4px;display:flex;align-items:center;gap:8px;padding:10px 14px;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;font-size:12px;color:#15803d;font-weight:600}
.dlg-erc-dot{width:7px;height:7px;border-radius:50%;background:#10b981;flex-shrink:0}
.dlg-form-title{font-size:16px;font-weight:800;color:#1a1a2e;margin-bottom:20px;padding-bottom:12px;border-bottom:1px solid #f3f4f6}
.dlg-list-wrap{max-width:900px;margin:32px auto 80px;padding:0 28px}
.dlg-list-title{font-size:15px;font-weight:700;color:#1a1a2e;margin-bottom:16px}
.dlg-publish-wrap{max-width:680px;margin:32px auto 80px;padding:0 28px}
/* ── DASHBOARD PAGE ── */
.dash-hero{padding:72px 28px 40px;display:flex;align-items:flex-end;justify-content:space-between;max-width:1100px;margin:0 auto;flex-wrap:wrap;gap:16px}
.dash-hero-tag{font-size:11px;font-weight:700;color:#7c3aed;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:12px}
h2.dash-hero-title{font-size:clamp(28px,4vw,48px);font-weight:900;letter-spacing:-1.5px;line-height:1;margin-bottom:8px;color:#1a1a2e}
.dash-hero-sub{font-size:14px;color:#6b7280}
.dash-live-badge{display:flex;align-items:center;gap:8px;padding:8px 16px;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:20px;font-size:12px;font-weight:700;color:#15803d;white-space:nowrap}
.dash-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;max-width:1100px;margin:0 auto;padding:0 28px 32px}
.dash-stat-card{background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:24px;display:flex;align-items:center;gap:16px;box-shadow:0 2px 12px rgba(0,0,0,.06);transition:transform .2s}
.dash-stat-card:hover{transform:translateY(-2px)}
.dash-stat-icon{font-size:28px;width:52px;height:52px;background:#f5f3ff;border-radius:14px;display:grid;place-items:center;flex-shrink:0}
.dash-stat-num{font-size:28px;font-weight:900;color:#1a1a2e;letter-spacing:-1px}
.dash-stat-lbl{font-size:12px;color:#6b7280;margin-top:2px}
.dash-log-panel{max-width:1100px;margin:0 auto;padding:0 28px 80px}
.dash-log-head{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;background:#fff;border:1px solid #e5e7eb;border-radius:16px 16px 0 0;border-bottom:none}
.dash-log-title{font-size:14px;font-weight:700;color:#1a1a2e;display:flex;align-items:center}
.dash-log-count{font-size:12px;color:#9ca3af}
.dash-log-body{background:#fff;border:1px solid #e5e7eb;border-radius:0 0 16px 16px;min-height:300px;max-height:520px;overflow-y:auto;padding:8px}
.dash-log-body .le{border-bottom:1px solid #f9fafb;padding:12px 8px;font-size:13px;transition:background .15s}
.dash-log-body .le:hover{background:#fafafa}
.dash-log-body .le:last-child{border-bottom:none}
@media(max-width:768px){.dlg-form-wrap{grid-template-columns:1fr}.dash-stats{grid-template-columns:1fr}}
</style>
</head>
<body>
<div class="o1 orb"></div><div class="o2 orb"></div>
<canvas id="cvs" style="display:none"></canvas>
<nav>
  <div class="logo"><div class="li">◆</div><div class="lt">MemeBounty</div></div>
  <div class="nls">
    <button class="nl" onclick="G('launch',this)">🚀 一键发币</button>
    <button class="nl on" onclick="G('home',this)">任务大厅</button>
    <button class="nl" onclick="G('how',this)">运行逻辑</button>
    <button class="nl" onclick="G('fair',this)">公平保障</button>
    <button class="nl" onclick="G('delegate',this)">委托 Agent</button>
    <button class="nl" onclick="G('dashboard',this)">Agent 日志</button>
    <button class="nl" onclick="G('my',this)">我的</button>
  </div>
  <div style="display:flex;align-items:center;gap:10px">
    <button class="wbtn" id="wbtn" onclick="connectWallet()">连接钱包</button>
    <div class="wi" id="wi"><div class="wd"></div><span style="color:var(--su)" id="wa"></span></div>
  </div>
</nav>

<div id="page-launch" class="pw">

  <!-- 顶部大字 Hero -->
  <div class="lh-hero">
    <div class="lh-tag">◆ &nbsp;FOUR.MEME × MEMEBOUNTY</div>
    <h1 class="lh-title">三分钟<br><span class="lh-grad">发币 + 社区</span><br>全自动</h1>
    <p class="lh-sub">填写代币信息，AI Agent 自动接管——发激励任务、管社区、汇报数据。<br>你只需要一个想法。</p>
    <div class="lh-steps">
      <div class="lh-step"><div class="lh-step-n">01</div><div class="lh-step-t">填写代币信息</div></div>
      <div class="lh-step-line"></div>
      <div class="lh-step"><div class="lh-step-n">02</div><div class="lh-step-t">Four.meme 上链</div></div>
      <div class="lh-step-line"></div>
      <div class="lh-step"><div class="lh-step-n">03</div><div class="lh-step-t">Agent 自动激励</div></div>
    </div>
  </div>

  <!-- 表单区 -->
  <div class="lh-form-wrap">

    <!-- 左：代币信息 -->
    <div class="lh-card">
      <div class="lh-card-head"><span class="lh-card-ico">🪙</span><span class="lh-card-title">代币信息</span></div>

      <div class="lh-preview-wrap">
        <div class="lh-preview" id="lk-preview">
          <div class="lh-preview-img" id="lk-preview-img">🐸</div>
          <div class="lh-preview-name" id="lk-preview-name">代币名称</div>
          <div class="lh-preview-sym" id="lk-preview-sym">$SYM</div>
        </div>
      </div>

      <div class="fg"><label class="fl">代币名称 *</label>
        <input class="fi" id="lk-name" placeholder="例如 PepeKing"
          oninput="document.getElementById('lk-preview-name').textContent=this.value||'代币名称'">
      </div>
      <div class="fg"><label class="fl">代币符号 *</label>
        <input class="fi" id="lk-sym" placeholder="例如 PPKG" style="text-transform:uppercase"
          oninput="document.getElementById('lk-preview-sym').textContent='$'+(this.value.toUpperCase()||'SYM')">
      </div>
      <div class="fg"><label class="fl">一句话描述 *</label>
        <textarea class="fi" id="lk-desc" rows="2" placeholder="让大家一眼记住你的代币..." style="resize:none"></textarea>
      </div>
      <div class="fr2">
        <div class="fg"><label class="fl">分类</label>
          <select class="fs" id="lk-label">
            <option value="Meme">🐸 Meme</option>
            <option value="AI">🤖 AI</option>
            <option value="Defi">💰 Defi</option>
            <option value="Games">🎮 Games</option>
            <option value="Social">💬 Social</option>
            <option value="Others">📦 Others</option>
          </select>
        </div>
        <div class="fg"><label class="fl">Logo 图片</label>
          <div class="lh-upload" onclick="document.getElementById('lk-file').click()" id="lh-upload-area">
            <input type="file" id="lk-file" accept="image/*" style="display:none" onchange="onLogoUpload(this)">
            <div id="lh-upload-icon">📷</div>
            <div id="lh-upload-tip">点击上传图片<br><span style="font-size:10px;color:#9ca3af">jpg/png/gif/webp</span></div>
          </div>
        </div>
      </div>
    </div>

    <!-- 右：Agent 设置 -->
    <div class="lh-card">
      <div class="lh-card-head"><span class="lh-card-ico">🤖</span><span class="lh-card-title">Agent 激励设置</span></div>

      <div class="fg"><label class="fl">交易税率</label>
        <div class="lh-tax-grid">
          <label class="lh-tax-opt"><input type="radio" name="tax" value="" checked><span>无税</span></label>
          <label class="lh-tax-opt"><input type="radio" name="tax" value="1"><span>1%</span></label>
          <label class="lh-tax-opt lh-tax-rec"><input type="radio" name="tax" value="3"><span>3% 推荐</span></label>
          <label class="lh-tax-opt"><input type="radio" name="tax" value="5"><span>5%</span></label>
        </div>
        <div style="font-size:11px;color:#9ca3af;margin-top:6px">税收 100% 流入 AI Agent 钱包，用于自动发布激励任务</div>
      </div>

      <div class="fg" style="margin-top:16px"><label class="fl">首个激励任务类型</label>
        <div class="lh-type-grid">
          <label class="lh-type-opt" id="lt0">
            <input type="radio" name="tasktype" value="2" checked>
            <div class="lh-type-body"><div class="lh-type-ico">🚀</div><div class="lh-type-name">早鸟</div><div class="lh-type-desc">前N名持仓者先到先得</div></div>
          </label>
          <label class="lh-type-opt" id="lt1">
            <input type="radio" name="tasktype" value="0">
            <div class="lh-type-body"><div class="lh-type-ico">⏳</div><div class="lh-type-name">持仓</div><div class="lh-type-desc">持仓满X分钟领奖</div></div>
          </label>
        </div>
      </div>

      <div class="fr2" style="margin-top:16px">
        <div class="fg"><label class="fl">每人奖励（BNB）</label>
          <input class="fi" id="lk-reward" type="number" placeholder="0.005" value="0.005" step="0.001">
        </div>
        <div class="fg"><label class="fl">获奖名额</label>
          <input class="fi" id="lk-winners" type="number" placeholder="100" value="100">
        </div>
      </div>

      <div class="lh-budget-tip" id="lk-budget-tip">
        预计需要 <strong id="lk-total">0.515</strong> BNB（奖励池 + 3% 服务费）
      </div>

      <button class="btnp" style="width:100%;padding:14px;font-size:15px;font-weight:700;margin-top:20px;letter-spacing:.3px" onclick="launchToken()" id="launch-btn">
        🚀 立即发币 + 启动 Agent
      </button>
      <p style="font-size:11px;color:#9ca3af;text-align:center;margin-top:8px">发币 Gas ≈ 0.01 BNB · 由 Four.meme 提供链上服务</p>
    </div>
  </div>

  <!-- 进度 / 结果 -->
  <div class="lh-progress" id="launch-progress" style="display:none">
    <div class="lh-progress-inner">
      <div class="ai-spinner" style="width:40px;height:40px;border-width:3px"></div>
      <div id="lp-msg" style="font-size:14px;color:#6b7280;margin-top:16px;text-align:center">准备中...</div>
      <div id="lp-steps" style="width:100%;max-width:400px;margin-top:20px"></div>
    </div>
  </div>

  <div class="lh-result" id="launch-result" style="display:none">
    <div class="lh-result-inner">
