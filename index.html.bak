      <div class="dlg-caps">
        <div class="dlg-cap-item"><div class="dlg-cap-ico">🔍</div><div><div class="dlg-cap-t">链上观察</div><div class="dlg-cap-d">持续监控持仓分布、交易量、新地址增速</div></div></div>
        <div class="dlg-cap-item"><div class="dlg-cap-ico">🧠</div><div><div class="dlg-cap-t">LLM 决策</div><div class="dlg-cap-d">GPT-4o 分析数据，自主决定激励方案</div></div></div>
        <div class="dlg-cap-item"><div class="dlg-cap-ico">⛓️</div><div><div class="dlg-cap-t">自动执行</div><div class="dlg-cap-d">直接调合约发任务，资金锁链上不可挪用</div></div></div>
        <div class="dlg-cap-item"><div class="dlg-cap-ico">📡</div><div><div class="dlg-cap-t">实时汇报</div><div class="dlg-cap-d">Telegram 推送每次决策，随时暂停</div></div></div>
        <div class="dlg-erc-badge">
          <span class="dlg-erc-dot"></span>
          ERC-8183 · 资金链上托管 · 超时自动退款
        </div>
      </div>

      <!-- 右：表单 -->
      <div class="df">
        <div class="dlg-form-title">创建委托</div>
        <div class="fg"><label class="fl">目标代币地址</label><input class="fi" id="d0" placeholder="0x..."></div>
        <div class="fr2">
          <div class="fg"><label class="fl">预算（BNB）</label><input class="fi" id="d1" type="number" placeholder="1.0" oninput="calcD()"></div>
          <div class="fg"><label class="fl">管理周期（天）</label><input class="fi" id="d2" type="number" placeholder="30" oninput="calcD()"></div>
        </div>
        <div class="fg"><label class="fl">激励目标</label>
          <select class="fs" id="d3">
            <option value="hold">📉 提升持仓时长 — 减少抛压</option>
            <option value="grow">📈 增加持有地址 — 扩大社区</option>
            <option value="trade">⚡ 提升交易量 — 活跃市场</option>
            <option value="refer">🤝 裂变推荐 — 病毒传播</option>
          </select>
        </div>
        <div class="fg"><label class="fl">Telegram 通知（可选）</label><input class="fi" id="d4" placeholder="@username 或 chat_id"></div>
        <div class="sb" id="ds" style="display:none">预算：<span id="db"></span> BNB &nbsp;·&nbsp; 每日：<span id="dd"></span> BNB &nbsp;·&nbsp; 预估任务：<span id="dt"></span></div>
        <button class="btnp" style="width:100%;padding:13px;font-size:14px;letter-spacing:.3px" onclick="submitDelegate()">
          委托 Agent 开始工作 →
        </button>
        <p style="font-size:11px;color:#9ca3af;margin-top:8px;text-align:center">预算由 ERC-8183 合约托管，未使用部分随时取回</p>
      </div>
    </div>

    <!-- 当前委托列表 -->
    <div class="dlg-list-wrap">
      <div class="dlg-list-title">当前委托</div>
      <div id="dlist"><div class="empty">暂无委托记录</div></div>
    </div>
  </div>

  <!-- TAB: AI 发布任务 -->
  <div id="dt-publish" style="display:none">
    <div class="dlg-publish-wrap">
      <div class="ai-step" id="ai-step1">
        <div class="dlg-form-title">✨ 告诉 AI 你想要什么</div>
        <div class="fg"><label class="fl">代币地址</label><input class="fi" id="p-token" placeholder="0x..."></div>
        <div class="fr2">
          <div class="fg"><label class="fl">代币符号</label><input class="fi" id="p-symbol" placeholder="PEPE..."></div>
          <div class="fg"><label class="fl">预算（BNB）</label><input class="fi" id="p-budget" type="number" placeholder="0.5"></div>
        </div>
        <div class="fg">
          <label class="fl">一句话描述目标</label>
          <textarea class="fi" id="p-intent" rows="3" placeholder="例如：我想让大家长期持有，减少抛压&#10;例如：前100名买入都有奖励&#10;例如：推荐好友买入，裂变传播" style="resize:none;line-height:1.6"></textarea>
        </div>
        <div class="ai-examples">
          <div class="ai-ex-label">快速选择：</div>
          <button class="ai-ex" onclick="setIntent(this)">💎 减少抛压，激励长期持仓</button>
          <button class="ai-ex" onclick="setIntent(this)">🚀 吸引新用户，前N名有奖</button>
          <button class="ai-ex" onclick="setIntent(this)">🤝 推荐好友，裂变扩大社区</button>
          <button class="ai-ex" onclick="setIntent(this)">🏆 锦标赛，持仓越多奖越多</button>
          <button class="ai-ex" onclick="setIntent(this)">💰 刺激交易量，买入有奖励</button>
        </div>
        <button class="btnp" style="width:100%;padding:13px;margin-top:20px;font-size:14px;display:flex;align-items:center;justify-content:center;gap:8px" onclick="generateTask()">
          <span>✨</span><span>AI 生成任务方案</span>
        </button>
      </div>

      <div class="ai-step" id="ai-step2" style="display:none">
        <div class="dlg-form-title">02 · AI 生成方案</div>
        <div class="ai-loading" id="ai-loading">
          <div class="ai-spinner"></div>
          <div>AI 正在分析需求，生成最优链上任务方案...</div>
        </div>
        <div id="ai-result" style="display:none">
          <div class="ai-preview">
            <div class="ai-preview-head">
              <div class="ai-type-badge" id="r-type-badge"></div>
              <div class="ai-reasoning" id="r-reasoning"></div>
            </div>
            <div class="ai-preview-title" id="r-title"></div>
            <div class="ai-preview-desc" id="r-desc"></div>
            <div class="ai-params" id="r-params"></div>
          </div>
          <div style="display:flex;gap:10px;margin-top:16px">
            <button class="btns" style="flex:1" onclick="backToStep1()">← 重新生成</button>
            <button class="btnp" style="flex:2;padding:12px" onclick="confirmPublish()">确认发布上链 →</button>
          </div>
        </div>
      </div>

      <div class="ai-step" id="ai-step3" style="display:none">
        <div class="dlg-form-title">03 · 发布上链</div>
        <div class="ai-loading">
          <div class="ai-spinner"></div>
          <div id="publish-status">等待钱包确认...</div>
        </div>
      </div>
    </div>
  </div>
</div>
